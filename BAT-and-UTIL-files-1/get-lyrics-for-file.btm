        :actually_rename_every_file_as_an_instrumental_or_whatever [opt1 opt2 opt3]
                set ask=0
                if "%1" == "%ask" .or. "%@UNQUOTE["%opt1%"]" == "ask" set ask=1
                for %%tmpFileForXAnswer in (%FILEMASK_AUDIO%) do (gosub ask_to_rename_file_as_instrumental_or_whatever "%@UNQUOTE["%tmpFileForXAnswer%"]" "%@unquote["%opt1%"]" "%@unquote["%opt2%"]" "%@unquote["%opt3%"]" )

        return
                :ask_to_rename_file_as_instrumental_or_whatever [tmpFileForXAnswer_copy opt2 opt3]

                        rem Cosmetics:
                                rem echo %ANSI_COLOR_DEBUG%- DEBUG: called :ask_to_rename_file_as_instrumental_or_whatever [%tmpFileForXAnswer_copy% opt2 opt3] ... ask=“%ask%”... force_mark_every_file_as_instrumental=“%force_mark_every_file_as_instrumental%” ... force_mark_every_file_as_NOT_an_instrumental=“%force_mark_every_file_as_NOT_an_instrumental%” ... answer=“%answer%”%ANSI_COLOR_NORMAL%
                                :begin_loop_arefaaiow
                                repeat 2 echo.
                                echos %ansi_color_important%%star% Filename: 
                                echos  %@Randfg_soft[]
                                echo    “%@UNQUOTE["%tmpFileForXAnswer_copy%"]”

                        rem Set various filenames, including the ADS filename for if it’s an instrumental::
                                rem 2025/03/29 after "P" kept playing a different file from wayyy before
                                set             audio_file=%@UNQUOTE["%tmpFileForXAnswer_copy%"]
                                set  potential_lrc=%@NAME["%@UNQUOTE["%tmpFileForXAnswer_copy%"]"].lrc
                                set  potential_srt=%@NAME["%@UNQUOTE["%tmpFileForXAnswer_copy%"]"].srt
                                set  potential_txt=%@NAME["%@UNQUOTE["%tmpFileForXAnswer_copy%"]"].txt
                                set potential_json=%@NAME["%@UNQUOTE["%tmpFileForXAnswer_copy%"]"].json
                                set  our_extension=%@EXT["%tmpFileForXAnswer_copy%"]
                                set  our_full_path=%@FULL["%tmpFileForXAnswer_copy%"]
                                :begin_loop_arefaaiow_for_real
                                unset /q ANSWER potential_is_instrumental 
                                set IS_INSTRUMENTAL_ADS_FILENAME=%@name[%@UNQUOTE["%tmpFileForXAnswer_copy%"]].%@EXT[%@UNQUOTE["%tmpFileForXAnswer_copy%"]]:is_instrumental


                        rem MIDI files can’t have vocals, so should automatically be excluded from this.
                        rem other trackers files through——such as MOD, STM, S3M——could still have *samples* of vocals, so they could still be transcribeable, except WhisperAI would not handle them.
                                rem echo     %glitch_star%  our_extension=“%our_extension%” ... is this valid?
                                iff "%our_extension%" == "mid" .or. "%our_extension%" == "mod" .or. "%our_extension%" == "stm" .or. "%our_extension%" == "s3m" .or. "%our_extension%" == "rol" .or. "%our_extension%" == "cmf"  then
                                        echo     %ansi_color_warning_soft%%star4% “%italics_on%%our_extension%%italics_off%” is %italics_on%not%italics_off% a transcribeable file type!
                                        echo     %ansi_color_warning_soft%%star5% Tagging “%italics_on%is_instrumental%italics_off%” ADS as “%italics_on%True%italics_off%”
                                        echo True>"%IS_INSTRUMENTAL_ADS_FILENAME%"
                                        return
                                endiff

                        rem Skip sound effects:
                                iff "1" == "%@REGEX[SOUND EFFECT,%@UPPER[%@full["%tmpFileForXAnswer_copy%"]]]" .or. "1" == "%@REGEX[SOUND CLIP,%@UPPER[%@full["%tmpFileForXAnswer_copy%"]]]" then
                                        set value=True
                                        echo     %ansi_color_warning_soft%%star4% “%italics_on%%@UNQUOTE["%tmpFileForXAnswer_copy%"]%italics_off%” is a %italics_on%sound effect%italics_off% and thus not transcribeable!
                                        echo     %ansi_color_warning_soft%%star5% Tagging “%italics_on%is_instrumental%italics_off%” ADS as “%italics_on%%value%%italics_off%” since sound effects don’t have words
                                        echo %value%>"%IS_INSTRUMENTAL_ADS_FILENAME%"
                                        return
                                endiff
                        
                        rem If we are in force mode, just do it:
                                if "%2" == "force" .or. "1" == "%force_unmark_every_file_as_instrumental%" .or. "1" == "%force_mark_every_file_as_instrumental%" .or. "1" == "%force_mark_every_file_as_NOT_an_instrumental%" goto /i endiff_skip_checks_becase_forcing_it_2865
                                        set potential_is_instrumental=%@EXECSTR[type "%@UNQUOTE["%tmpFileForXAnswer_copy%"]:is_instrumental" >>&>nul] 
                                        if      "1" == "%@Regex[[\[\(]instrumental[\]\)],"%tmpFileForXAnswer_copy%"]" (echo %STAR3% Already named an instrumental! %+ return) 

                                        rem Check if it’s already marked via ADS tag:
                                                rem echo potential_is_instrumental == "%potential_is_instrumental%" 
                                                if "NOT_SET" == "%potential_is_instrumental%" goto not_yet_marked_2850
                                                if   "False" == "%potential_is_instrumental%" goto already_marked_2875
                                                if    "True" == "%potential_is_instrumental%" goto already_marked_2875
                                                if        "" == "%potential_is_instrumental%" goto not_yet_marked_2850
                                                goto not_yet_marked_2850
                                                        :already_marked_2875
                                                                echo %STAR% instrumental status already marked as: “%potential_is_instrumental%”
                                                                return
                                                :not_yet_marked_2850
                        
                                        rem Preview sidecar files if applicable:
                                                if "1" == "%ask%" goto show_previews
                                                if "1" != "%currently_getting_lyrics%" goto /i endiff_endpoint_because_currently_getting_lyrics
                                                        :show_previews
                                                        if  exist  "%potential_txt%" call review-file      -wh "%potential_txt%"
                                                        if  exist  "%potential_lrc%" call review-file      -wh "%potential_lrc%"
                                                        if  exist  "%potential_srt%" call review-file -ins -wh "%potential_srt%"
                                                :endiff_endpoint_because_currently_getting_lyrics
                                :endiff_skip_checks_becase_forcing_it_2865

                        rem Re-create the is_instrumental ads-tag filename because things may have changed:
                                :about_to_askyn_3390
                                set IS_INSTRUMENTAL_ADS_FILENAME=%@name[%@UNQUOTE["%tmpFileForXAnswer_copy%"]].%@EXT[%@UNQUOTE["%tmpFileForXAnswer_copy%"]]:is_instrumental %+ rem update this so our ads tagging doesn’t mark the old filename

                        rem Ask if it is an instrumental——unless we’re not supposed to ask!
                                rem pause hmmmm[1] ask=“%ask%”, answer=“%answer%”
                                unset /q ANSWER
                                unset /q OUTER_INSTRUMENTAL_ANSWER 
                                if "1" == "%ask%" call  AskYN "Instrumental? [%ansi_color_bright_green%P%ansi_color_prompt%lay/%ansi_color_bright_green%R%ansi_color_prompt%ename/%ansi_color_bright_green%D%ansi_color_prompt%el sidecars/is %ansi_color_bright_green%s%ansi_color_prompt%ound effect/s%ansi_color_bright_green%K%ansi_color_prompt%ip/%ansi_color_bright_green%A%ansi_color_prompt%=mark instr with ADS tag {for semi-instr}]"  no     0      ADIKPQRS    Q:enQueue_in_winamp,P:play_it,I:yup_it_is_instrumental,R:rename_it!!,D:delete_some_of_the_sidecar_files,S:mark_as_sound_effect,K:sKip_answering,A:mark_instr_with_ADS_tag
                                set OUTER_INSTRUMENTAL_ANSWER=%ANSWER%

                        rem If we are renaming it:
                                iff "M" == "%OUTER_INSTRUMENTAL_ANSWER%" then
                                        gosub check_for_answer_of_M "%@UNQUOTE[%AUDIO_FILE%]"
                                        goto /i about_to_askyn_3390
                                endiff

                        rem If we want to mark it as a sound effect, do that:
                                iff "S" == "%OUTER_INSTRUMENTAL_ANSWER%" then
                                        gosub rename_audio_file_as_sound_effect "%@UNQUOTE["%tmpFileForXAnswer_copy%"]"  tmpFileForXAnswer_copy
                                        echo - DEBUG: LAST_RENAMED_TO=%lq%%LAST_RENAMED_TO%%rq% 🐈
                                        if "" == "%LAST_RENAMED_TO%" goto /i do_not__update_3032
                                                set tmpFileForXAnswer_copy=%LAST_RENAMED_TO% 
                                                set IS_INSTRUMENTAL_ADS_FILENAME=%@name[%@UNQUOTE["%tmpFileForXAnswer_copy%"]].%@EXT[%@UNQUOTE["%tmpFileForXAnswer_copy%"]]:is_instrumental
                                        :do_not__update_3032
                                        echo - DEBUG: tmpFileForXAnswer_copy now == %lq%%tmpFileForXAnswer_copy%%rq% .. LAST_RENAMED_TO was %lq%%LAST_RENAMED_TO%%rq% 
                                        goto about_to_askyn_3390
                                endiff

                        rem If we are forcing a global change, just do it:
                                iff "1" == "%force_unmark_every_file_as_instrumental%" .or. "1" == "%force_mark_every_file_as_instrumental%" .or. "1" == "%force_mark_every_file_as_NOT_an_instrumental%" then
                                        echo %ansi_color_important% %star2% Removing %lq%as_instrumental%rq% ADS tag
                                        unset /q ANSWER
                                                                                                   set TMP_VALUE=NOT_SET
                                        if "1" == "%force_mark_every_file_as_instrumental%"        set TMP_VALUE=True
                                        if "1" == "%force_mark_every_file_as_NOT_an_instrumental%" set TMP_VALUE=False
                                        echo echo %TMP_VALUE%`>`"%IS_INSTRUMENTAL_ADS_FILENAME%"%newline%
                                             echo %TMP_VALUE%  >"%IS_INSTRUMENTAL_ADS_FILENAME%"
                                endiff


                        rem Deal with playing/enqueing the file, in case we can’t decide and need to preview it:
                                rem DEBUG: pause "is this where things go haywire? checking p"
                                if "P" == "%OUTER_INSTRUMENTAL_ANSWER%" gosub check_for_answer_of_P  "%@UNQUOTE["%tmpFileForXAnswer_copy%"]"
                                rem DEBUG: pause "is this where things go haywire? checking q [OUTER_INSTRUMENTAL_ANSWER=OUTER_INSTRUMENTAL_ANSWER]"
                                if "Q" == "%OUTER_INSTRUMENTAL_ANSWER%" gosub check_for_answer_of_Q  "%@UNQUOTE["%tmpFileForXAnswer_copy%"]"
                                rem DEBUG: pause "is this where things go haywire? guess not?  [OUTER_INSTRUMENTAL_ANSWER=OUTER_INSTRUMENTAL_ANSWER]"

                        rem If we hit “R” for Rename, then process the renaming, which will require re-creating the is_instrumental ADS filename:
                                rem pause hmmmm[2] ask=“%ask%”, answer=“%OUTER_INSTRUMENTAL_ANSWER%” %+ echo off
                                if "R" != "%OUTER_INSTRUMENTAL_ANSWER%" goto /i endiff_3062
                                        unset /q LAST_RENAMED_TO
                                        call rn "%@UNQUOTE["%tmpFileForXAnswer_copy%"]"
                                        echo %ansi_color_blue%- DEBUG:after rn at 3020, last_renamed_to=“%LAST_RENAMED_TO%” so maybe set tmpFileForXAnswer_copy=%LAST_RENAMED_TO%%newline%- DEBUG: tmpFileForXAnswer_copy is now “%tmpFileForXAnswer_copy%” and IS_INSTRUMENTAL_ADS_FILENAME is now “%IS_INSTRUMENTAL_ADS_FILENAME%”%ansi_color_normal%
                                        if "" == "%LAST_RENAMED_TO%" goto /i endiff_3058
                                                rem DEBUG: echo - DEBUG: %ZZZZZZzZ%ansi_color_pink%set  tmpFileForXAnswer_copy=%LAST_RENAMED_TO% !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!%ansi_color_normal% 
                                                set SOME_INSTRUMENTALS_WERE_MARKED=1
                                                set  tmpFileForXAnswer_copy=%LAST_RENAMED_TO%
                                                echo tmpFileForXAnswer_copy is [A] now “%tmpFileForXAnswer_copy%”
                                                rem DEBUG: echo - DEBUG: %zzzzzzz%%ansi_color_pink%set  IS_INSTRUMENTAL_ADS_FILENAME=%@name[%@UNQUOTE["%tmpFileForXAnswer_copy%"]].%@EXT[%@UNQUOTE["%tmpFileForXAnswer_copy%"]]:is_instrumental`%+`%ansi_color_purple%rem update this so our ads tagging doesn’t %ansi_color_normal%
                                                set  IS_INSTRUMENTAL_ADS_FILENAME=%@name[%@UNQUOTE["%tmpFileForXAnswer_copy%"]].%@EXT[%@UNQUOTE["%tmpFileForXAnswer_copy%"]]:is_instrumental %+ rem update this so our ads tagging doesn’t 
                                                echo IS_INSTRUMENTAL_ADS_FILENAME is [A] now ‘%IS_INSTRUMENTAL_ADS_FILENAME%’
                                        :endiff_3058
                                        echo %ansi_color_debug%- DEBUG:after rn at 3024, last_renamed_to=“%LAST_RENAMED_TO%” so maybe set tmpFileForXAnswer_copy=%LAST_RENAMED_TO%
                                        echo %ansi_color_debug%- DEBUG: tmpFileForXAnswer_copy is now “%tmpFileForXAnswer%” and IS_INSTRUMENTAL_ADS_FILENAME is now “%IS_INSTRUMENTAL_ADS_FILENAME%”%ansi_color_normal%
                                :endiff_3062


                        rem If we answered “A” to mark “is_instrumental” as “True” using ADS tags, deal with it
                                rem  (This is something we’ve decided to NOT do as a general rule, so that filenames matter more than ADS tags)
                                rem  (But in the case of files marked “[semi-instrumental]”, we MAY want to do this)
                                iff  "A" == "%OUTER_INSTRUMENTAL_ANSWER%" then
                                        echo True>"%IS_INSTRUMENTAL_ADS_FILENAME%"
                                endiff


                        rem Certain answers require us asking the question again after answering:
                                if  "A" == "%OUTER_INSTRUMENTAL_ANSWER%"  goto /i about_to_askyn_3390
                                if  "P" == "%OUTER_INSTRUMENTAL_ANSWER%"  goto /i about_to_askyn_3390
                                if  "Q" == "%OUTER_INSTRUMENTAL_ANSWER%"  goto /i about_to_askyn_3390
                                if  "R" == "%OUTER_INSTRUMENTAL_ANSWER%"  goto /i about_to_askyn_3390

                        rem If we answered “N” for “NO, it’s not an instrumental”, then update the ADS filename with a “false” value for “is_instrumental”:
                                if  "N" == "%OUTER_INSTRUMENTAL_ANSWER%"  echo False>"%IS_INSTRUMENTAL_ADS_FILENAME%"


                        rem More stuff to deal with FORCED modes where we AREN’T supposed to ask the user for each file:
                                rem pause hmmm[3] if  "1" == "%force_unmark_every_file_as_instrumental%" 
                                iff "1" == "%force_unmark_every_file_as_instrumental%" .or. "1" == "%force_mark_every_file_as_NOT_an_instrumental%" then
                                        echo %ansi_color_unimportant% %star2% We%smart_apostrophe%re not doing renaming in this mode
                                        return 
                                else
                                        if "%1" != "ask" set   answer=y
                                endiff

                        rem If we hit “D” to delete sidecar files,w e need to deal with that:
                                if  "D" == "%OUTER_INSTRUMENTAL_ANSWER%"  goto /i delete_some_of_the_sidecar_files_2880


                        rem If we ultimately said “Y”/“I” for “Yes, it’s an Instrumental”, then mark it as such:
                                if  "Y" != "%OUTER_INSTRUMENTAL_ANSWER%" .and. "I" != "%OUTER_INSTRUMENTAL_ANSWER%" goto /i endiff_not_y_2856
                                        set SOME_INSTRUMENTALS_WERE_MARKED=1

                                        rem Let’s not use the ADS tag, since we will be renaming the file:
                                        rem *echo True>"%IS_INSTRUMENTAL_ADS_FILENAME%"
                                        rem ...instead let’s mostly use the ADS tag to mark False, but never True


                                        :delete_some_of_the_sidecar_files_2880
                                        %color_removal%
                                        set HELD_ANSWER_2876=%OUTER_INSTRUMENTAL_ANSWER%
                                                echo - DEBUG: delete some sidecar files??? potential_srt=“%potential_srt%” / potential_txt=“%potential_txt%” / potential_lrc=“%potential_lrc%”
                                                if not exist     "%potential_srt%"  goto /i endiff_not_exist_potential_srt 
                                                        call review-file -ins -wh "%potential_srt%"
                                                        call AskYN  "Delete SRT file" yes 0
                                                                if "Y" != "%ANSWER%"       goto /i endiff_not_exist_potential_srt 
                                                                echos %ansi_color_removal%
                                                                gosub delete_file "%potential_srt%"
                                                :endiff_not_exist_potential_srt 

                                                if not exist     "%potential_lrc%"  goto /i endiff_not_exist_potential_lrc 
                                                        call review-file -wh "%potential_lrc%"
                                                        call AskYN  "Delete LRC file" yes 0
                                                                if "Y" != "%ANSWER%"       goto /i endiff_not_exist_potential_lrc 
                                                                echos %ansi_color_removal%
                                                                gosub delete_file "%potential_lrc%"
                                                :endiff_not_exist_potential_lrc 

                                                if not exist     "%potential_txt%"  goto /i endiff_not_exist_potential_txt
                                                        call review-file -wh "%potential_txt%"
                                                        call AskYN  "Delete TXT file" yes 0
                                                                if "Y" != "%ANSWER%"       goto /i endiff_not_exist_potential_txt 
                                                                echos %ansi_color_removal%
                                                                gosub delete_file "%potential_txt%"
                                                :endiff_not_exist_potential_txt

                                                if not exist     "%potential_json%" goto /i endiff_not_exist_potential_json
                                                        echos %ansi_color_removal%
                                                        gosub delete_file "%potential_json%"
                                                :endiff_not_exist_potential_json
                                                echos %ansi_color_normal%
                                                           %color_normal%
                                        set ANSWER=%HELD_ANSWER_2876%

                                        rem If we are here because we hit “D” instead of “I”, then we just wanted to [D]elete the sidecar files, 
                                        rem not [M]ark it as an instrumental, so we need to skip over that part and not mark it as an instrumental:
                                                if  "D" == "%OUTER_INSTRUMENTAL_ANSWER%"  goto /i endiff_not_y_2856

                                        rem If we are here, time to ACTUALLY mark it as an instrumental, as well as time
                                        rem to and update the %tmpFileForXAnswer_copy% filename if the rename was successful:
                                                gosub rename_audio_file_as_instrumental "%@UNQUOTE["%tmpFileForXAnswer_copy%"]" %opt1% %opt2% %opt3%
                                                echo DEBUG: after rename, LAST_RENAMED_TO=“%LAST_RENAMED_TO%”
                                                iff "%LAST_RENAMED_TO%" != "" then
                                                        set tmpFileForXAnswer_copy=%LAST_RENAMED_TO%
                                                        set IS_INSTRUMENTAL_ADS_FILENAME=%@name[%@UNQUOTE["%tmpFileForXAnswer_copy%"]].%@EXT[%@UNQUOTE["%tmpFileForXAnswer_copy%"]]:is_instrumental
                                                endiff
                                :endiff_not_y_2856
                return                                                          %+ rem return from actually_rename_every_file_as_an_instrumental_or_whatever 

        :approve_lyrics_done [%opt%]
                rem TODO: consider if we should call approve-lyrics with the file here, or if that’s not necessary if we approved it in-the-moment such that we encoded it. 
                set LYRIC_STATUS=APPROVED
                set LYRICS_FETCHED=1
                set LYRICS_ACCEPTABLE=1
                set JUST_APPROVED_LYRICS=1               
                if "1" != "%[logged_lyricapproval_%AUDIO_FILE%]" @echo %@REPEAT[%newline%,2]%EMOJI_DESKTOP_COMPUTER% %_DATETIME: %check% Approved: Lyrics: “%@UNQUOTE[%@FULL["%AUDIO_FILE%"]]” >>:u8"%AUDIOFILE_TRANSCRIPTION_LOG_FILE%"
                set          logged_lyricapproval_%AUDIO_FILE%=1
        return

        :ask_about_instrumental [as_what]
                rem DEBUG: echo %ansi_color_debug%🐐%blink_on%🐐%blink_off%🐐 called ask_about_instrumental [as_what=“%as_what”] [answer]%ansi_color_normal%

                rem reset flags:
                        set JUST_RENAMED_TO_INSTRUMENTAL=0      %+ rem added 2025/05/15

                rem ADS tag checking:
                        set HAS_INSTRUMENTAL_ADS_TAG=0
                        if "%as_what%" == "" set temp_ads_tag_name=is_instrumental
                        if "%as_what%" != "" set temp_ads_tag_name=is_%as_what%
                        set IS_INSTRUMENTAL_or_whatever_ADS_FILENAME=%@name[%@UNQUOTE["%AUDIO_FILE%"]].%@EXT[%@UNQUOTE["%AUDIO_FILE%"]]:%temp_ads_tag_name%
                        if "1" == "%DEBUG_ADS_MARKING%" echo IS_INSTRUMENTAL_or_whatever_ADS_FILENAME=%IS_INSTRUMENTAL_or_whatever_ADS_FILENAME%

                rem Did we already ask about this one?
                        iff "1" != "%[already_asked_about_%IS_INSTRUMENTAL_or_whatever_ADS_FILENAME%]" then
                                 set  already_asked_about_%IS_INSTRUMENTAL_or_whatever_ADS_FILENAME%=1
                        else
                                echo %ansi_color_warning_soft%%star2% Already asked about this song.... (already_asked_about_%IS_INSTRUMENTAL_or_whatever_ADS_FILENAME%=“%[already_asked_about_%IS_INSTRUMENTAL_or_whatever_ADS_FILENAME%]”)%ansi_color_normal%
                                if "%PARENT_BAT%" != "" .and. "%PARENT_BAT%" != "create-srt-from-file" return

                                rem 2025/09: let’s just return, getting double-asked is becoming annoying:
                                return
                        endiff

                rem if it’s not marked as instrumental, ask if it is one...
                        if "1" == "%DEBUG_ADS_MARKING%" echo 🐐 checking[f] iff "1" == "`%`@Regex[instrumental,"%AUDIO_FILE%"]" == "%@Regex[instrumental,"%AUDIO_FILE%"]" then
                        if "1" != "%@Regex[instrumental,"%AUDIO_FILE%"]" goto /i else_2280
                                if "1" == "%DEBUG_ADS_MARKING%" gosub debug "❶ Marked file with ADS tag of %italics_on%True%italics_off%: “%IS_INSTRUMENTAL_or_whatever_ADS_FILENAME%”"
                                echo True>"%IS_INSTRUMENTAL_or_whatever_ADS_FILENAME%"
                                goto /i endiff_2318
                        :else_2280
                                rem Read or ask answer about if it’s an instrumental or not:                                                                                                                                                                                     %+ rem echo checking[g] iff "1" != HAS_INSTRUMENTAL_ADS_TAG="%HAS_INSTRUMENTAL_ADS_TAG%" then
                                if "1" != "%HAS_INSTRUMENTAL_ADS_TAG%" goto /i do_it_2282
                                                                       goto /i else_do_it_2294
                                        :do_it_2282
                                        set HELD_ANSWER=%ANSWER%
                                                :ask_again_2283
                                                unset /q ANSWER

                                                if "1" == "%ASKED_ABOUT_INSTRUMENTAL_ALREADY%" .or. "1" == "%LYRICS_SHOULD_BE_CONSIDERED_ACCEPTIBLE%" goto :asked_about_intrumental_already_or_we_skipped_it

                                                if not defined IS_THIS_AN_INSTRUMENTAL_WAIT_TIME call validate-environment-variable IS_THIS_AN_INSTRUMENTAL_WAIT_TIME
                                                call AskYN "₁Is this an instrumental? [%ansi_color_bright_green%P%faint_on%/%faint_off%Q%ansi_color_prompt%=Preview/enQueue,%ansi_color_bright_green%S%ansi_color_prompt%=sound effect]" No %IS_THIS_AN_INSTRUMENTAL_WAIT_TIME% IPQS Q:enQueue_in_winamp,P:preview_song,I:instrumental_it_is!,S:no_but_its_a_sound_effect
                                                SET ASKED_ABOUT_INSTRUMENTAL_ALREADY=1
                                                SET LAST_ANSWER_TO_ISTHISINSTRUMENTAL=%ANSWER%

                                                gosub check_for_answer_of_P "%@UNQUOTE[%AUDIO_FILE%]"
                                                if "P" == "%ANSWER%" gosub ask_again_2283

                                                SET   ANSWER=%LAST_ANSWER_TO_ISTHISINSTRUMENTAL%
                                                gosub check_for_answer_of_Q "%@UNQUOTE[%AUDIO_FILE%]"
                                                if "Q" == "%ANSWER%" gosub ask_again_2283

                                                SET   ANSWER=%LAST_ANSWER_TO_ISTHISINSTRUMENTAL%
                                                gosub check_for_answer_of_S "%@UNQUOTE[%AUDIO_FILE%]"
                                                if "S" == "%ANSWER%" gosub ask_again_2283

                                                SET   ANSWER=%LAST_ANSWER_TO_ISTHISINSTRUMENTAL%
                                                if "I" == "%ANSWER%" .or. "Y" == "%ANSWER%" (echos %EMOJI_BEAR% %+ gosub rename_audio_file_as_instrumental %+ goto /i END_OF_GET_LYRICS)
                                        set   ANSWER=%HELD_ANSWER%
                                        :asked_about_intrumental_already_or_we_skipped_it
                                        goto /i endiff_2300
                                :else_do_it_2294
                                        rem Unreachable block of code but want to leave it here anyway:
                                                iff "1" == "%ADS_TAG_SAYS_INSTRUMENTAL%" then
                                                        set ANSWER=Y
                                                else
                                                        set ANSWER=N
                                                endiff
                                :endiff_2300
                        
                                                                                                                                                                                                                rem echo ** if "Y" ==   LAST_ANSWER_TO_ISTHISINSTRUMENTAL{which is "%LAST_ANSWER_TO_ISTHISINSTRUMENTAL%"} then..  %+ rem echo ** if "Y" == "%LAST_ANSWER_TO_ISTHISINSTRUMENTAL%" then
                                iff "Y" == "%LAST_ANSWER_TO_ISTHISINSTRUMENTAL%" then
                                        rem DEBUG: gosub debug "❷[222] Marked file with ADS tag: “%IS_INSTRUMENTAL_or_whatever_ADS_FILENAME%”"
                                        echo True>"%IS_INSTRUMENTAL_or_whatever_ADS_FILENAME%"
                                        iff "" !=  "%LAST_RENAMED_TO%" then
                                                set AUDIO_FILE=%@UNQUOTE[%LAST_RENAMED_TO%]
                                                set JUST_RENAMED_TO_INSTRUMENTAL=1
                                                set IS_INSTRUMENTAL_or_whatever_ADS_FILENAME=%@name[%@UNQUOTE["%AUDIO_FILE%"]].%@EXT[%@UNQUOTE["%AUDIO_FILE%"]]:%temp_ads_tag_name%
                                                pause "goatgoat IS_INSTRUMENTAL_or_whatever_ADS_FILENAME=%IS_INSTRUMENTAL_or_whatever_ADS_FILENAME%"
                                        endiff
                                        gosub rename_audio_file_as_instrumental %@UNQUOTE["%AUDIO_FILE%"]
                                        goto /i END_OF_GET_LYRICS %+ rem TODOTODO? 2025/05/07 update: will this stop the problem of asking us to mark it as a failed transcription in the case of renaming a file as an instrumental after a lyricless transcription that triggers out “possible instrumental detected” logic ? 2026/04: I dunno, i guess? don’t recall this still being a problem anymore
                                        goto /i endiff_2313
                                else
                                        rem echo We just said Noooooooooooo to if it’s an instrumental.........
                                        echo False>"%IS_INSTRUMENTAL_or_whatever_ADS_FILENAME%"
                                        rem DEBUG: gosub debug "❸[333] Marked file with ADS tag of %italics_on%FALSE%italics_off%: “%IS_INSTRUMENTAL_or_whatever_ADS_FILENAME%”"
                                endiff

                                rem echo            🐐 gonna gosub rename_audio_file_as_instrumental from ask_about_instrumental
                        :endiff_2318
        return

        :ask_if_want_mark_lyriclessness []
                rem DEBUG: echo 🌷🌷🌷  Asking if we want to mark as lyricless.... 🌷🌷🌷 >nul
                echo %ansi_color_advice%%star2% NOTE: “%ansi_color_bright_yellow%lyric%underline_on%less%underline_on%%ansi_color_advice%”     means “we can’t/won’t find lyrics for this song”
                echo %ansi_color_advice%%star2%       “%ansi_color_bright_yellow%linstrumental%ansi_color_advice%” means “no words are sung or spoken at all”
                :ask_if_want_mark_lyriclessness_2
                unset /q ANSWER
                call AskYn "Want to mark this song %ansi_color_bright_green%i%ansi_color_prompt%nstrumental or %ansi_color_bright_green%l%ansi_color_prompt%yrics %underline_on%unfindable%underline_off% (i.e. officially abandon our lyric search[%ansi_color_bright_green%Z%ansi_color_prompt%=All]) [P=%ansi_color_bright_green%P%ansi_color_prompt%lay]" no %IS_THIS_AN_INSTRUMENTAL_WAIT_TIME% IGLPQZ I:Mark_this_file_as_an_instrumental,G:Google,L:It’s_Lyricless,Z:Mark_all_as_lyricless,Q:enQueue_in_winamp,P:Play_it %+ rem 🐮 borrowed wait time
                gosub check_for_answer_of_G
                gosub check_for_answer_of_I "%@UNQUOTE[%AUDIO_FILE%]"
                if "1" == "%GOTO_END%" (goto /i END_OF_GET_LYRICS)
                gosub check_for_answer_of_L
                gosub 
                gosub check_for_answer_of_Q
                if  "P" == "%ANSWER%" goto /i ask_if_want_mark_lyriclessness_2
                if  "Q" == "%ANSWER%" goto /i ask_if_want_mark_lyriclessness_2
                iff "Y" == "%ANSWER%" then 
                        set ABANDONED_SEARCH=1
                        set ANSWER=L
                        gosub check_for_answer_of_L
                        rem echo Just got back from check_for_answer_of_L called FROM WITHIN :ASK_IF_WANT_MARK_LYRICLESSNESS [] ...answer=“%ANSWER%”, goto_end=“%GOTO_END%”
                        if "1" == "%goto_END%" goto /i END_OF_GET_LYRICS
                endiff
                if "1" == "%GOOGLE_NOW%" (goto /i Google_Now)
                if "1" == "%GOTO_END%"   (goto /i END_OF_GET_LYRICS)
        return
        goto /i END_OF_GET_LYRICS

        :check_for_answer_of_A [alsoAcceptThisLetter]
                if "%ANSWER%" != "A" .and. "%ANSWER%" != "%alsoAcceptThisLetter%" return
                call  approve-lyrics "%LYRIC_FILE%"
                gosub approve_lyrics_done
                goto /i END_OF_GET_LYRICS
                rem ^^ todo should we perhaps goto lyric success message instead? Hmm.
        return
        :check_for_answer_of_C [file_to_convert]
                rem If we didn’t hit “C”, we’re not supposed to even be here today:
                        if "C" != "%ANSWER%" return

                rem We are supposed to pass a parameter, but if we don’t make a best guess:
                        iff "" == %file_to_convert% then
                                if exist "%LRC_SIDECAR_FILENAME%"      set file_to_convert=%LRC_SIDECAR_FILENAME%
                                if exist "%LRC_SIDECAR_FILENAME_TEMP%" set file_to_convert=%LRC_SIDECAR_FILENAME_TEMP%
                                
                        endiff

                rem Error if the parameter doesn’t exist:
                        iff not exist %file_to_convert% then
                                call error "check_for_answer_of_C called in get-lyrics-for-file.btm with a filename of %filename_to_convert% that does not exist"
                                return
                        endiff

                rem Let user know we are converting:
                        echo %ansi_color_important%%star4% Stretching %italics_on%new%italics_off% LRC...%ansi_color_normal%
                        
                rem Perform the conversion:
                        gosub stretch_downloaded_lrc "%LRC_SIDECAR_FILENAME_TEMP%" 
        return                                                                
        :check_for_answer_of_D [opt]
                gosub check_for_answer_of_D_to_eset_artist_and_song %opt%
        return
        :check_for_answer_of_D_to_eset_artist_and_song []
                iff  "%answer%" == "D"  then
                        gosub eset_fileartist_and_filesong
                        set goto_download_with_lyric_downloader_1=1
                endiff
        return
        :check_for_answer_of_dollar [opt]                
                gosub "%BAT%\create-srt-from-file.bat" check_for_answer_of_dollar %opt%
        return                         
        :check_for_answer_of_E [opt]                
                gosub "%BAT%\create-srt-from-file.bat" check_for_answer_of_E %opt%
        return                         
        :check_for_answer_of_F [opt]                
                iff "F" != "%ANSWER%" return
                gosub delete_maybe_files                                
                if "1" == "%QUICK_LRC_MODE%" goto end_quick_lrc_mode_fail
                if "1" != "%QUICK_LRC_MODE%" goto end_of_get_lyrics
        return                         
        :check_for_answer_of_G []
                if  "%ANSWER%" == "G" set GOOGLE_NOW=1 
                if  "%ANSWER%" != "G" set GOOGLE_NOW=0
                if "1" == "%GOOGLE_NOW%" goto Google_Now
        return
        :check_for_answer_of_H [opt]
                gosub edit_lyrics_now_if_we_answered_H %opt%
        return                  
        :check_for_answer_of_I [opt1 opt2 opt3]                        
                iff "%answer%" == "X" then
                        echo dry run:
                        for %%tmpFileForXAnswer in (%FILEMASK_AUDIO%) echo gosub rename_audio_file_as_instrumental "%@UNQUOTE["%tmpFileForXAnswer%"]"
                        pause
                        echo real run:
                        pause
                        echo was doing this: for %%tmpFileForXAnswer in (%FILEMASK_AUDIO%) gosub rename_audio_file_as_instrumental "%@UNQUOTE["%tmpFileForXAnswer%"]"
                        echo but now testing a gosub, so
                        pause
                        gosub actually_rename_every_file_as_an_instrumental_or_whatever %opt1% %opt2% %opt3%
                        set goto_END=1
                        goto /i END_OF_GET_LYRICS
                else
                        gosub rename_audio_file_as_instr_if_answer_was_I %opt1 %opt2 %opt3
                endiff       
                if "1" == "%GOTO_END%" (goto /i END_OF_GET_LYRICS)
        return
        :check_for_answer_of_K [opt]
                if "K" != "%ANSWER%" return
                set ANSWER_BAK=%ANSWER%
                call AskYN "Skip %ansi_color_bright_green%F%ansi_color_prompt%ile or rest of %ansi_color_bright_green%D%ansi_color_prompt%irectory" 0 0 FD F:skip_just_this_file,D:skip_file_or_the_folder
                set CHK4AOK_ANSWER=%ANSWER%
                set ANSWER=%ANSWER_BAK%
                        iff "D" == "%CHK4AOK_ANSWER%" then
                                call gosub divider
                                call warning "Skipping LRCs for the rest of the folder!" big
                                set SKIPPING_GET_LRCS_FOR_REST_OF_FOLDER=1
                                call gosub divider
                                rem Why is this giving issue? goto /i end_quick_lrc_mode_skip
                        endiff
                        rem goatgoat maybe we need to checkif "1" == "%QUICK_LRC_MODE%" or not
                        iff "F" == "%CHK4AOK_ANSWER%" .or. "D" == "%CHK4AOK_ANSWER%" then
                                goto /i end_quick_lrc_mode_skip
                        endiff
        return
        :check_for_answer_of_L [opt]
                rem debug: echo %ANSI_COLOR_MAGENTA%010101 check_for_answer_of_L answer=“%answer%”, JUST_RENAMED_TO_INSTRUMENTAL=“%JUST_RENAMED_TO_INSTRUMENTAL%”, GOTO_END=“%GOTO_END%”%ANSI_COLOR_NORMAL%
                set HOLD_ANSWER_CFAOL=%answer%
                if "%answer%" == "L" gosub mark_as_lyricless %opt%

                if "%HOLD_ANSWER_CFAOL%" == "L" (goto /i END_OF_GET_LYRICS)
                set     answer=%HOLD_ANSWER_CFAOL%
                rem echo %ANSI_COLOR_MAGENTA%020202 check_for_answer_of_L answer=“%answer%”, JUST_RENAMED_TO_INSTRUMENTAL=“%JUST_RENAMED_TO_INSTRUMENTAL%”, GOTO_END=“%GOTO_END%”%ANSI_COLOR_NORMAL%

                iff "%answer%" == "Z" then
                        for %%tmpFileForZAnswer in (%FILEMASK_AUDIO%) gosub mark_as_lyricless "%@UNQUOTE["%tmpFileForZAnswer%"]"
                        goto /i END_OF_GET_LYRICS
                endiff
                set      answer=%HOLD_ANSWER_CFAOL%
        return
        :check_for_answer_of_M_to_rename_file
        :check_for_answer_of_M [opt]                        
                gosub "%BAT%\create-srt-from-file.bat" check_for_answer_of_M %opt%
        return
        :check_for_answer_of_O [opt]
                iff "%ANSWER%" == "O" .or. "1" == "%goto_download_with_lyric_downloader_1%" then
                        set goto_download_with_lyric_downloader_init=1
                        goto /i download_with_lyric_downloader_init
                endiff
        return
        :check_for_answer_of_P [opt opt2]
                rem Debug:
                        rem echo %arrow% %arrow% %arrow% check_for_answer_of_P [opt=%opt%] ... audio_file = %lq%%AUDIO_FILE%%rq%, SONGFILE isn’t even existing if you’re just running get-lyrics= %lq%%SONGFILE%%rq% and alias of song_file is %lq%%SONG_FILE%%rq%, opt=%lq%%opt%%rq%, answer=%lq%%answer%%rq% ... %ansi_color_magenta%[PLAYER_COMMAND=%lq%%PLAYER_COMMAND%%rq%]%ansi_color_normal%  🐐
                        if "1" == "%DEBUG_GETLYRICS_CALL%" echo %ansi_color_debug%📞📞📞 called: get-lyrics: check_for_answer_of_P [opt=%opt%] [answer=%lq%%answer%%rq%] [PLAYER_COMMAND=%lq%%PLAYER_COMMAND%%rq%] 📞📞📞%ansi_color_normal% 

                rem Determine player command:
                        :try_again
                        iff "%PLAYER_COMMAND%" == "" then
                                echo %ANSI_COLOR_WARNING_soft%%EMOJI_CAUTION%Player command isn’t set!%ansi_color_normal%
                                iff defined DEFAULT_PLAYER_COMMAND then
                                        set PLAYER_COMMAND=%DEFAULT_PLAYER_COMMAND%
                                else
                                        set PLAYER_COMMAND=call preview-audio-file      %+ rem Fallback value is needed for when we call this function from other unrelated BAT files
                                endiff
                                echo %ANSI_COLOR_WARNING_soft%%EMOJI_CAUTION%Player command is now: %lq%%player_command%%rq%!%ansi_color_normal%
                        endiff
                        if "%PLAYER_COMMAND%" == "" (eset player_command %+ goto /i try_again)

                rem Return if the answer isn’t “P” or “Q”:
                        if "%answer%" != "P" .and. "%answer%" != "Q" goto :not_really_playing

                rem Determine which file to use; default or parameter:
                        set FILE_TO_USE=%AUDIO_FILE%
                        if "" == %opt% .or. "" == "%opt%" goto :opt_empty
                                iff "%@UNQUOTE["%opt%"]" != "" .and. exist "%@UNQUOTE["%opt%"]" then
                                        set FILE_TO_USE=%@UNQUOTE["%opt%"]
                                else
                                        call warning "couldn’t make sense of opt=“%opt%” in %0 on line 2785ish .. pbatchname=“%_PBATCHNAME”"
                                endiff

                rem Determine size of file:
                        set size=-1
                        :opt_empty
                        set size=%@FILESIZE["%FILE_TO_USE%"] 
                        rem DEBUG: echo %arrow% %arrow% %arrow% check_for_answer_of_P [] ... %ansi_color_bright_yellow%file_to_use%ansi_color_normal%=%lq%%FILE_TO_USE%%rq% and size is %lq%%size%%rq% 🐐

                rem If the file doesn’t exist now, for whatever reason (deleted in another window for example), we have a problem:
                        if "" == "%@UNQUOTE["%FILE_TO_USE%"]" pause "we got problems here 3108"

                rem Is the file too small to really be a playable file?
                        iff %size% lt 1000 then
                                call warning "file is %size% bytes! -- %lq%%FILE_TO_USE%%rq%"
                                set HOLD_OUR_ANSWER=%ANSWER%
                                call askyn "⁵Delete it" no 0
                                        iff "Y" == "%ANSWER%" .and. exist "%@UNQUOTE["%FILE_TO_USE%"]" then
                                                *del /z /Ns "%@UNQUOTE["%FILE_TO_USE%"]"
                                                call warning "Aborting because we deleted the file for only being %blink_on%%size%%blink_off% bytes"
                                                goto /i END_OF_GET_LYRICS
                                        endiff
                                        
                                set       ANSWER=%HOLD_OUR_ANSWER%
                        endiff

                        rem No, it is not too small, so prepare play/enQueue it:
                                rem echo 🐐 File was NOT too small, and Answer=%lq%%answer%%rq% at 2872   ... player_command_to_use=%lq%%player_command_to_use%%rq%
                                rem moved into preview-audio-file.bat: echo %ANSI_COLOR_IMPORTANT%%EMOJI_PLAY_BUTTON% Playing file: “%@UNQUOTE["%FILE_TO_USE%"]” %ansi_color_normal%
                                set player_command_to_use=%PLAYER_COMMAND% "%@UNQUOTE["%FILE_TO_USE%"]" %player_command_extra_options% %opt2%
                                rem echo %ansi_color_debug%- DEBUG: Player command: %faint_on%%player_command_to_use%%faint_off%
                                set LAST_PLAYER_COMMAND_USED=%player_command_to_use%                 

                rem If we are here because we actually pressed “Q” [check_for_answer_of_Q calls this subroutine!], then we enQueue instead of Play:
                        iff "Q" == "%ANSWER%" then
                                iff "1" != "%WINAMP_INTEGRATION_GETLYRICS%" then
                                        echo %ansi_color_warning_soft%%STAR% WINAMP_INTEGRATION_GETLYRICS is not set to 1, so we will only use VLC player if you hit %lq%Q%rq%. Change value in get-lyrics-for-file.btm if you want to enable WinAmp integration. %ansi_color_normal%
                                else
                                        call enqueue "%@UNQUOTE["%FILE_TO_USE%"]"
                                        call winamp-next        
                                        pause "Press any key after you’re done previewing..."
                                endiff

                rem Otherwise we use our normal play command:
                        else
                                rem echo 🐐 playing with player_command_to_use of: %player_command_to_use%
                                %player_command_to_use%                 
                        endiff

                rem And finish up (this is where we goto if they didn’t press “P” or “Q”)
                        :not_really_playing
        return
        call error "should not be here!"
        :check_for_answer_of_Q [opt]
                on break resume
                set CHECKFORANSWERQ_ANSWER_HOLD=%ANSWER%
                if "Q" == "%ANSWER%" gosub check_for_answer_of_P %opt%
                set        ANSWER=%CHECKFORANSWERQ_ANSWER_HOLD%
                on break cancel
        return
        rem Merged with answer_of_M 20260504: :check_for_answer_of_R [opt]
        rem Merged with answer_of_M 20260504:         if "R" != "%ANSWER%" return
        rem Merged with answer_of_M 20260504:         call  rn "%@UNQUOTE[%AUDIO_FILE%]"
        rem Merged with answer_of_M 20260504:         rem echo %ansi_color_debug%- DEBUG; after rn at 2625, last_renamed_to=“%LAST_RENAMED_TO%” so maybe set tmpFileForXAnswer=%LAST_RENAMED_TO% if we’re calling this from something that use that?%ansi_color_normal%
        rem Merged with answer_of_M 20260504:         iff "" != "%LAST_RENAMED_TO%" then
        rem Merged with answer_of_M 20260504:                 set AUDIO_FILE=%LAST_RENAMED_TO%
        rem Merged with answer_of_M 20260504:                 set LYRIC_FILE=%@NAME["%AUDIO_FILE%"].txt
        rem Merged with answer_of_M 20260504:                 set   SRT_FILE=%@NAME["%AUDIO_FILE%"].srt
        rem Merged with answer_of_M 20260504:                 set   LRC_FILE=%@NAME["%AUDIO_FILE%"].lrc
        rem Merged with answer_of_M 20260504:         endiff
        rem Merged with answer_of_M 20260504:         call warning "Renaming may break future operations...You may want to hit Ctrl-C now...." %+ pause
        rem Merged with answer_of_M 20260504: return               



        :check_for_answer_of_S [opt]        
                rem echo -DEBUG: we are at check_for_answer_of_S [%opt%] and answer=“%ANSWER%”         
                rem This only applies if we gave an answer of “S”:
                        iff "S" != "%ANSWER" return
                
                rem Process “opt” parameter to potentially override %lyric_file% with a different file:
                        if exist       "%LYRIC_FILE%" set file_to_use=%@UNQUOTE["%LYRIC_FILE%"]
                        if "" != "%@UNQUOTE["%opt%"]" set file_to_use=%@UNQUOTE["%opt%"]

                rem Rename it:
                        gosub rename_audio_file_as_sound_effect "%@UNQUOTE["%file_to_use%"]"  
        return
        :check_for_answer_of_T [opt]                
                gosub "%BAT%\create-srt-from-file.bat" check_for_answer_of_T %opt%
        return
        :check_for_answer_of_V [file_to_convert]
                rem If we didn’t hit “V”, we’re not supposed to even be here:
                        if "V" != "%ANSWER%" return

                rem We are supposed to pass a parameter, but if we don’t make a best guess:
                        iff "" == %file_to_convert% then
                                if exist "%LRC_SIDECAR_FILENAME%"      set file_to_convert=%LRC_SIDECAR_FILENAME%
                                if exist "%LRC_SIDECAR_FILENAME_TEMP%" set file_to_convert=%LRC_SIDECAR_FILENAME_TEMP%
                                
                        endiff

                rem Error if the parameter doesn’t exist:
                        iff not exist %file_to_convert% then
                                call error "check_for_answer_of_V called in get-lyrics-for-file.btm with a filename of %filename_to_convert% that does not exist"
                                return
                        endiff

                rem Let user know we are converting:
                        echo %ansi_color_important%%star4% Converting %italics_on%new%italics_off% %underline_on%LRC%underline_off% into %underline_on%TXT%underline_off%...
                        

                rem Perform the conversion:
                        call lrc2txt "%LRC_SIDECAR_FILENAME_TEMP%" "%TXT_SIDECAR_FILENAME%" silent                        
        return                                 
        :check_for_answer_of_X [opt]
                if "X" == "%ANSWER%" for %%tmpCFAXfile in (%filemask_audio%) do gosub rename_audio_file_as_instrumental "%@UNQUOTE["%%tmpCFAXfile"]"
        return

        :create_or_set_postprocessed_lyrics [opt]
                rem Debug: echo %ansi_color_bright_green%%EMOJI_PHONE% CALLED: gosub [get-lyrics::]create_or_set_postprocessed_lyrics "%opt%" ... %newline%%tab%%star%lyric_file=“%lyric_file%” ...%newline%%tab%%star%file_to_use==“%file_to__use%”%newline%%tab%%star%postprocessed_lyrics==“%postprocessed_lyrics%”%ansi_color_normal%

                rem Process “opt” parameter to potentially override %lyric_file% with a different file:
                        if exist       "%LYRIC_FILE%" set file_to_use=%@UNQUOTE["%LYRIC_FILE%"]
                        if "" != "%@UNQUOTE["%opt%"]" set file_to_use=%@UNQUOTE["%opt%"]

                rem Debug: echo %ansi_color_bright_green%%EMOJI_PHONE% DOINGG: gosub [get-lyrics::]create_or_set_postprocessed_lyrics ....... file_to_use==“%file_to__use%”%newline%%tab%%star%postprocessed_lyrics==“%postprocessed_lyrics%”%ansi_color_normal%

                rem Do they exist already? - Verdict: While it’s nice to know, it doesn’t make sense to output this and review it at this point
                        rem echos %ansi_color_debug%%star% Postprocessed lyrics 
                        rem iff exist "%postprocessed_lyrics%" then
                        rem         echo  do exist! ``
                        rem         call review-file "%postprocessed_lyrics%"  "test postprocessed lyrics review"
                        rem else
                        rem         echo  do not exist: “%postprocessed_lyrics%” ``
                        rem endiff

                rem Create a %tmpfile%:
                        call set-tmp-file "postprocessed lyrics"

                rem Run the post-processor on our input file, outputting to our tmpfile:
                        rem  type "%@UNQUOTE["%LYRIC_FILE%"]" |:u8  lyric-postprocessor.pl -A -L -S)                  >     %tmpfile%
                        rem (type            "%FILE_TO_USE%"  |:u8  lyric-postprocessor.pl -A -L -S)                  >     %tmpfile%
                        if "1" == "%DEBUG_POSTPROCESSORS%"     echo lyric-postprocessor.pl -A -L -S  "%FILE_TO_USE%" `>`:u8 %tmpfile%
                                                                    lyric-postprocessor.pl -A -L -S  "%FILE_TO_USE%"  >:u8 %tmpfile%

                rem Save the filename of our post-processed lyrics, so we can grab them later:
                        rem iff defined postprocessed_lyrics .and. exist "%@UNQUOTE["%postprocessed_lyrics%"]" .and. "%last_file_used_for_lyric_processing%" == "%file_to_use%" then
                        rem         rem do nothing because it’s already set to an existing postprocessed file
                        rem else
                        rem         set postprocessed_lyrics=%tmpfile% 
                        rem endiff

                rem Save the filename of our post-processed lyrics, so we can grab them later:
                        if defined tmpfile .and. exist %tmpfile% set postprocessed_lyrics=%tmpfile% 

                rem Save the filename of our last input file, just in case we need it for something (aka “auditing”):
                        set last_file_used_for_lyric_processing=%file_to_use%

                rem Debug: rem echo %ansi_color_green%%EMOJI_PHONE%  ENDED: gosub [get-lyrics::]create_or_set_postprocessed_lyrics "%lyric_file%" ... file_to_use==“%file_to__use%” ... postprocessed_lyrics=“%tmpfile%”%ansi_color_normal%
        return

        :debug [msg]
                
                echo %ANSI_COLOR_DEBUG%- DEBUG: %msg% %ansi_color_normal%
        
        return

        
        :delete_file [file file2 file3 file4 file5 file6 file7 file8 file9]

                echos %ANSI_COLOR_REMOVAL%%EMOJI_AXE%%EMOJI_AXE%%EMOJI_AXE% ``
                
                *del /Ns %file% %file2% %file3% %file4% %file5% %file6% %file7% %file8% %file9%
                
                echos %ANSI_COLOR_NORMAL%
        return
        :backup_file [file_parameter reason_parameter opt3 opt4 opt5 opt6 opt7 opt8 opt9]
                set file=%@UNQUOTE[%file_parameter%]
                set reason=%@UNQUOTE[%reason_parameter%]
                echos %ANSI_COLOR_RUN%%EMOJI_BOOK% ``
                *ren /Ns /q "%file%" "%file%.%reason%.%[_datetime].bak"
                echos %ANSI_COLOR_NORMAL%
        return
        :rename_file [opt1 opt2 opt3 opt4 opt5 opt6 opt7 opt8 opt9]
                echos %ANSI_COLOR_RUN%%EMOJI_GEAR% ``
                set FILE2=%@UNQUOTE[%opt2%]
                if exist "%FILE2%" *ren /Ns /q "%FILE2%" "%FILE2%.replaced_on_%_datetime.bak" 
                *ren /Ns %opt1% %opt2% %opt3% %opt4% %opt5% %opt6% %opt7% %opt8% %opt9%
                rem goatgoatgoat put this null on previous lnie when things settle >nul

                echos %ANSI_COLOR_NORMAL%
        return
        :delete_maybe_files []
                iff exist *.maybe then
                        call subtle "Deleting %italics_on%SyncedLyrics%italics_off% temporary rejected files..."
                        echos %ansi_save_position%
                        *del /a: /f /Ns /[!*%PID*] %dumps%;*.maybe >>&nul %+ rem |:u8 copy-move-post 
                        echos %ansi_restore_position%
                endiff
        return
        :delete_quick_lrc_mode_files [opt]
                rem Cosmetic divider only if necessary:
                        if exist "%TXT_SIDECAR_FILENAME_TEMP%" .or. exist "%LRC_SIDECAR_FILENAME_TEMP%" .or. exist "%SRT_SIDECAR_FILENAME_TEMP%" .or. exist "%ELRC_SIDECAR_FILENAME_TEMP%" gosub divider

                rem Actually delete each .maybe file:
                        if exist  "%TXT_SIDECAR_FILENAME_TEMP%" gosub delete_file  "%TXT_SIDECAR_FILENAME_TEMP%"
                        if exist  "%LRC_SIDECAR_FILENAME_TEMP%" gosub delete_file  "%LRC_SIDECAR_FILENAME_TEMP%"
                        if exist  "%SRT_SIDECAR_FILENAME_TEMP%" gosub delete_file  "%SRT_SIDECAR_FILENAME_TEMP%"
                        if exist "%ELRC_SIDECAR_FILENAME_TEMP%" gosub delete_file "%ELRC_SIDECAR_FILENAME_TEMP%"
        return

        :DisplayAudioDirectory [opt opt2 opt3]
                set AUDIO_FILE_TO_USE=%AUDIO_FILE%
                if %opt% != ""set AUDIO_FILE_TO_USE=%@UNQUOTE[%opt%]
                rem  %ansi_color_prompt%%star% %ansi_color_bright_yellow%Audio directory: %ansi_color_bright_red%“%italics_on%%blink_off%%ansi_color_green%%@PATH[%AUDIO_FILE%]%blink_off%%italics_off%%ansi_color_prompt%%ansi_color_bright_red%”%ansi_color_normal%                        
                echo %ansi_color_prompt%%star% %ansi_color_yellow%Audio directory: %ansi_color_bright_red%%faint_on%%italics_on%%blink_off%%ansi_color_green%%ansi_color_pink%%@IF["" != "%@UNQUOTE[%@PATH[%AUDIO_FILE_TO_USE%]]",%@PATH[%AUDIO_FILE_TO_USE%],%_CWD]%blink_off%%italics_off%%faint_off%%ansi_color_prompt%%ansi_color_bright_red%%ansi_color_normal%
                rem echo %ARROW_UP%%ARROW_UP%%ARROW_UP%%ARROW_UP%%ARROW_UP%%ARROW_UP%%ARROW_UP% TESTING 🐐
                if "%opt%" ==   "noFilename" goto /i nofilename
                if "%opt%" == "withFilename" goto /i with_filename
                                             goto /i nofilename
                :with_filename
                        if "%PREVIOUS_GENIUS_FILENAME%" !=  "" (
                                set dspauddir_spacer= ``
                        ) else (
                                unset /q dspauddir_spacer
                        )
                        echos %ansi_color_prompt%%star% %ansi_color_bright_yellow%Audio %dspauddir_spacer%filename%ansi_color_yellow%:%ansi_color_prompt%  %dspauddir_spacer%“%italics_on%%blink_off%%ansi_color_green%%AUDIO_FILE_TO_DISPLAY_NAME%%blink_off%%italics_off%%ansi_color_prompt%”
                :nofilename
        return
        :DisplayAudioFileName [opt]
                                      set FILE2USE=%@UNQUOTE[%AUDIO_FILE%]
                if exist %INPUT_FILE% set FILE2USE=%@UNQUOTE[%INPUT_FILE%]
                if exist %opt%        set FILE2USE=%@UNQUOTE[%opt]
                rem echo %star% Audio file: %faint_on%%FILE2USE%%faint_off%%conceal_on%%0%%conceal_off%
                echo %ansi_color_bright_yellow%%star% Audio filename:  %ansi_color_bright_red%%faint_on%%FILE2USE%%faint_off%%ansi_color_normal%%conceal_on%0%conceal_off%
        return
        :DisplayAudioFileLength [audfile opt2 opt3 opt4]
                rem Used lazy loading back when we only used this on 1 file:
                rem        if     defined LAST_FILE_LENGTH call subtle "LAST_FILE_LENGTH  is already defined and is “%LAST_FILE_LENGTH%”"
                rem        if not defined LAST_FILE_LENGTH gosub get_audio_file_length %audfile% %opt2% %opt3% %opt4%
                rem But now that we use this on multiple files, we just re-read it each time. It’s fast anyway:
                        gosub get_audio_file_length %audfile% %opt2% %opt3% %opt4%

                rem Deal with failures:
                        if "%READER_OUTPUT%" == "N/A" .or. "%READER_OUTPUT%" == "-1" call warning "File-length-reader output failed!"

                rem Define extension for output:
                        set  EXT_TO_USE=%@EXT["%audfile%"]
                        if "%EXT_TO_USE%" == "maybe" set EXT_TO_USE=%@EXT[%@NAME["%audfile%"]]
                rem Define columns for output:
                        set COL1=4+%@WIDTH[%EXT_TO_USE%]
                        set COL2=%@EVAL[%col1% + 13]
                rem Output:
                        call less_important "%ansi_color_important%%italics_on%%EXT_TO_USE%%italics_off% %@ansi_move_to_col[%COL1%]file length%ansi_color_less_important%: %@ansi_move_to_col[%COL2%]%LAST_FILE_LENGTH%"
        return
                :get_audio_file_length [opt opt2]
                        rem call debug "get_audio_file_length called with opt=%opt%,opt2=%opt2%"
                        rem lazy loading is a thing of the past: if defined LAST_FILE_LENGTH .and. "%opt2%" != "force" return
                        set LAST_FILE_LENGTH=file “%opt%” not found
                        set opt1=%@UNQUOTE["%opt%"]
                        if not exist %opt1% return

                        rem extensions will get checked in the display-audio-file-length bat so no need: 
                                rem set LAST_FILE_LENGTH=unreadable extension (%@EXT[%opt1%])
                                rem if "%@EXT["%opt1%"]" != "mp3" return
                                set LAST_FILE_LENGTH=error reading %opt%

                        call display-audio-file-length "%opt1%" silent      
                        set LAST_FILE_LENGTH=%DISPLAY_AUDIO_FILE_LENGTH_AiTranscriptionSystem%
                        set LAST_FILE_LENGTH_SS=%AUDIO_FILE_LENGTH%
                        set LAST_FILE_LENGTH_SHORT=%DISPLAY_AUDIO_FILE_LENGTH_HH_MM_SS%
                return


        rem :divider_v000_moved_to_createsrt_script [divider_param]
        rem         rem Suppress divider if instructed:
        rem                 iff "1" == "%suppress_next_divider%" then
        rem                         set  suppress_next_divider=0
        rem                         return
        rem                 endiff
        rem 
        rem         rem Determine divider file to use:
        rem                 set wd=%@EVAL[%_columns - 1]
        rem                 set nm=%bat%\dividers\rainbow-%wd%.txt
        rem 
        rem         rem Type divider file if it exists:
        rem                 iff exist %nm% then
        rem                         *type %nm%
        rem                         set last_divider_method=type
        rem                         set last_divider_param=%divider_param%
        rem         rem Otherwise, manually draw the divider:
        rem                 else
        rem                         echo %@char[27][93m%@REPEAT[%@CHAR[9552],%wd%]%@char[27][0m
        rem                         set last_divider_method=echo
        rem                 endiff
        rem 
        rem         rem Our divider files do not include newlines. Do we add one ourself?
        rem                 rem debug: *pause>nul
        rem                 iff "%divider_param%" == "NoNewline"  then
        rem                         set last_divider_newline=False
        rem                 else 
        rem                         set last_divider_newline=True
        rem 
        rem                         rem Go to the next line:
        rem                                 echos %NEWLINE%
        rem 
        rem                         rem Then move to column 0/1 [which are the same column]:
        rem                                 echos %@ANSI_MOVE_TO_COL[0] 
        rem                 endiff
        rem 
        rem         rem Debug: echo wtf last_divider_newline=%last_divider_newline% should we do one? >nul
        rem return


        rem we must remember to update this in both files:
        :divider [divider_param]
                rem  %POTENTIAL_REDIRECTION% is an optional string that represents where we want to direct our output too

                rem Suppress divider if instructed:
                        iff "1" == "%suppress_next_divider%" then
                                set  suppress_next_divider=0
                                return
                        endiff

                rem Determine divider file to use:
                        set wd=%@EVAL[%_columns - 1]
                        set nm=%bat%\dividers\rainbow-%wd%.txt

                rem Type divider file if it exists:
                        iff exist %nm% then
                                *type %nm%  %POTENTIAL_REDIRECTION%
                                set last_divider_method=type
                                set last_divider_param=%divider_param%
                rem Otherwise, manually draw the divider:
                        else
                                echo %@char[27][93m%@REPEAT[%@CHAR[9552],%wd%]%@char[27][0m %POTENTIAL_REDIRECTION%
                                set last_divider_method=echo
                        endiff

                rem Our divider files do not include newlines. Do we add one ourself?
                        rem debug: *pause>nul
                        iff "%divider_param%" == "NoNewline"  then
                                set last_divider_newline=False
                        else 
                                set last_divider_newline=True

                                rem Go to the next line:
                                        echo. %POTENTIAL_REDIRECTION%

                                rem Then move to column 0/1 [which are the same column]:
                                        echos %@ANSI_MOVE_TO_COL[0] %POTENTIAL_REDIRECTION%

                        endiff

                rem Debug:
                        echo wtf last_divider_newline=%last_divider_newline% should we do one? >nul
        return
                                                
        :edit_lyrics_now_if_we_answered_H [subarg force]
                rem This gets called excessively, so we have to make sure it only happens once...

                rem echo called: edit_lyrics_now_if_we_answered_H [subarg=%subarg% force=%force%] ALREADY_HAND_EDITED=“%ALREADY_HAND_EDITED%”, answer=“%answer%”
                iff  "1" == "%ALREADY_HAND_EDITED%" then
                        rem Confirm:
                                set hold_hand_answer=%answer%
                                rem call askyn "We already hand-edited this, are you sure you want to again" no 300
                                echo %ansi_color_unimportant%%star3% We already hand-edited this, so we’re not doing it again%ansi_color_normal%
                                set already_answer=%answer%
                                set        answer=%hold_hand_answer%
                        rem Exit if that’s what we want:
                                rem call debug "if “N” == “%already_answer%” return"
                                if "N" == "%already_answer%" return
                endiff
                set do_next_block=0                                                                                                                                                                                                                     %+ rem echo %ansi_color_orange%� mid1:   edit_lyrics_now_if_we_answered_H [subarg=%subarg% force=%force%] ALREADY_HAND_EDITED=“%ALREADY_HAND_EDITED%”, answer=“%answer%”, do_next_block=“%do_next_block%”, subarg=“%subarg%”, force=“%force%”%ansi_color_normal%
                if "H" == "%ANSWER%" .or. "%force%" == "force" .or. ("%ANSWER%" == "%subarg%" .and. "" !=  "%subarg") set do_next_block=1                                                                                                               %+ rem echo %ansi_color_orange% mid2:   edit_lyrics_now_if_we_answered_H [subarg=%subarg% force=%force%] ALREADY_HAND_EDITED=“%ALREADY_HAND_EDITED%”, answer=“%answer%”, do_next_block=“%do_next_block%”%ansi_color_normal%
                if "0" == "%do_next_block%" goto /i else_from_2712
                if "1" == "%do_next_block%" goto /i edit_it_already_2751
                        :edit_it_already_2751
                        echos %ANSI_POSITION_SAVE%
                        set EDIT_CALL=%EDITOR% "%LYRIC_FILE%"
                        rem DEBUG: echo %star2% DEBUG: editing lyric file because answer=“%answer%”  ... google_now=“%google_now%”.... call = “%blink_on%%edit_call%%blink_off%” 💩 FILE_SONG_TO_USE=“%FILE_SONG_TO_USE” 🐐
                        %EDIT_CALL%
                        pause "%blink_on%Press any key when done editing%blink_off%"
                        set   ALREADY_HAND_EDITED=1                                                                                                                                                                                                     %+ rem echo checking[bb] if filesize["%LYRIC_FILE%"] of “%@FILESIZE["%LYRIC_FILE%"]” lt 5 then 
                        if %@FILESIZE["%LYRIC_FILE%"] gt 5 goto /i endiff_filesize_is_fine
                                set LYRICS_ACCEPTABLE=0
                                *del /Ns /q "%LYRIC_FILE%" >nul
                                gosub ask_if_want_mark_lyriclessness
                        :endiff_filesize_is_fine

                                                                        goto we_dont_need_this_prompt_afterall_2787
                                                                                                        rem Ask if the new ones are acceptable or not
                                                                                                                call askyn "Acceptable BETA PROMPT" no %GOOGLE_FOR_LYRICS_PROMPT_WAIT_TIME%

                                                                                                        iff "N" == "%ANSWER%" then
                                                                                                                set     LYRICS_ACCEPTABLE=0
                                                                                                                set  JUST_APPROVED_LYRICS=0
                                                                                                        endiff
                                                                                                        if "Y" != "%ANSWER%" goto /i endiff_not_y_from_2702
                                                                                                                set     LYRICS_ACCEPTABLE=1
                                                                                                                set  JUST_APPROVED_LYRICS=1
                                                                                                                goto recheck_post_hand_edited_lyrics
                                                                                                        :endiff_not_y_from_2702
                                                                                                        rem echo LYRICS_ACCEPTABLE=%LYRICS_ACCEPTABLE%, JUST_APPROVED_LYRICS=%JUST_APPROVED_LYRICS%
                                                                        :we_dont_need_this_prompt_afterall_2787
                goto /i endiff_from_2740
                :else_from_2712
                        set  DO_NOT_ASK_TO_HAND_EDIT=1
                        echo FORCE_HAND_EDIT trace ZZZ >nul 
                        set  FORCE_HAND_EDIT=0
                :endiff_from_2740
        return
        goto /i END_OF_GET_LYRICS

        :eset_fileartist_and_filesong []
                rem 🧹 make sure the variables are clean and ready for modification 🧹
                        if not defined FILE_ARTIST (set FILE_ARTIST=?)
                        if not defined FILE_SONG   (SET   FILE_SONG=?)

                rem Pre-set it to the last thing we changed it to, in case the situation is happening multiple times:
                        if "" !=  "%FILE_ARTIST_LAST_CHANGED_TO%" set FILE_ARTIST=%FILE_ARTIST_LAST_CHANGED_TO%
                        rem   !=    "%FILE_SONG_LAST_CHANGED_TO%" set   FILE_SONG=%FILE_SONG_LAST_CHANGED_TO%    ━━━ it doesn’t make sense to do it for the song; only for the artist

                rem keep track of original values:
                        set FILE_ARTIST_BEFORE_CHANGE=%FILE_ARTIST%
                        set   FILE_SONG_BEFORE_CHANGE=%FILE_SONG%

                rem Display filename in case its scrolled off the screen and we can’t ascertain it:                        
                rem ✍🏻 hand-editing artist/song name: ✍🏻 
                        set   FILE_ARTIST_PRE_ESET=%FILE_ARTIST%
                        set   FILE_SONG_PRE_ESET=%FILE_SONG%
                        gosub DisplayAudioDirectory 
                        gosub DisplayAudioFilename %AUDIO_FILE%
                        call eset-alias FILE_ARTIST quick
                        call eset-alias FILE_SONG quick
                        rem  FILE_ALBUM

                rem Massage ’ into ' because ’ doesn’t match ' in genius searches:
                        set   FILE_SONG=%@Replace[’,',%FILE_SONG%]
                        set FILE_ARTIST=%@Replace[’,',%FILE_ARTIST%]

                rem Update flag:
                        if "%FILE_ARTIST_PRE_ESET%" != "%FILE_ARTIST%" .or. "%FILE_SONG_PRE_ESET%" != "%FILE_SONG%"   set debanded=0

                rem Store values for future runs:
                        iff "%FILE_ARTIST%" != "%FILE_ARTIST_BEFORE_CHANGE%" then
                                rem echo setting FILE_ARTIST_LAST_CHANGED_TO=%FILE_ARTIST% 🐺
                                set FILE_ARTIST_LAST_CHANGED_TO=%FILE_ARTIST%
                        endiff
                        iff "%FILE_SONG%"   !=   "%FILE_SONG_BEFORE_CHANGE%" then
                                rem echo setting FILE_SONG_LAST_CHANGED_TO=%FILE_SONG% 🐺
                                set   FILE_SONG_LAST_CHANGED_TO=%FILE_SONG%
                        endiff
                        

                rem Update related/alias values based on new values:
                        set        FILE_SONG_TO_USE=%FILE_SONG%
                        set       FILE_TITLE_TO_USE=%FILE_SONG%
                        set      FILE_ARTIST_TO_USE=%FILE_ARTIST%
                        set FILE_ORIG_ARTIST_TO_USE=%FILE_ORIG_ARTIST%
                        set       FILE_ALBUM_TO_USE=%FILE_ALBUM%
                        rem gosub debug "🎨🎨🎨[30] FILE_ARTIST_TO_USE=“%FILE_ARTIST_TO_USE%, FILE_ARTIST=“%FILE_ARTIST%””"
        return
              
        :mark_as_lyricless [use_this_file_instead opt2]
                rem Ensure our filename is set correctly:
                                                                        set FILE_TO_MARK_AS_LL=%AUDIO_FILE%
                        if "" != "%@UNQUOTE["%use_this_file_instead%"]" set FILE_TO_MARK_AS_LL=%use_this_file_instead%      

                rem Get parameters:
                        set NO_END=0
                        if "%@UNQUOTE["%opt2%"]" == "no_end" set NO_END=1

                rem Let user know we called this:
                        echo %star% Marking filename: %faint_on%“%FILE_TO_MARK_AS_LL%”%faint_off%, no_end=“%no_end%” %conceal_on%XX%conceal_off%


                rem Is there even an answer to hold? I dunno
                        set HOLD_ANSWER=%ANSWER%


                rem Delete TXT file if we’ve marked it as lyricless, because that would mean the TXT isn’t our lyrics:
                        rem echo 🐐 checking if exist: SIDECAR_LYRICS==“%SIDECAR_LYRICS%”
                        set SIDECAR_LYRICS=%@NAME[%@UNQUOTE["%FILE_TO_MARK_AS_LL%"]].txt
                        set   SIDECAR_JSON=%@NAME[%@UNQUOTE["%FILE_TO_MARK_AS_LL%"]].json
                        set    SIDECAR_LRC=%@NAME[%@UNQUOTE["%FILE_TO_MARK_AS_LL%"]].lrc
                        set   SIDECAR_ELRC=%@NAME[%@UNQUOTE["%FILE_TO_MARK_AS_LL%"]].elrc
                        set    SIDECAR_SRT=%@NAME[%@UNQUOTE["%FILE_TO_MARK_AS_LL%"]].srt
                        iff exist "%SIDECAR_LYRICS%" then
                                rem echo %EMOJI_AXE% %ansi_color_warning_soft%Possibly deleting lyric file of%faint_on%:%faint_off% %ansi_color_pink%“%ansi_color_green%%SIDECAR_LYRICS%%ansi_color_pink%”%ansi_color_normal% %emoji_axe%%ansi_color_removal%
                                set hold_our_answer_for_now=%answer%
                                        echo %ansi_color_debug%- [DEBUG] sidecar_lyrics/json=%newline%%tab%“%sidecar_lyrics%”%newline%%tab%“%sidecar_json%”%ansi_color_normal%
                                        unset /q ANSWER
                                        if not defined LYRIC_ACCEPTABILITY_REVIEW_WAIT_TIME set LYRIC_ACCEPTABILITY_REVIEW_WAIT_TIME=180
                                        call AskYn "Delete lyrics & json" yes %LYRIC_ACCEPTABILITY_REVIEW_WAIT_TIME%
                                        if "Y" != "%answer"  goto /i :endiff_do_not_delete_2754
                                                if exist "%SIDECAR_LYRICS%" (echos    %AXE%%AXE%%AXE% `` %+ *del /Ns /a: /f  "%SIDECAR_LYRICS%")
                                                if exist "%SIDECAR_JSON%"   (echos    %AXE%%AXE%%AXE% `` %+ *del /Ns /a: /f  "%SIDECAR_JSON%"  )
                                        :endiff_do_not_delete_2754
                                        unset /q ANSWER

                                        rem If LRC *and* SRT exist, we can give an option to say no to both at once:
                                                iff exist "%SIDECAR_LRC%" .and. exist "%SIDECAR_SRT%" then
                                                        call AskYn "Delete lrc & srt" yes %LYRIC_ACCEPTABILITY_REVIEW_WAIT_TIME%
                                                        if "Y" != "%answer"  goto /i :endiff_do_not_delete_2850
                                                endiff

                                                        rem Delete LRC or SRT if they exist:
                                                                if exist "%SIDECAR_LRC%"  (echos    %AXE%%AXE%%AXE% `` %+ *del /Ns /a: /f  "%SIDECAR_LRC%")
                                                                if exist "%SIDECAR_ELRC%" (echos    %AXE%%AXE%%AXE% `` %+ *del /Ns /a: /f "%SIDECAR_ELRC%")
                                                                if exist "%SIDECAR_SRT%"  (echos    %AXE%%AXE%%AXE% `` %+ *del /Ns /a: /f  "%SIDECAR_SRT%")

                                        :endiff_do_not_delete_2850
                                        echos %ansi_color_normal%
                                        %color_normal%
                                set          answer=%hold_our_answer_for_now%
                        endiff

                rem Is it already marked?
                        iff "%LYRICLESSNESS_STATUS%" == "APPROVED" then
                                gosub divider
                                echo %ansi_color_warning%Already marked this as lyricless!%ansi_color_normal%
                                return
                        endiff

                rem Store our answer:
                        rem DEBUG: echo %faint_on%🐱 CALLED: mark_as_lyricless [Q1X1] in get-lyrics-for-file with use_this_file_instead=“%use_this_file_instead%”%faint_off%, answer=“%ANSWER%”, hold_answer=“%hold_answer%”
                        set HOLD_ANSWER=%ANSWER%                

                rem If it’s not explicitly marked as “[instrumental]” then we need to ask if it is, and add an ADS stating such and/or rename it:
                        set HOLD_AUDIO_FILE=%AUDIO_FILE%
                        set AUDIO_FILE="%@UNQUOTE["%FILE_TO_MARK_AS_LL%"]"
                        gosub ask_about_instrumental "%AUDIO_FILE%"
                        set ASKED_ABOUT_INSTRUMENTAL_ALREADY=1

                rem Don’t do it if we’ve already done it:
                        if "%LYRICLESSNESS_STATUS%" == "APPROVED" goto /i already_approved_from_2790

                                rem Let user know we’re doing the thing:
                                        call bigecho "%ansi_color_blue%%STAR2% Marking as lyricless and approving lyric%underline_on%%italics_on%less%italics_off%%underline_off%ness..."

                                rem Update our internal flags/values for lyric/lyriclessness/etc:
                                        set  ABANDONED_SEARCH=1
                                        set  JUST_APPROVED_LYRICS=0
                                        set  JUST_APPROVED_LYRICLESSNESS=1
                                        set  LYRICLESSNESS_STATUS=APPROVED
                                        set  LYRICS_STATUS=NOT SET

                                rem Call our approval utility to mark it properly with the proper validations:
                                        call approve-lyriclessness-for-file.bat "%@UNQUOTE["%FILE_TO_MARK_AS_LL%"]"

                                rem Logging:
                                       if "1" == "%[logged_lyriclessness_%file_to_mark_as_ll%]" goto skip_logfile_logging_this_time

                                                echo %@REPEAT[%newline%,2]%EMOJI_DESKTOP_COMPUTER% %_DATETIME: %no% Approved: Lyriclessness: “%@UNQUOTE["%@FULL["%file_to_mark_as_ll%"]"]”>>:u8"%AUDIOFILE_TRANSCRIPTION_LOG_FILE%"
                                                set          logged_lyriclessness_%file_to_mark_as_ll%=1

                                        :skip_logfile_logging_this_time

                                rem Account for “Z” to rename *EVERY* file in the folder as an instrumental:
                                        set           ANSWER=%HOLD_ANSWER%
                                        if "1" == "%QUICK_LRC_MODE%" goto /i end_quick_lrc_mode_fail
                                        if "Z" != "%ANSWER%"         goto /i end_of_get_lyrics
                                                

                        :already_approved_from_2790

                rem Be done!
                        if "1" == "%NO_END%" return 666
                        goto /i END_OF_GET_LYRICS
                        return 666
        return                

        :log_compliance [filename_to_log_param reason_for_logging]
                if not defined AUDIOFILE_TRANSCRIPTION_LOG_FILE call fatal_error "AUDIOFILE_TRANSCRIPTION_LOG_FILE isn’t defined in :log_compliance[] in %0 and needs to be"
                set filename_to_log=%@UNQUOTE["%filename_to_log_param%"]
                echo %EMOJI_EAR% %_DATETIME: %REASON_FOR_LOGGING%: filename: %FILENAME_TO_LOG% >>:u8"%AUDIOFILE_TRANSCRIPTION_LOG_FILE%"
        return


        :mark_every_file_as_an_instrumental_ADS_tag_only [opt1 opt2 opt3]
                unset /q answer
                set ask=0
                set force_mark_every_file_as_instrumental=1
                for %%tmpFileForXAnswer in (%FILEMASK_AUDIO%) do gosub ask_to_rename_file_as_instrumental_or_whatever "%@UNQUOTE["%tmpFileForXAnswer%"]" "%@unquote["%opt1%"]" "%@unquote["%opt2%"]" "%@unquote["%opt3%"]" 
                set force_mark_every_file_as_instrumental=0
                unset /q ask
        return
                :unmark_every_file_as_an_instrumental_ADS_tag_only [opt1 opt2 opt3]
                        unset /q answer
                        set ask=0
                        set force_unmark_every_file_as_instrumental=1
                        for %%tmpFileForXAnswer in (%FILEMASK_AUDIO%) do gosub ask_to_rename_file_as_instrumental_or_whatever "%@UNQUOTE["%tmpFileForXAnswer%"]" "%@unquote["%opt1%"]" "%@unquote["%opt2%"]" "%@unquote["%opt3%"]" 
                        set force_unmark_every_file_as_instrumental=0
                        unset /q ask
                return
        :mark_every_file_as_NOT_an_instrumental_ADS_tag_only [opt1 opt2 opt3]
                unset /q answer
                set ask=0
                set force_mark_every_file_as_NOT_an_instrumental=1
                for %%tmpFileForXAnswer in (%FILEMASK_AUDIO%) do gosub ask_to_rename_file_as_instrumental_or_whatever "%@UNQUOTE["%tmpFileForXAnswer%"]" "%@unquote["%opt1%"]" "%@unquote["%opt2%"]" "%@unquote["%opt3%"]" 
                set force_mark_every_file_as_NOT_an_instrumental=0
                unset /q ask
        return


        :maybe_switch_lyric_provider_and_restart_from_top [opt]
                set RESTARTED_WITH_OTHER_LYRIC_PROVIDER=0
                if "" != "%PROVIDER_ONLY%" return
                if exist "%LYRIC_FILE%" return

                set PREVIOUS_LYRIC_PROVIDER_DISPLAY=%CURRENT_LYRIC_PROVIDER_DISPLAY%

                iff "%CURRENT_LYRIC_PROVIDER%" == "GENIUS" then
                        set PROVIDER_PASS_DONE_GENIUS=1
                        if "1" == "%PROVIDER_PASS_DONE_SYNCEDLYRICS%" return
                        set CURRENT_LYRIC_PROVIDER=SyncedLyrics
                else
                        set PROVIDER_PASS_DONE_SYNCEDLYRICS=1
                        if "1" == "%PROVIDER_PASS_DONE_GENIUS%" return
                        set CURRENT_LYRIC_PROVIDER=LyricsGenius
                endiff

                gosub refresh_current_lyric_provider_metadatas
                gosub reset_full_lyric_search_state_for_new_provider

                if "%CURRENT_LYRIC_PROVIDER%" == "GENIUS" .and. "1" == "%QUICK_LRC_MODE%" goto /i end_quick_lrc_mode_fail

                gosub divider


                echo %ANSI_COLOR_WARNING_SOFT%%STAR% No valid lyrics found with %italics_on%%PREVIOUS_LYRIC_PROVIDER_DISPLAY%%italics_off%. Restarting the full query ladder with %italics_on%%CURRENT_LYRIC_PROVIDER%%italics_off%...%ANSI_RESET%
                set RESTARTED_WITH_OTHER_LYRIC_PROVIDER=1
        return

        :rename_audio_file_as_sound_effect [a_different_filename_than_usual optional_name_of_env_var_to_set_to_new_filename]                        
                gosub rename_audio_file_as_instrumental %a_different_filename_than_usual% "sound effect"
                if "%optional_name_of_env_var_to_set_to_new_filename%" != "" .and. "%LAST_RENAMED_TO%" != "" set %[%optional_name_of_env_var_to_set_to_new_filename%]=%LAST_RENAMED_TO%                                                                                                                                                                                      
        return
        :rename_audio_file_as_instr_if_answer_was_I [opt]
                if "I" == "%ANSWER%" gosub rename_audio_file_as_instrumental %opt%
        return
        :rename_audio_file_as_instrumental [different_filename_than_usual as_what ask force]                        
                rem renaming as instrumental or as what else?
                        set nature=instrumental
                        if "" != "%@UNQUOTE["%as_what%"]" .and. "ask" != "%@UNQUOTE["%as_what%"]" set nature=%@UNQUOTE[%as_what%]
                        set     nature_bak=%nature%
                        set   last_as_what=%as_what%
                        unset /q   as_what
               
                rem Process filename parameter:
                        iff "" == "%different_filename_than_usual%" then
                                set filename_to_rename_as_instrumental_or_whatever=%audio_file%
                        else
                                set filename_to_rename_as_instrumental_or_whatever=%different_filename_than_usual%
                        endiff

                rem DEBUG:
                        if "1" == "%DEBUG_INSTRUMENTAL%" echo %ansi_color_debug%- DEBUG: called :rename_audio_file_as_instrumental [different_filename_than_usual=%different_filename_than_usual% as_what=%as_what% ask=%ask%] ... nature=“%nature%” ... filename_to_rename_as_instrumental_or_whatever=“%filename_to_rename_as_instrumental_or_whatever%” %ansi_color_normal%  %+ pause

                rem Skip if the file has already been marked as an instrumental/whatever:
                        rem 20250327: added brackets around %nature% in regex
                        iff "%@Regex[\[%nature%\],"%filename_to_rename_as_instrumental_or_whatever%"]" == "1" .and. "%force%" != "force" then
                                echo %ansi_color_warning_soft%%star2% %italics_on%Already marked%italics_off% as %nature%: “%faint_on%%filename_to_rename_as_instrumental_or_whatever%%faint_off%”
                                set already_marked_as=1
                        else
                                set already_marked_as=0
                                rem Try again without brackets:
                                iff "%@Regex[sound effect,"%filename_to_rename_as_instrumental_or_whatever%"]" == "1" .or. "%@Regex[sound clip,"%filename_to_rename_as_instrumental_or_whatever%"]" == "1" then
                                        echo %ansi_color_warning_soft%%star2% %italics_on%Already marked%italics_off% as a sound effect: “%faint_on%%filename_to_rename_as_instrumental_or_whatever%%faint_off%”
                                        set already_marked_as=1
                                endiff
                        endiff
                        if "1" == "%already_marked_as%" goto /i skip_it_2700




                rem If we have been asked to ask [if it’s an instrumental], then we need deal with that scenario:

                        rem 1) Check if we need to do this:
                                if "%1" != "ask" .and. "%ask%" != "ask" goto :do_not_ask_4533

                        rem 2) If we do, prepare to ask the question:
                                :rafai_ask_again
                                unset /q ANSWER              

                        rem 2.33) But like——if we already answered the question in the outer function——don’t ask:
                                rem echo - DEBUG: OUTER_INSTRUMENTAL_ANSWER==“%OUTER_INSTRUMENTAL_ANSWER%”
                                iff "" != "%OUTER_INSTRUMENTAL_ANSWER%" then
                                        set ANSWER=%OUTER_INSTRUMENTAL_ANSWER%
                                        unset /q    OUTER_INSTRUMENTAL_ANSWER
                                        goto :we_used_the_outer_answer_instead
                                endiff

                        rem 2.66) But otherwise——DO ask:
                                if "%1" == "ask" .or. "%ask%" == "ask"  call AskYN "₅Mark as %italics_on%%nature%%italics_off%? [P=%ansi_color_bright_green%P%ansi_color_prompt%lay]" no 1200 PQ Q:enQueue_in_winamp,P:Preview_file_via_playback
                                :we_used_the_outer_answer_instead


                        rem 3) If we answered the question with “P” for “Play it” (or “Q” to enQueue in WinAmp), then we aren’t sure what to do yet, and need to play it:
                        rem 3.5) And if we answered “S” for sound effect, that needs to work too...
                                iff "P" == "%ANSWER%" .or. "Q" == "%ANSWER%" .or. "S" == "%ANSWER%" then
                                        gosub   check_for_answer_of_P   "%@UNQUOTE["%filename_to_rename_as_instrumental_or_whatever%"]"
                                        gosub   check_for_answer_of_Q   "%@UNQUOTE["%filename_to_rename_as_instrumental_or_whatever%"]"
                                        gosub   check_for_answer_of_S   "%@UNQUOTE["%filename_to_rename_as_instrumental_or_whatever%"]"
                                        call    delete-zero-byte-files   %FILEMASK_AUDIO% 
                                endiff
                                iff "P" == "%ANSWER%" .or. "Q" == "%ANSWER%" then
                                        goto /i rafai_ask_again       
                                endiff

                        rem 4) If we opted not to rename it (did not press a key that results in renaming), then abort this function (return):
                                rem DEBUG: gosub debug "answer at 3942 is %answer% 🐐"
                                iff  "Y" != "%ANSWER%" .and. "I" != "%ANSWER%" .and. "S" != "%ANSWER%" .and. "C" != "%ANSWER%" then    rem We use “I” in place of “Y” for Yes-rename-as-instrumental
                                        echo %ansi_color_warning_soft%%star%Fine, won’t rename as %italics_on%%nature%%italics_off% then!%ansi_color_normal%
                                        return
                                endiff

                        rem 5) If we answered “N”
                                if "N" == "%ANSWER%" return

                        rem 6) Mark the end of this section:
                               :do_not_ask_4533



                rem Delete the existing lyric file, since if it’s an instrumental, there shouldn’t be one. Same thing for SRT/LRC files.
                        set LYRIC_SIDECAR=%@NAME["%filename_to_rename_as_instrumental_or_whatever%"].txt                        %+ rem echo %ansi_color_removal%LYRIC_SIDECAR is “%LYRIC_SIDECAR%”
                        set  JSON_SIDECAR=%@NAME["%filename_to_rename_as_instrumental_or_whatever%"].json
                        set   LRC_SIDECAR=%@NAME["%filename_to_rename_as_instrumental_or_whatever%"].lrc
                        set   SRT_SIDECAR=%@NAME["%filename_to_rename_as_instrumental_or_whatever%"].srt
                        set   LOG_SIDECAR=%@NAME["%filename_to_rename_as_instrumental_or_whatever%"].log
                        rem suspending this: if not exist "%LYRIC_SIDECAR%" goto /i no_delete_20934

                                rem if exist  "%JSON_SIDECAR%" *del    /Ns  "%JSON_SIDECAR%"
                                if exist  "%JSON_SIDECAR%" gosub delete_file  "%JSON_SIDECAR%"

                                rem if not exist    "%SRT_SIDECAR%"  goto /i endiff_not_exist_SRT_SIDECAR 
                                rem         call review-file "%SRT_SIDECAR%"
                                rem         call AskYN  "Delete SRT file" yes 0
                                rem         if "Y" != "%ANSWER%"       goto /i endiff_not_exist_SRT_SIDECAR 
                                rem         echos %ansi_color_removal%
                                rem         *del    "%SRT_SIDECAR%"
                                rem :endiff_not_exist_SRT_SIDECAR 
                                rem 
                                rem if not exist    "%LRC_SIDECAR%"  goto /i endiff_not_exist_LRC_SIDECAR 
                                rem         call review-file "%LRC_SIDECAR%"
                                rem         call AskYN  "Delete LRC file" yes 0
                                rem         if "Y" != "%ANSWER%"       goto /i endiff_not_exist_LRC_SIDECAR 
                                rem         echos %ansi_color_removal%
                                rem         *del    "%LRC_SIDECAR%"
                                rem :endiff_not_exist_LRC_SIDECAR 
                                rem 
                                rem if not exist    "%LYRIC_SIDECAR%"  goto /i endiff_not_exist_LYRIC_SIDECAR
                                rem         call review-file "%LYRIC_SIDECAR%"
                                rem         call AskYN  "Delete TXT file" yes 0
                                rem         if "Y" != "%ANSWER%"       goto /i endiff_not_exist_LYRIC_SIDECAR 
                                rem         echos %ansi_color_removal%
                                rem         *del    "%LYRIC_SIDECAR%"
                                rem :endiff_not_exist_LYRIC_SIDECAR

                                rem old way as a fallback:
                                        rem Cosmetics:
                                                set AXER=%EMOJI_AXE%%EMOJI_AXE%%EMOJI_AXE% ``

                                        rem Delete any files that are too teeny:
                                                set THRESH=5
                                                if exist "%LYRIC_SIDECAR%" if %@FILESIZE["%LYRIC_SIDECAR%"] lt %THRESH% gosub delete_file "%LYRIC_SIDECAR%"
                                                if exist  "%ELRC_SIDECAR%" if %@FILESIZE["%ELRC_SIDECAR%"]  lt %THRESH% gosub delete_file  "%ELRC_SIDECAR%"
                                                if exist   "%LRC_SIDECAR%" if %@FILESIZE["%LRC_SIDECAR%"]   lt %THRESH% gosub delete_file   "%LRC_SIDECAR%"
                                                if exist   "%SRT_SIDECAR%" if %@FILESIZE["%SRT_SIDECAR%"]   lt %THRESH% gosub delete_file   "%SRT_SIDECAR%"
                                                if exist   "%TXT_SIDECAR%" if %@FILESIZE["%TXT_SIDECAR%"]   lt %THRESH% gosub delete_file   "%TXT_SIDECAR%"

                                        rem Deal with lyrics:                        
                                                iff exist "%LYRIC_SIDECAR%" then
                                                        call review-file -wh -stu -ins "%LYRIC_SIDECAR%"        
                                                        call askyn "%AXER%⁵Delete lyric sidecar" yes 0 
                                                                iff "Y" == "%ANSWER%" then
                                                                        rem echos %AXER% ``
                                                                        rem *del /Ns "%LYRIC_SIDECAR%" 
                                                                        gosub delete_file "%LYRIC_SIDECAR%" 
                                                                        set JUST_APPROVED_LYRICS=0
                                                                        set LYRICS_JUST_DISAPPROVED=1
                                                                        set LYRIC_STATUS=NOT_APPROVED
                                                                endiff
                                                endiff
                                        rem Deal with subtitles:                        
                                                iff exist   "%SRT_SIDECAR%" .or. exist "%LRC_SIDECAR%" then
                                                        if exist "%LRC_SIDECAR%"                             (set KIND=LRC     %+ set sidecar=sidecar %+ call review-file -wh -stu -ins "%LRC_SIDECAR%")
                                                        if exist "%SRT_SIDECAR%"                             (set KIND=SRT     %+ set sidecar=sidecar %+ call review-file -wh -stu -ins "%SRT_SIDECAR%")
                                                        if exist "%SRT_SIDECAR%" .and. exist "%LRC_SIDECAR%" (set KIND=SRT/LRC %+ set sidecar=sidecars)
                                                        call askyn "%AXER%Delete %KIND% %SIDECAR%" yes 0 
                                                        iff "Y" == "%ANSWER%" then
                                                                if exist "%SRT_SIDECAR%" (echos %AXER% %+ *del /Ns "%SRT_SIDECAR%")
                                                                if exist "%LRC_SIDECAR%" (echos %AXER% %+ *del /Ns "%LRC_SIDECAR%")
                                                        endiff
                                                endiff
                                        rem Deal with administrative/audit files:                        
                                                if exist  "%LOG_SIDECAR%" (call askyn "%AXER%⁶Delete logfile sidecar" yes 0 %+ if "Y" == "%ANSWER%" (echos    %AXER% `` %+ *del /Ns  "%LOG_SIDECAR%"))
                                                if exist "%JSON_SIDECAR%" (call askyn "%AXER%⁷Delete JSON sidecar"    yes 0 %+ if "Y" == "%ANSWER%" (echos    %AXER% `` %+ *del /Ns "%JSON_SIDECAR%"))

                                        rem Cosmetics:
                                                echos %ansi_color_normal%

                        :no_delete_20934

                rem Unset status bar if it’s set:
                        call status-bar unlock
                        if "1" == "%DEBUG_INSTRUMENTAL%" echo - DEBUG: rename_audio_file_as_instrumental called with filename_to_rename_as_instrumental_or_whatever == “%filename_to_rename_as_instrumental_or_whatever%”

                rem Clean our junk files first, so they don’t get caught in the sidecar renaming madness:
                        if "1" == "%DEBUG_INSTRUMENTAL%" (echo * about to call clean-up-AI-transcription-trash-files-here.bat but just checking value of %0 which is “%0” and what about pbatchname it is “%_PBATCHNAME” and hey DELETING_BAD_AI_TRANSCRIPTIONS is %DELETING_BAD_AI_TRANSCRIPTIONS% %+ pause)
                        call clean-up-AI-transcription-trash-files-here.bat

                rem Rename the file & validate that it was named:
                        set nature=%nature_bak%
                        echos %ANSI_ERASE_TO_END_OF_SCREEN%
                        if "1" == "%DEBUG_INSTRUMENTAL%" echo - DEBUG: %ansi_color_unimportant%call rn "%@UNQUOTE[%filename_to_rename_as_instrumental_or_whatever%]" "%@NAME["%filename_to_rename_as_instrumental_or_whatever%"] [%nature%].%@EXT["%filename_to_rename_as_instrumental_or_whatever%"]"%ansi_color_normal% 🐐🐐 ... nature==“%nature%”

                        unset /q LAST_RENAMED_TO
                        rem set DEBUG_INSTRUMENTAL=1 
                        if not exist "%@UNQUOTE[%filename_to_rename_as_instrumental_or_whatever%]" goto :skip_the_rn_4114
                        call rn "%@UNQUOTE[%filename_to_rename_as_instrumental_or_whatever%]" "%@NAME["%filename_to_rename_as_instrumental_or_whatever%"] [%nature%].%@EXT["%filename_to_rename_as_instrumental_or_whatever%"]"
                        :skip_the_rn_4114
                        if "1" == "%DEBUG_INSTRUMENTAL%" echo %ansi_color_debug%- DEBUG: after rn at 3125, last_renamed_to=“%LAST_RENAMED_TO%” so maybe set tmpFileForXAnswer_copy=%LAST_RENAMED_TO%%ansi_color_normal% 
                        iff "" != "%LAST_RENAMED_TO%" then
                                set tmpFileForXAnswer_copy=%LAST_RENAMED_TO%
                                set SOME_INSTRUMENTALS_WERE_MARKED=1
                                rem     let’s not do this anymore: (20250221): set AUDIO_FILE=%@UNQUOTE[%LAST_RENAMED_TO%]
                                rem but let’s not do this now:     (20260401): 
                                set INPUT_FILE=%@UNQUOTE[%LAST_RENAMED_TO%]
                                set   SONGFILE=%@UNQUOTE[%LAST_RENAMED_TO%]
                                set AUDIO_FILE=%@UNQUOTE[%LAST_RENAMED_TO%]
                                call subtle "INPUT_FILE/SONGFILE/AUDIO_FILE set to: %INPUT_FILE%"
echo "%blink_on%set JUST_RENAMED_TO_%nature%=1 this is testing using %%nature%% in the variable name%blink_off% GOAT" %+ pause
                                set JUST_RENAMED_TO_%nature%=1
                                set JUST_RENAMED=1
                        endiff

                rem Validate that the renaming happened:              
                        rem echo BUG MONITOR for bug of: Marking instrumental doesn’t end when it should. Checking iff "" != "`%`LAST_RENAMED_TO`%`" which is “%LAST_RENAMED_TO%”... 🐐
                        iff "" != "%LAST_RENAMED_TO%" then
                                goto /i END_OF_GET_LYRICS
                                rem echo BUG MONITOR for bug of: Marking instrumental doesn’t end when it should. GOTO_END is now “%GOTO_END%” and JUST_RENAMED_TO_INSTRUMENTAL is now “%JUST_RENAMED_TO_INSTRUMENTAL%” 🐐
                        endiff

                rem All done!
                        :skip_it_2700   
                        if "1" ==           "%DEBUG_INSTRUMENTAL%" echo %ansi_color_debug%- DEBUG: DONE WITH rename_audio_file_as_instrumental %%ansi_color_normal% 
                        if "1" == "%JUST_RENAMED_TO_INSTRUMENTAL%" goto /i END_OF_GET_LYRICS                                                            %+ rem If we just marked something instrumental, then yeahhhh, we’re done with lyric-getting...
        return

        :refresh_current_lyric_provider_metadatas [opt]
                iff "%CURRENT_LYRIC_PROVIDER%" == "LyricsGenius" .or. "%CURRENT_LYRIC_PROVIDER%" == "GENIUS" then
                        set CURRENT_LYRIC_PROVIDER=LyricsGenius
                        set CURRENT_LYRIC_PROVIDER_DISPLAY=LyricsGenius
                        set OTHER_LYRIC_PROVIDER=SyncedLyrics
                        set OTHER_LYRIC_PROVIDER_DISPLAY=SyncedLyrics
                else
                        set CURRENT_LYRIC_PROVIDER=SyncedLyrics
                        set CURRENT_LYRIC_PROVIDER_DISPLAY=SyncedLyrics
                        set OTHER_LYRIC_PROVIDER=LyricsGenius
                        set OTHER_LYRIC_PROVIDER_DISPLAY=LyricsGenius
                endiff
        return
        :refresh_lyric_status [opt]
                rem echo %ANSI_COLOR_DEBUG%- DEBUG: 🐐 called 💚 refresh_lyric_status 💚 [%opt%]%ansi_color_normal%
                unset /q FILE_TO_GET_LYRIC_STATUS_OF
                set FILE_TO_GET_LYRIC_STATUS_OF=%LYRIC_FILE%
                if exist %opt% set FILE_TO_GET_LYRIC_STATUS_OF="%@UNQUOTE["%opt%"]"
                rem echo 🐐 %blink_on% %ansi_color_orange% getting lyric status of “%FILE_TO_GET_LYRIC_STATUS_OF%” %blink_off% 
                if exist "%FILE_TO_GET_LYRIC_STATUS_OF%" goto /i we_good
                        echo %ansi_color_warning_soft%%star% Lyric file doesn’t yet exist: %faint_on%“%italics_on%%FILE_TO_GET_LYRIC_STATUS_OF%%italics_off%”%faint_off% %star%
                        set LYRIC_STATUS=DOES_NOT_EXIST
                        return
                :we_good
                set REFRESH_COMMAND=call get-lyric-status "%@UNQUOTE["%FILE_TO_GET_LYRIC_STATUS_OF%"]"                
                rem echo %blink_on% %ansi_color_orange% lyric status refresh command will be: %REFRESH_COMMAND% %blink_off% 
                iff exist "%FILE_TO_GET_LYRIC_STATUS_OF%" .or. "%opt%" == "force" then
                        %REFRESH_COMMAND% >nul
                        if "" == "%last_file_to_get_lyric_status_of%" set last_file_to_get_lyric_status_of="%@UNQUOTE["%FILE_TO_GET_LYRIC_STATUS_OF%"]"
                endiff
                rem echo %blink_on% %ansi_color_orange% got lyric status of “%lyric_status%” %blink_off% 
                unset /q FILE_TO_GET_LYRIC_STATUS_OF
        return
        :refresh_lyriclessness_status [opt]
                gosub "%BAT%\create-srt-from-file.bat" refresh_lyriclessness_status %opt%
        return

        :reset_full_lyric_search_state_for_new_provider
                unset /q FIRST_SEARCH_COMPLETE lyric_downloader_initialized debanded last_search current_search current_search_* current_provider_key LD1_MASSAGED_ATTEMPT_1 cover_original_attempt ONLY_ONE_FILE_AND_IT_WAS_TRIED PREV_GENIUS_FNAME_2_USE postprocessed_lyrics
                unset /q already_tried_featured_with_* already_tried_the_with_* already_tried_at_with_*
                set        FILE_SONG_TO_USE=%FILE_SONG%
                set       FILE_TITLE_TO_USE=%FILE_SONG%
                set      FILE_ARTIST_TO_USE=%FILE_ARTIST%
                set FILE_ORIG_ARTIST_TO_USE=%FILE_ORIG_ARTIST%
                set       FILE_ALBUM_TO_USE=%FILE_ALBUM%
        return

        :say_if_exists [opt1 opt2]                
                gosub "%BAT%\create-srt-from-file.bat" say_if_exists %opt1% %opt2%
        return
        :set_latest_file [opt]
                setdos /x0
                set LATEST_FILE=%@EXECSTR[dir /b /odt |:u8 tail -1]
                call debug "%underline_on%LATEST_FILE%underline_off% is now set to: %lq%%faint_on%%LATEST_FILE%%faint_off%%rq%" silent
        return
        :set_up_variables_for_answer_of_K [opt]
                iff "1" == "%QUICK_LRC_MODE%" .or. "GOATGOAT" == "GOATGOAT" then
                        set MAYBE_OPTION_K=K
                        set MAYBE_DESCRIPTION_K=K:sKip_file_or_folder,
                        set MAYBE_PRINTABLE_K=s%ansi_color_bright_green%K%ansi_color_prompt%ip file/folder,
                else
                        unset /q MAYBE_OPTION_K MAYBE_DESCRIPTION_K MAYBE_PRINTABLE_K
                endiff
        return
        :stretch_downloaded_lrc [LRC_FILE_TO_STRETCH_PARAM]
                
                rem Validate/get filename that we are going to stretch:
                        set LRC_FILE_TO_STRETCH_TO_USE=%@UNQUOTE[%LRC_FILE_TO_STRETCH_PARAM%]
                
                        iff not exist "%LRC_FILE_TO_STRETCH_TO_USE%" then
                        
                                call warning "Cannot stretch LRC because it does not exist: %LRC_FILE_TO_STRETCH_TO_USE%" big
                        
                                return
                
                        endiff

                

                rem Figure out if we need to edit the LRC first:
                        gosub divider
        
                        call important_less "The first timestamp in the LRC must be the actual first sung word %faint_on%(not spammy song intro/transcriber credit stuff)%faint_off%"
                        call important_less "The last timestamp in the LRC must be the actual last sung word %faint_on%(not transcriber credits or blank)%faint_off%"
                        :Ask_Again_5300
                        call AskYN "Edit LRC first? %faint_on%(particularly if either of these timestamp requirements are false)%faint_off%" no 0 YNP p:PlaY_IT
                        echos %ansi_color_normal%
                        gosub check_for_answer_of_P "%@UNQUOTE[%AUDIO_FILE%]"
                        if  "P" == "%ANSWER%" goto /i Ask_Again_5300
                        iff "Y" == "%ANSWER%" then
                                repeat 2 echo.
                                echos %@ANSI_MOVE_UP[2]%ANSI_POSITION_SAVE%
                                set EDIT_CALL=%EDITOR% "%LRC_FILE_TO_STRETCH_TO_USE%"
                                rem DEBUG: echo %star2% DEBUG: editing lyric file because answer=“%answer%”  ... google_now=“%google_now%”.... call = “%blink_on%%edit_call%%blink_off%” 💩 FILE_SONG_TO_USE=“%FILE_SONG_TO_USE” 🐐
                                %EDIT_CALL%
                                pause "%blink_on%Press any key when done editing%blink_off%"
                                echos %ANSI_POSITION_RESTORE%%ANSI_CLEAR_TO_END_OF_SCREEN%     
                                echo %ansi_color_success%%check% LRC edited %check%%ansi_color_normal%%ansi_erase_to_end_of_line%%ansi_erase_to_end_of_screen%
                                if exist "%LRC_FILE_TO_STRETCH_TO_USE%" call review-file --KeepTimestamps -wh -stU "%LRC_FILE_TO_STRETCH_TO_USE%" "%underline_on%LRC after your edit%underline_off%"               
                                rem goto /i Ask_Again_5300                
                        endiff
                        gosub divider

                rem Get the parameters for our stretch:
                        call advice "Stretch argument examples:"
                
                                echo %ansi_color_advice%%star% Usage 1: seconds to slide every timestamp by, e.g. %ansi_color_bright_green%+2.45%ansi_color_advice% or %ansi_color_bright_green%-2.5s%ansi_color_normal%
                
                                echo %ansi_color_advice%%star% Usage 2: new final timestamp %faint_on%(slides all timestamps so the last one lands there)%faint_off%, e.g. %ansi_color_bright_green%1:59%ansi_color_advice% or %ansi_color_bright_green%0:35.22%ansi_color_normal%
                
                                echo %ansi_color_advice%%star% Usage 3: new beginning and final timestamps, e.g. %ansi_color_bright_green%0:30,4:45%ansi_color_normal%
                
                        if not defined LRC_STRETCH_ARGUMENT set LRC_STRETCH_ARGUMENT=0
                
                        eset LRC_STRETCH_ARGUMENT

                


                rem Stretch the file appropriately:
                        iff "%LRC_STRETCH_ARGUMENT%" == "" .or. "%LRC_STRETCH_ARGUMENT%" == "0" then
                        
                                call unimportant "No LRC stretch requested."
                
                        else
                        
                                rem calling: stretch_lrc.py                                                                
                                echo %ansi_color_run%%ansi_color_debug%%bold_on%%emoji_telephone_receiver% Calling:%bold_off%  stretch_lrc.py %faint_on%"%LRC_FILE_TO_STRETCH_TO_USE%"%faint_off% %blink_on%%LRC_STRETCH_ARGUMENT%%blink_off%%ansi_color_normal%
                                pause "%ansi_color_warning_soft%Press any key to %underline_on%stretch%underline_off% the LRC...%ansi_color_normal%"
                                stretch_lrc.py "%@UNQUOTE["%LRC_FILE_TO_STRETCH_TO_USE%"]" "%LRC_STRETCH_ARGUMENT%"
                                call errorlevel
                        endiff

                

                rem Display/Review our results:
                        if exist "%LRC_FILE_TO_STRETCH_TO_USE%" call review-file --KeepTimestamps -wh -stL "%LRC_FILE_TO_STRETCH_TO_USE%" "%underline_on%LRC after stretch step%underline_off% - %LRC_FILE_TO_STRETCH_TO_USE%"
                
                        gosub divider
        
        return

        



rem ━━━━━━━━━━━━━━ SUBROUTINES: END ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━





rem ━━━━━━━━━━━━━━ ENDINGS: BEGIN ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

:end_quick_lrc_mode_fail
        gosub delete_quick_lrc_mode_files
        gosub divider
        call celebrate "%ansi_color_warning_soft% Quick LRC retrieval failed! ``"
        gosub divider
        repeat 8 echo.
        set QUICK_LRC_FAILED=1
        set QUICK_LRC_SKIPPED=0
        set QUICK_LRC_SUCCESS=0
        goto :END_OF_GET_LYRICS

:end_quick_lrc_mode_skip
        gosub delete_quick_lrc_mode_files
        gosub divider
        call celebrate "Quick LRC retrieval skipped!"
        gosub divider
        repeat 8 echo.
        set QUICK_LRC_FAILED=0
        set QUICK_LRC_SKIPPED=1
        set QUICK_LRC_SUCCESS=0
        goto :END_OF_GET_LYRICS

:end_quick_lrc_mode_success
        gosub delete_quick_lrc_mode_files
        gosub divider
        call celebrate "Quick LRC retrieved successful!"
        gosub divider
        repeat 8 echo.
        set QUICK_LRC_FAILED=0
        set QUICK_LRC_SKIPPED=0
        set QUICK_LRC_SUCCESS=1
        goto :END_OF_GET_LYRICS
        
:END_OF_GET_LYRICS          
        call subtle "End of get-lyrics (parent_bat=%PARENT_BAT%) begins [QUICK_LRC_FAILED=“%QUICK_LRC_FAILED%”  QUICK_LRC_SKIPPED=“%QUICK_LRC_SKIPPED%”  QUICK_LRC_SUCCESS=“%QUICK_LRC_SUCCESS%”]"

rem ━━━━━━━━━━━━━━ ENDINGS: END ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━





:Not_Quite_The_VERY_End
        echo 🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁 end 🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁 >nul
        rem echo 🦴 this is the very end! %+ rem call pause-for-x-seconds 9

        rem Fix command separator:        
                if "%username%" != "claire" goto /i fcs_end
                        @setdos /x0
                        @*setdos /x-5
                        @*setdos /c%DEFAULT_COMMAND_SEPARATOR_CHARACTER%
                        @setdos /x0
                :fcs_end

        rem Clean our temporary file (do we want to do this in SetVarsOnly mode?):
                if exist "__" (*del /q "__">nul)

:Pop_D
        echo 🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁 end 🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁 >nul
        rem Bring us back one folder level from the folder stack:
                setdos /x0
                REM this got me in trouble: whatever it was fixing needs to be fixed some other way:
                rem if %@DirStack[] gt 0 popd                                    %+ rem If we pushd’ed to another folder, popd back
                rem But unlike in create-srt, we will only do this once, so we won’t do this part: if %@DirStack[] gt 0 goto /i Pop_D

        echo 🧹🧹🧹🧹🧹🧹 unsetting 🧹🧹🧹🧹🧹🧹🧹 GOTO_END=“%GOTO_END%” >nul
        rem echo 🦴 this is the unsetting of the very end! %+ rem call pause-for-x-seconds 9
        rem Unset various environment variables that we realllllllly want unset:        
                unset /q DO_NOT_ASK_TO_HAND_EDIT WE_GOOGLED TRY_SELECTION_AGAIN COVER_ORIGINAL_ATTEMPT LD1_MASSAGED_ATTEMPT_1 ONLY_ONE_FILE_AND_IT_WAS_TRIED DO_NOT_ASK_TO_HAND_EDIT JUST_APPROVED_LYRICS LYRICS_JUST_DISAPPROVED JUST_GENERATED_LYRICS FORCE_HAND_EDIT GENIUS_ONLY GOOGLE_NOW FORCE_ASK_TO_APPROVE_LYRICLESSNESS RESTARTED_WITH_OTHER_LYRIC_PROVIDER
            rem unset /q ALREADY_HAND_EDITED

            rem for LYRIC/LYRICLESSNESS status we want to retain the values if being called to create karaoke——so the karaoke creation process knows they are done
            rem     But otherwise, if we’re just looking for lyrics, then we can unset this value as we don’t need it later and it can mess up multilpe lyric search:
            rem echo 🦴 parent_bat = “%PARENT_BAT%” .. making_karaoke=“%making_karaoke%” %+ rem call pause-for-x-seconds 9
                if "%PARENT_BAT%" != "create-srt-from-file" unset /q LYRICLESSNESS_STATUS LYRIC_STATUS                                                  
                if "%2"           != "SetVarsOnly"          unset /q FORCE_REGEN_LYRICS 
            rem unset /q ANSWER HOLD_ANSWER 
                unset /q ABANDONED_SEARCH
            rem unset /q LYRIC_SEARCH_FAILED            //leave this one for auditing
            rem unset /q LYRIC_RETRIEVAL_1_FAILED       //leave this one for auditing
            rem unset /q JUST_RENAMED_TO_INSTRUMENTAL   //leave this one for the outer create-srt to know result of
            rem unset /q PROBED_OR_REFUSED_ALREADY_709
                unset /q LYRICS_SHOULD_BE_CONSIDERED_ACCEPTIBLE  found_broad_lyrics_branch_1 LYRIC_SUCCESS_CELEBRATION_DISPLAYED already_tried_potential_lyrics_* did_not_go_to_end_169 goto_download_with_lyric_downloader_1 FIRST_SEARCH_COMPLETE goto_download_with_lyric* lyric_downloader_initialized  debanded LAST_ALIGNMENT_TEMP_INDEX PREV_GENIUS_FNAME_2_USE postprocessed_lyrics DO_NOT_ASK_TO_SET_LYRICLESS_AGAIN REFUSED_LOCAL_REPO COPIED_REPO_LYRIC
                unset /q CURRENT_LYRIC_PROVIDER CURRENT_LYRIC_PROVIDER_DISPLAY OTHER_LYRIC_PROVIDER OTHER_LYRIC_PROVIDER_DISPLAY PRIMARY_LYRIC_PROVIDER PROVIDER_ONLY PROVIDER_PASS_DONE_GENIUS PROVIDER_PASS_DONE_SYNCEDLYRICS RESTARTED_WITH_OTHER_LYRIC_PROVIDER PREVIOUS_LYRIC_PROVIDER_DISPLAY SYNCEDLYRICS_ONLY current_provider_key 
            rem unset /q JUST_CONVERTED_LRC_TO_TEXT=0 JUST_CONVERTED_SRT_TO_TEXT=0 %+ rem TODO i think maybe this should not be added: 


:final_ending
        rem echo 🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁 END GET-LYRICS %* !!!! 🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁🏁 (pbatchname=%_PBATCHNAME)  {LYRIC_STATUS=“%LYRIC_STATUS”,LYRICLESSNESS_STATUS=“%LYRICLESSNESS_STATUS%”} >nul
        unset /q logged_lyricapproval_* player_command_to_use currently_getting_lyrics
        :SetVarsOnly_skip_to_2
        @setdos /x0
        echo PARENT_BAT was %PARENT_BAT% >nul
        call subtle "End of get-lyrics (parent_bat=%PARENT_BAT%) ends"


