                rem DEBUG: call debug "[9A9A9A] CURRENT_LYRIC_PROVIDER = %CURRENT_LYRIC_PROVIDER% goat"  silent
                iff "%CURRENT_LYRIC_PROVIDER%" != "LyricsGenius" then
                        rem call subtle "Skipping %italics_on%LyricGenius%italics_off% section because %italics_on%current_lyric_provider%italics_off% is “%underline_on%%CURRENT_LYRIC_PROVIDER%%underline_off%”..."
                        goto /i :end_of_lyric_genius_section_1
                else
                        call subtle "Continuing into %italics_on%LyricsGenius%italics_off% section..."
                endiff

        rem Get the most latest file so we can examine it to see if it’s the lyrics we just tried to download or not:
                gosub set_latest_file
                call subtle "Determined latest file: %faint_on%%italics_on%%LATEST_FILE%%italics_off%%faint_off%"

        rem Generate the proper post-downloader intermediate filename for our freshly-downloaded lyrics, and if it already exists, back it up:
                set LATEST_FILE_EXTENSION=%@EXT[%LATEST_FILE]`` 
                rem EXPECTED_JSON_FILE_NAME=%SONG_DIR%%ZZZZZZZZ%%@NAME["%AUDIO_FILE%"].%LATEST_FILE_EXTENSION%``
                set EXPECTED_JSON_FILE_NAME=%SONG_DIR%%@UNQUOTE[%@NAME["%AUDIO_FILE%"]].json
                call subtle "Determining preferred JSON filename: %faint_on%%italics_on%%EXPECTED_JSON_FILE_NAME%%italics_off%%faint_off%"
                if exist "%EXPECTED_JSON_FILE_NAME%" .and. ("%LATEST_FILE_EXTENSION%" == "json" .or. "%LATEST_FILE_EXTENSION%" == "txt") (*ren /Ns /q "%EXPECTED_JSON_FILE_NAME%" "%EXPECTED_JSON_FILE_NAME%.%_datetime.replaced-by-download.bak">nul)  %+ rem maintanance warning: if we ever download extensions other than JSON/TXT we need to update this

        rem See if our latest file is the expected extension [which would indicate download sucess] or not:              
                if not exist %LATEST_FILE% set SIZE_OF_LATEST_FILE=0
                if     exist %LATEST_FILE% set SIZE_OF_LATEST_FILE=%@FILESIZE[%LATEST_FILE]
                call subtle "Determining extension & size of latest file: %faint_on%%italics_on%%LATEST_FILE_EXTENSION%, %SIZE_OF_LATEST_FILE%%italics_off%%faint_off%"
                set  WHAT_WE_SEARCHED_GENIUS_FOR=%@CAPS[%@ReReplace[_, ,%@ReReplace[lyrics_,,%@NAME[%LATEST_FILE%]]]]
                iff %SIZE_OF_LATEST_FILE% gt %MOST_BYTES_THAT_LYRICS_COULD_BE% then  
                        @echos %@ANSI_MOVE_TO_COL[0]               %@ANSI_MOVE_TO_COL[11]``
                        echo %ansi_color_warning%%emoji_warning% Caution! Download is %SIZE_OF_LATEST_FILE%b, larger than threshold of %MOST_BYTES_THAT_LYRICS_COULD_BE%b %emoji_warning%%ansi_color_normal%
                        if 0 lt %LARGE_DOWNLOAD_WARNING_WAIT_TIME (call pause-for-x-seconds %LARGE_DOWNLOAD_WARNING_WAIT_TIME%)
                endiff
                iff "%LATEST_FILE_EXTENSION%" == "%LYRIC_DOWNLOADER_1_EXPECTED_EXT%" then
