                                iff exist %TMPFILE1% then
                                        set GENIUS_FRESH_LYRICS=%TMPFILE1%
                                        type "%GENIUS_FRESH_LYRICS%" |:u8 %BAT%\insert-before-each-line.py "           "   |:u8 %BAT%\strip-ansi |:u8 %BAT%\highlight "[A-Za-z0-9_]*.json"
                                endiff

                :endiff_2316
