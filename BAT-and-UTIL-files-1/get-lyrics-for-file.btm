                        set   DO_NOT_ASK_TO_HAND_EDIT=1

                        goto /i have_acceptable_lyrics_now_or_at_the_very_least_are_done
                else
                        iff "%ANSWER%" == "L" then
                                set LYRICLESSNESS_STATUS=APPROVED
                        else
