                                rem call debug "Initiating search with LyricsGenius...CURRENT_LYRIC_PROVIDER = %CURRENT_LYRIC_PROVIDER% GOAT" silent
                                rem OLD: ((echo y | %LYRIC_RETRIEVAL_COMMAND%) |:u8 %BAT%\insert-before-each-line.py "           "   |:u8 %BAT%\strip-ansi |:u8 %BAT%\highlight "[A-Za-z0-9_]*.json") 
                                rem NEW:
                                call set-tmp-file "genius-lyric-maybe"
                                (echo y | %LYRIC_RETRIEVAL_COMMAND%) >:u8%TMPFILE1%
