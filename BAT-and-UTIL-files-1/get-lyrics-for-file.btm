                                                rem !!!                           timer /5 on >nul
                                                rem !!!                           set       FILE_ALBUM=%@EXECSTR[%PROBER% -v quiet -show_entries format_tags=album  -of default=noprint_wrappers=1:nokey=1 "%AUDIO_FILE%" |:u8 change-single-quotes-to-double-apostrophes.py]
                                                rem !!!                           set      FILE_ARTIST=%@EXECSTR[%PROBER% -v quiet -show_entries format_tags=artist -of default=noprint_wrappers=1:nokey=1 "%AUDIO_FILE%" |:u8 change-single-quotes-to-double-apostrophes.py]
                                                rem !!!                           set        FILE_SONG=%@EXECSTR[%PROBER% -v quiet -show_entries format_tags=title  -of default=noprint_wrappers=1:nokey=1 "%AUDIO_FILE%" |:u8 change-single-quotes-to-double-apostrophes.py]
                                                rem !!!                           set FILE_ORIG_ARTIST=%@EXECSTR[%PROBER% -v quiet -show_entries format_tags=TOPE   -of default=noprint_wrappers=1:nokey=1 "%AUDIO_FILE%" |:u8 change-single-quotes-to-double-apostrophes.py]
                                                rem !!!                           set PROBED_FILE_ALBUM=%PROBED_FILE_ALBUM%
                                                rem !!!                           set PROBED_FILE_ARTIST=%FILE_ARTIST%
                                                rem !!!                           set PROBED_FILE_SONG=%FILE_SONG%
                                                rem !!!                           set PROBED_FILE_ORIG_ARTIST=%FILE_ORIG_ARTIST%
                                                rem !!!                           echos %ansi_color_yellow%
                                                rem !!!                           timer   /5   off %+ rem 0.946-.948
                                                rem !!!                           :probe_slower_end
                                                rem !!!                           
                                                rem !!!                           
                                                rem !!!                           
                                                rem !!!           
                                                rem !!!                   :probe_faster
                                                rem !!!                           rem timer /5 on >nul
                                                rem !!!                           
                                                rem !!!                           rem Handle undefined variables
                                                rem !!!                                   set "probe_tit="
                                                rem !!!                                   set "probe_art="
                                                rem !!!                                   set "probe_alb="
                                                rem !!!                                   set "probe_tpe="
                                                rem !!!                                   set "probe_hmm="
                                                rem !!!                                                           
                                                rem !!!                           rem Skip if we already probed the file (for instance, in the outer-layer/LRC-creator):
                                                rem !!!                                   set already_probed=0
                                                rem !!!                                   iff "%last_file_probed%" == "%AUDIO_FILE%" .and. defined probe_output .and. "" != "%PROBE_OUTPUT%" then
                                                rem !!!                                           if %DEBUG_VALUE_TRANSFER gt 0 (echo Skipping probe because we already probed %audio_file%)
                                                rem !!!                                           goto /i :already_probed
                                                rem !!!                                   endiff
                                                rem !!!                                   
                                                rem !!!                           rem Clear any previous leftover probe values:
                                                rem !!!                                   set       FILE_ALBUM=
                                                rem !!!                                   set      FILE_ARTIST=
                                                rem !!!                                   set        FILE_SONG=
                                                rem !!!                                   set FILE_ORIG_ARTIST=
                                                rem !!!                                   
                                                rem !!!                           rem Probe the file:                        
                                                rem !!!                                   set delimeter_ascii=14
                                                rem !!!           
                                                rem !!!                                   set PROBE_COMMAND=%PROBER% -v quiet -show_entries format_tags=title,artist,album,TOPE,composer -of compact=p=0:nk=0:s="%@CHAR[%delimeter_ascii%]"  "%AUDIO_FILE%"
                                                rem !!!                                   if %DEBUG_VALUE_TRANSFER% gt 0 (echo %ansi_color_debug%%star9% argh: PROBE_COMMAND=“%PROBE_COMMAND%”)
                                                rem !!!                                   unset /q probe_output        
                                                rem !!!           
                                                rem !!!                                   rem echo %ansi_color_debug%- DEBUG [aaa]: [about to set probe output] [] probe_command=“%probe_command” 👾 %ansi_color_normal%
                                                rem !!!           
                                                rem !!!                                   call set-tmp-file "probed_results"
                                                rem !!!                                   set tmpfile=%tmpfile%.txt
                                                rem !!!           
                                                rem !!!                                   rem echo %ansi_color_debug%- DEBUG [ccc]: old command was: rem (set probe_output=`%`@execstr[%PROBE_COMMAND% `|`:u8 change-single-quotes-to-double-apostrophes.py])%ansi_color_normal%
                                                rem !!!           
                                                rem !!!                                   (%PROBE_COMMAND% |:u8 change-single-quotes-to-double-apostrophes.py) >:u8 %tmpfile%
                                                rem !!!           
                                                rem !!!                                   *setdos /x-5 %+ rem otherwise if the probe data has “&&” in it, the part after “&&” gets sent to the command line! bug report filed at https://jpsoft.com/forums/threads/is-this-by-design-execstr-type-filename-and-line-send-parts-of-the-text-file-after-directly-to-the-command-line.12502/
                                                rem !!!                                   set probe_output=%@EXECSTR[type "%@UNQUOTE["%tmpfile%"]"]
                                                rem !!!                                   setdos /x0
                                                rem !!!           
                                                rem !!!                                   if %DEBUG_VALUE_TRANSFER% gt 0  (echo %star9% sooo: PROBE_OUTPUT=“%PROBE_OUTPUT%”)
                                                rem !!!           
                                                rem !!!                                   set last_file_probed=%AUDIO_FILE%
                                                rem !!!           
                                                rem !!!           
                                                rem !!!                           rem Split the string into tokens:
                                                rem !!!                                   rem echo - DEBUG:  wondering if things went south yet [1]
                                                rem !!!                                   for /f "tokens=1-5 delims=%@CHAR[%delimeter_ascii%]" %%a in ("%probe_output%") do (
                                                rem !!!                                           rem if %DEBUG_VALUE_TRANSFER gt 0 .or. %DEBUG_TOKEN_PROCESSING gt 0 (echo       %faint_on%%wrench% processing tokens (tit=%[faint_off]%%a %@ansi_move_left[1]%[faint_on]) (art=%[faint_off]%%b %@ansi_move_left[1]%[faint_on]) (alb=%[faint_off]%%c %@ansi_move_left[1]%[faint_on]) (tope=%[faint_off]%%d %@ansi_move_left[1]%[faint_on]) (hmm=%[faint_off]%e %@ansi_move_left[1]%[faint_on])%[faint_off])
                                                rem !!!                                           rem this ruins things *setdos /x-5
                                                rem !!!                                           set "probe_tit=%%a"
                                                rem !!!                                           set "probe_art=%%b"
                                                rem !!!                                           set "probe_alb=%%c"
                                                rem !!!                                           set "probe_tpe=%%d"
                                                rem !!!                                           set "probe_hmm=%%e"
                                                rem !!!                                           setdos /x0
                                                rem !!!                                   )
                                                rem !!!           
                                                rem !!!                           rem It doesn’t count if it matches the a/b/c/d/e var we already had outside of the split ... those are urnelated single-letter environment variables
                                                rem !!!                                   *setdos /x-5
                                                rem !!!                                   if "%probe_tit" == "%a" set probe_tit=
                                                rem !!!                                   if "%probe_art" == "%b" set probe_art=
                                                rem !!!                                   if "%probe_alb" == "%c" set probe_alb=
                                                rem !!!                                   if "%probe_tpe" == "%d" set probe_tpe=
                                                rem !!!                                   if "%probe_hmm" == "%e" set probe_hmm=
                                                rem !!!                                   setdos /x0
                                                rem !!!           
                                                rem !!!                           rem Save post-probed values for auditing
                                                rem !!!                                   rem echo - DEBUG:  wondering if things went south yet [2]
                                                rem !!!                                   unset /q PROBED*
                                                rem !!!                                   *setdos /x-5
                                                rem !!!                                   set PROBED_FILE_SONG=%probe_tit%
                                                rem !!!                                   set PROBED_FILE_ARTIST=%probe_art%
                                                rem !!!                                   set PROBED_FILE_ALBUM=%probe_alb%
                                                rem !!!                                   set PROBED_FILE_ORIG_ARTIST_TOPE=%probe_tpe%
                                                rem !!!                                   set PROBED_FILE_ORIG_ARTIST_HMMM=%probe_hmm%
                                                rem !!!                                   setdos /x0
                                                rem !!!           
                                                rem !!!                           rem Untested attempt to copmensate for original artist/composer difference in mp3/flac tags:
                                                rem !!!                                   if "" == "%probe_tpe" .and. "" != "%probe_hmm%" (set probe_tpe=%probe_hmm%)
                                                rem !!!                                   
                                                rem !!!                           rem Transfer values over to our variables:         
                                                rem !!!                                   for %%tmpVarName in (probe_tit, probe_art, probe_alb, probe_tpe, probe_hmm) do gosub sub_for_724  "%@UNQUOTE["%tmpVarName%"]"
                                                rem !!!                                                   goto /i for_724_end                                        
                                                rem !!!                                                           :sub_for_724 [opt1]
                                                rem !!!                                                                   set tmpVarName=%@UNQUOTE["%tmpVarName%"]
                                                rem !!!                                                                   rem bad idea ... really need to set the separator to somehting else *setdos /x-5
                                                rem !!!                                                                   set value=%[%tmpvarname]                                
                                                rem !!!           
                                                rem !!!                                                                   set LEFT_NIN=%@left[ 9,%value%]
                                                rem !!!                                                                   set LEFT_TEN=%@left[10,%value%]
                                                rem !!!                                                                   set LEFT_ELV=%@left[11,%value%]
                                                rem !!!                                                                   set LEFT_THI=%@left[13,%value%]
                                                rem !!!           
                                                rem !!!                                                                   if %DEBUG_VALUE_TRANSFER gt 0  (echo %newline%!!   %%tmpVarName  is %lq%%TmpVarName%%rq% is %%value=%lq%%value%%rq% %+ echo    left_nin is %lq%%left_nin%%rq%%+ echo    left_ten is %lq%%left_ten%%rq% %+ echo    left_elv is %lq%%left_elv%%rq% %+ echo    left_thi is %lq%%left_thi%%rq%)
                                                rem !!!                                                                   setdos /x0
                                                rem !!!                                                
                                                rem !!!                                                                   rem echo %ansi_color_grey%- DEBUG:  wondering if things went south yet [3]%ansi_color_normal%
                                                rem !!!           
                                                rem !!!                                                                   iff "%LEFT_TEN%" == "tag:TITLE=" then
                                                rem !!!                                                                           if %DEBUG_VALUE_TRANSFER gt 0 (echo    🐓 setting FILE_SONG=%@right[%@eval[%@len[%value]-10],%value])
                                                rem !!!                                                                           set FILE_SONG=%@right[%@eval[%@len[%value]-10],%value]
                                                rem !!!                                                                   endiff
                                                rem !!!                                                                   iff "%LEFT_ELV%" == "tag:ARTIST=" then
                                                rem !!!                                                                           set FILE_ARTIST=%@right[%@eval[%@len[%value]-11],%value]
                                                rem !!!                                                                           if %DEBUG_VALUE_TRANSFER gt 0 (echo    🐓 setting FILE_ARTIST=%@right[%@eval[%@len[%value]-11],%value])
                                                rem !!!                                                                   endiff 
                                                rem !!!                                                                   iff "%LEFT_TEN%" == "tag:ALBUM=" then
                                                rem !!!                                                                           set tmpvalue=%@right[%@eval[%@len[%value]-10],%value]
                                                rem !!!                                                                           set FILE_ALBUM=%tmpvalue%
                                                rem !!!                                                                           if %DEBUG_VALUE_TRANSFER gt 0 (echo    🐓 setting FILE_ALBUM=%lq%%tmpvalue%%rq%)
                                                rem !!!                                                                   endiff 
                                                rem !!!                                                                   iff "%LEFT_THI%" == "tag:COMPOSER=" then
                                                rem !!!                                                                           set FILE_ORIG_ARTIST=%@right[%@eval[%@len[%value]-13],%value]
                                                rem !!!                                                                           if %DEBUG_VALUE_TRANSFER gt 0 (echo    🐓 setting FILE_ORIG_ARTIST=%@right[%@eval[%@len[%value]-13],%value])
                                                rem !!!                                                                   endiff
                                                rem !!!                                                                   iff "%LEFT_NIN%" == "tag:TOPE=" then
                                                rem !!!                                                                           set FILE_ORIG_ARTIST=%@right[%@eval[%@len[%value]-9],%value]
                                                rem !!!                                                                           if %DEBUG_VALUE_TRANSFER gt 0 (echo    🐓 setting FILE_ORIG_ARTIST=%@right[%@eval[%@len[%value]-9],%value])
                                                rem !!!                                                                   endiff
                                                rem !!!                                                           return
                                                rem !!!                                                   :for_724_end
                                                rem !!!                                   rem echo - DEBUG:  wondering if things went south yet [4]
                                                rem !!!                                   iff "1" == "%DEBUG_DISPLAY_PROBE_RESULTS%" then
                                                rem !!!                                           %color_debug%
                                                rem !!!                                           color bright red on black
                                                rem !!!                                           setdos /x-5
                                                rem !!!                                           echo    🔬 probed song: “%probe_tit%” but file_song  =“%file_song%”
                                                rem !!!                                           echo    🔬 probed band: “%probe_art%” but file_artist=“%file_artist%”
                                                rem !!!                                           echo    🔬 probed albm: “%probe_alb%” but file_album =“%file_album%”
                                                rem !!!                                           echo    🔬 probed tope: “%probe_tpe%” \__ orig_artist=“%file_orig_artist%”
                                                rem !!!                                           echo    🔬 probed hmmm: “%probe_hmm%” /
                                                rem !!!                                           setdos /x0
                                                rem !!!                                           %color_normal%
                                                rem !!!                                   endiff                                
                                                rem !!!           
                                                rem !!!                   rem If we didn’t get a title, use the filename after the number, i.e. “01_Time.flac" ——> “Time"
                                                rem !!!                           if "" == "%FILE_SONG%" (set FILE_SONG=%@rereplace[[\d]+_,,%@name["%AUDIO_FILE%"]])
                                                rem !!!           
                                                rem !!!                   rem If we didnt’ get an artist, but the filename is a " - " type name, then get the aprt before the " - "                
                                                rem !!!                           set audio_file_has_spacedashspace=%@RegEx[ \- ,"%AUDIO_FILE%"]
                                                rem !!!                           iff "" == "%FILE_ARTIST%" .and. "1" == "%audio_file_has_spacedashspace%" then
                                                rem !!!                                   set FILE_ARTIST=%@UNQUOTE[%@ReReplace[[0-9]+_,,%@ReReplace[ \- .*$,,"%AUDIO_FILE%"]]]
                                                rem !!!                                   echo %star3%%emoji_warning% Attempting to create file_artist from audio filename.... got “%FILE_ARTIST%” %emoji_warning% %star3% %conceal_on%🦕🦕🦕🦕🦕🦕🦕🦕🦕🦕🦕🦕🦕🦕🦕🦕%conceal_off%
                                                rem !!!                           endiff
                                                rem !!!           
                                                rem !!!                   rem If we didn’t get an original artist, also check fo the Composer tag which is the only place it would likely be in a FLAC file...
                                                rem !!!                           rem echo - DEBUG:  wondering if things went south yet [5]
                                                rem !!!                           rem NO! ffprobe does some voodoo behind the scenes making this unnecessary: if "" == "%FILE_ORIG_ARTIST%" (set FILE_ORIG_ARTIST=%@EXECSTR[%PROBER% -v quiet -show_entries format_tags=Composer -of default=noprint_wrappers=1:nokey=1 "%AUDIO_FILE%" |:u8 change-single-quotes-to-double-apostrophes.py])
                                                rem !!!           
                                                rem !!!                   rem “Title” is better than “Song”, but we are doing both for ease-of-remembrance
                                                rem !!!                           set FILE_TITLE=%FILE_SONG%
                                                rem !!!           
                                                rem !!!                   rem Done probing!                
                                                rem !!!                           if %DEBUG gt 0 call unimportant "Probing done"         
                                                rem !!!                           :already_probed
                                                rem !!!           
                                                rem !!!           
                                                rem !!!           rem Update window title:
                                                rem !!!                   if %DEBUG gt 0 call unimportant "setting window title to “%FILE_ARTIST% – %FILE_SONG%”"
                                                rem !!!                   set title=%FILE_ARTIST% – %FILE_SONG%
                                                rem !!!                   title %title%
                                                rem !!!                   if %vebose gt 0 call unimportant "Title set" 
                                                rem !!!           
                                                rem !!!           rem Back up original values of these variables because we change them as we try various different ways of searching:
                                                rem !!!                   set      FILE_ARTIST_INITIAL=%FILE_ARTIST%
                                                rem !!!                   set FILE_ORIG_ARTIST_INITIAL=%FILE_ORIG_ARTIST%
                                                rem !!!                   set       FILE_ALBUM_INITIAL=%FILE_ALBUM%
                                                rem !!!                   set        FILE_SONG_INITIAL=%FILE_SONG%
                                                rem !!!                   set       FILE_TITLE_INITIAL=%FILE_SONG%
                                                rem !!!                   if %vebose gt 0 call unimportant "Original values saved" 
                                                rem !!!                   rem echo - DEBUG:  wondering if things went south yet [6]
                                                rem !!!           
:old_probe_end_846




rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

rem If we are in the special mode where we ONLY set environment variables, go to that section:
        if "%2" == "SetVarsOnly" (goto /i SetVarsOnly_skip_to_1)

rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
rem Debug info:
        if "1" == "%DEBUG_DISPLAY_PROBE_RESULTS%" gosub debug "Retrieved: artist=“%FILE_ARTIST%” ⫽ title=“%FILE_SONG%” ⫽ album=“%FILE_ALBUM%” ⫽ orig art=“%FILE_ORIG_ARTIST%” ⫽ probe_tpe=“%probe_tpe%”"
        if %vebose gt 0 call unimportant "Debug info printed" 

rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━-━-━-━

rem First things first——If it’s a cover song, and we know the original artist, we should search for lyrics by the original artist.
rem However, FLAC files don’t have an original artist tag, just “Composer”, and people put both types of values in them.
rem So we have to suspend this practice and compensate some other way later.
        iff "%FILE_ARTIST%" != "%FILE_ORIG_ARTIST%" .and. "" != "%FILE_ORIG_ARTIST%" then
                rem set FILE_ARTIST=%FILE_ORIG_ARTIST%
                set IS_POTENTIALLY_COVER_SONG=1
        else                
                set IS_POTENTIALLY_COVER_SONG=0
        endiff                
        
        if "1" == "%DEBUG_DISPLAY_PROBE_RESULTS%"  echo %star% %ansi_color_green%[DDPR] IS_POTENTIALLY_COVER_SONG=%IS_POTENTIALLY_COVER_SONG% .... FILE_ARTIST = “%FILE_ARTIST%” ... FILE_ORIG_ARTIST = “%FILE_ORIG_ARTIST%”  🎸  %ansi_color_normal%


rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━-━-━-━

rem Set potential filenames in our %LYRICS% repository, which can be matched 2 different ways: 
        :SetVarsOnly_skip_to_1
        set MAYBE_SUBDIR_LETTER=%@LEFT[1,%file_artist]
        set              MAYBE_LYRICS_1=%lyrics\%MAYBE_SUBDIR_LETTER%\%file_artist% - %zzzzzzz%%@ReReplace[',_,%file_song%].txt
        set MAYBE_LYRICS_1_BROAD_SEARCH=%lyrics\%MAYBE_SUBDIR_LETTER%\%file_artist% - %@LEFT[3,%@ReReplace[',_,%file_song]]*.txt
        set              MAYBE_LYRICS_2=%lyrics\%MAYBE_SUBDIR_LETTER%\%@NAME[%AUDIO_FILE].txt

rem Also, subtitle files that may exist?
        set MAYBE_SRT_1=%@PATH[%maybe_lyrics_1]%@NAME[%MAYBE_LYRICS_1].lrc
        set MAYBE_SRT_2=%@PATH[%maybe_lyrics_2]%@NAME[%MAYBE_LYRICS_2].lrc

        if "%2" == "SetVarsOnly" (goto /i SetVarsOnly_skip_to_2)


rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━-━-━-━
             
rem If we have set CONSIDER_ALL_LYRICS_APPROVED=1, then auto-approve lyrics at this first prompt, and reduce the time-wait on that prompt:
        iff "1" == "%CONSIDER_ALL_LYRICS_APPROVED%" then
                rem echo - %italics_on%Automatic%italics_off% acceptance of lyrics at prompt#1 turned %blink_on%on%blink_off% %ANSI_COLOR_NORMAL%
                set DEFAULT_LYRIC_ACCEPTANCE_PROMPT_1=yes
                if not defined LYRIC_ACCEPTABILITY_REVIEW_WAIT_TIME_AUTO set LYRIC_ACCEPTABILITY_REVIEW_WAIT_TIME_AUTO=4
                set LYRIC_ACCEPTABILITY_REVIEW_WAIT_TIME=%LYRIC_ACCEPTABILITY_REVIEW_WAIT_TIME_AUTO%
                set HAND_EDIT_ARTIST_AND_SONG_AND_LYRICS_PROMPT_WAIT_TIME=%LYRIC_ACCEPTABILITY_REVIEW_WAIT_TIME_AUTO%
        else
                rem echo %ANSI_COLOR_DEBUG%%STAR% %italics_on%Automatic%italics_off% acceptance of lyrics at prompt#1 turned %blink_on%off%blink_off% %ANSI_COLOR_NORMAL%
                set DEFAULT_LYRIC_ACCEPTANCE_PROMPT_1=no
        endiff
        
rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

rem Check if we already have a LRC/SRT file but no TXT file

        :Check_Again
        iff exist "%LYRIC_FILE%" .and. "%@FILESIZE["%LYRIC_FILE%"]" != "0" goto /i goto_endpoint_830

                rem don’t convert if in genius-download-only mode:
                        if "1" == "%GENIUS_ONLY%" .or. "%PROVIDER_ONLY%" != "" .or. "1" == "%QUICK_LRC_MODE%" goto /i :do_not_convert_if_in_genius_only_mode

                        rem Do convert if a sidecar exists but no TXT file exists, and we’re NOT in genius-download-only mode:
                                iff exist "%SRT_SIDECAR_FILENAME%" then                
                                        call warning_soft "%italics_on%SRT%italics_off% exists...but no lyrics: ‘%italics_on%%LRC_SIDECAR_FILENAME%%italics_off’%"
                                        call less_important "Converting SRT file to TXT"
                                        call srt2txt.bat "%SRT_SIDECAR_FILENAME%" silent
                                        if not defined tmpfile call set-tmp-file "postprocessed lyrics"
                                        lyric-postprocessor.pl -A -L -S  "%TXT_SIDECAR_FILENAME%"  >:u8 %tmpfile%
                                        *copy /q /Ns "%tmpfile%"             "%TXT_SIDECAR_FILENAME%"  >nul
                                        unset /q LYRIC_STATUS
                                        set JUST_GENERATED_LYRICS=1
                                        set JUST_CONVERTED_SRT_TO_TEXT=1
                                        set JUST_CONVERTED_FROM=srt
                                        rem goto /i :Check_Again
                                endiff
                                iff exist "%LRC_SIDECAR_FILENAME%" .and. "1" != "%JUST_CONVERTED_LRC_TO_TEXT%" then
                                        call warning_soft "%italics_on%LRC%italics_off% exists...but no lyrics: ‘%italics_on%%LRC_SIDECAR_FILENAME%%italics_off’%"
                                        call warning_soft "Converting %italics_on%LRC%italics_off% file to %italics_on%TXT%italics_off%: ‘%italics_on%%TXT_SIDECAR_FILENAME%%italics_off’%"
                                        rem  LRC to TXT conversion is trivial enough to handle with cut.exe:
                                        call lrc2txt.bat "%LRC_SIDECAR_FILENAME%" silent
                                        unset /q LYRIC_STATUS
                                        set JUST_GENERATED_LYRICS=1
                                        set JUST_CONVERTED_LRC_TO_TEXT=1
                                        set JUST_CONVERTED_FROM=lrc
                                        rem goto /i :Check_Again
                                endiff
                        rem Review it! We auto-approved tons of these and left a horrible mess for ourselves by not adding this review step in til 2025/04/02
                                rem pause  set JUST_GENERATED_LYRICS=“%JUST_GENERATED_LYRICS%” ... TXT_SIDECAR_FILENAME=“%TXT_SIDECAR_FILENAME%”
                                if "1" != "%JUST_GENERATED_LYRICS%" goto /i endif_903
                                        set tmpmsg1=%@RAINBOW[Freshly generated from]
                                        set tmpmsg2=%italics_on%
                                        set tmpmsg3=%@RAINBOW[%JUST_CONVERTED_FROM%]
                                        set tmpmsg4=%italics_off%
                                        set tmpmsg5=%@RAINBOW[ file!]
                                        call bigecho "🧁 %tmpmsg1%%tmpmsg2%%tmpmsg3%%tmpmsg4% %tmpmsg5% 🧁" 
                                        if exist "%TXT_SIDECAR_FILENAME%" call review-files -wh "%TXT_SIDECAR_FILENAME%"
                                        :Ask_Again_845
                                        unset /q ANSWER hold_answer
                                        if not defined LONGEST_POSSIBLE_HAND_EDIT_TIME_IN_SECONDS set LONGEST_POSSIBLE_HAND_EDIT_TIME_IN_SECONDS=800
                                        call AskYn "Are these lyrics%dash%%blink_on%converted from %italics_on%%just_converted_from%%italics_off%%blink_off%%dash%acceptible" No %LONGEST_POSSIBLE_HAND_EDIT_TIME_IN_SECONDS% ADHILOPQ A:approve_the_lyrics,D:delete_sidecars,I:mark_instrumental,L:mark_lyriclessness,O:dOwnload_new_lyrics,Q:enQueue_in_winamp,P:play_file,H:hand-edit
                                        rem Preserve answer in case any subroutines call AskYN and re-set it:
                                                set OUR_LAST_ANSWER_HERE=%ANSWER%
                                        rem On “N”:
                                                iff "%OUR_LAST_ANSWER_HERE%" == "N" then                               
                                                        if exist "%LYRIC_FILE%" (*ren  /Ns /q "%LYRIC_FILE%" "%LYRIC_FILE%.%_datetime.rejected-after-conversion-from-%just_converted_from%.bak")                                                
                                                endiff
                                        rem On “Y”/“A”/“D”/“I”/“L”/“P”/“Q”:
                                                gosub check_for_answer_of_Q "%@UNQUOTE[%AUDIO_FILE%]"
                                                gosub check_for_answer_of_P "%@UNQUOTE[%AUDIO_FILE%]"
                                                if "P" == "%OUR_LAST_ANSWER_HERE%" goto /i Ask_Again_845
                                                if "E" == "%OUR_LAST_ANSWER_HERE%" goto /i Ask_Again_845
                                                if "Q" == "%OUR_LAST_ANSWER_HERE%" goto /i Ask_Again_845
                                                gosub check_for_answer_of_A Y
                                                gosub check_for_answer_of_D
                                                gosub check_for_answer_of_H
                                                gosub check_for_answer_of_I "%@UNQUOTE[%AUDIO_FILE%]"
                                                gosub check_for_answer_of_L
                                        rem Finishings for “I”, “L”, “O”:
                                                if  "I" == "%OUR_LAST_ANSWER_HERE%"   goto /i END_OF_GET_LYRICS
                                                if  "L" == "%OUR_LAST_ANSWER_HERE%"   goto /i END_OF_GET_LYRICS
                                                if  "O" == "%OUR_LAST_ANSWER_HERE%"   goto /i download_with_lyric_downloader_init
                                :endif_903

                        :do_not_convert_if_in_genius_only_mode       
        :goto_endpoint_830


rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

rem Branch off for Quick LRC mode:
        iff "1" == "%QUICK_LRC_MODE%" then
                set CURRENT_LYRIC_PROVIDER=SyncedLyrics
                rem Unnecessary here: gosub refresh_current_lyric_provider_metadatas
                goto /i download_with_lyric_downloader_init
        endiff

rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━


rem Check if we already have approved lyrics in the same folder:

        :check_lyric_file_begin                
        rem echo - DEBUG:  wondering if things went south yet [16]
        iff exist "%LYRIC_FILE%" .and. %@FILESIZE["%LYRIC_FILE%"] gt 0 .and. "1" != "%FORCE_REGEN_LYRICS%"  .and. "1" != "%QUICK_LRC_MODE%" then
                rem Get lyric pre-approval status
                        rem if  "%LYRIC_STATUS%" == "" call get-lyric-status "%LYRIC_FILE%" silent
                        if  "%LYRIC_STATUS%" == "" gosub refresh_lyric_status       
                        iff "%LYRIC_STATUS%" == "APPROVED" then 
                                gosub divider
                                call success "Lyrics are already approved!"
                                set LYRICS_ACCEPTABLE=1
                                set LYRIC_ACCEPTANCE_PROMPT_TO_USE=yes
                                if not defined LYRIC_ACCEPTABILITY_REVIEW_WAIT_TIME_AUTO set LYRIC_ACCEPTABILITY_REVIEW_WAIT_TIME_AUTO=4
                                set LYRIC_ACCEPTABILITY_REVIEW_WAIT_TIME_TO_USE=%LYRIC_ACCEPTABILITY_REVIEW_WAIT_TIME_AUTO%
                                set HAND_EDIT_ARTIST_AND_SONG_AND_LYRICS_PROMPT_WAIT_TIME=%LYRIC_ACCEPTABILITY_REVIEW_WAIT_TIME_AUTO%
                                rem set GOTO_END=1
                                goto /i END_OF_GET_LYRICS
                        elseiff "1" == "%FORCE_REGEN_LYRICS" then 
                                set LYRIC_ACCEPTABILITY_REVIEW_WAIT_TIME=%LYRIC_ACCEPTABILITY_REVIEW_WAIT_TIME_FOR_FORCE_REGEN%
                        else                        
                                set LYRICS_ACCEPTABLE=0
                                set LYRIC_ACCEPTANCE_PROMPT_TO_USE=%DEFAULT_LYRIC_ACCEPTANCE_PROMPT_1%
                                set LYRIC_ACCEPTABILITY_REVIEW_WAIT_TIME_TO_USE=%LYRIC_ACCEPTABILITY_REVIEW_WAIT_TIME%
                                set HAND_EDIT_ARTIST_AND_SONG_AND_LYRICS_PROMPT_WAIT_TIME=%HAND_EDIT_ARTIST_AND_SONG_AND_LYRICS_PROMPT_WAIT_TIME%
                        endiff                   
                        if "1" == "%GOTO_END%" goto /i END_OF_GET_LYRICS

                rem Display lyrics:
                        iff not exist "%LYRIC_FILE%" then
                                call warning "LYRICS DO NOT EXIST: %LYRIC_FILE%"
                        else
                                gosub create_or_set_postprocessed_lyrics "%LYRIC_FILE%"
                                if "1" == "%SHOW_UNPROCESSED_LYRICS_ALSO%" call review-file   -wh  -st    "%LYRIC_FILE%"           "%underline_on%Current lyrics%underline_off% (not processed)"
                                                                           call review-file   -wh  -stU   "%postprocessed_lyrics%" "%underline_on%Current lyrics%underline_off% (processed)"
                        endiff

                        echos %@ANSI_CURSOR_CHANGE_COLOR_WORD[purple]%ANSI_CURSOR_CHANGE_TO_BLOCK_BLINKING%   
                        @gosub divider

                rem Get lyric approval status:
                        rem No let’s not do this yet! unset /q  lyric_status
                        rem %LYRIC_STATUS%" == "" call      get-lyric-status "%LYRIC_FILE%" silent
                        if "%LYRIC_STATUS%" == "" gosub refresh_lyric_status
                        iff    "%lyric_status%" == "APPROVED" then
                                set LYRICS_ACCEPTABLE=1
                                set LYRICS_FOUND_TO_HAVE_BEEN_PREAPPROVED=1
                                goto /i have_acceptable_lyrics_now_or_at_the_very_least_are_done
                        else                                
                                set LYRICS_FOUND_TO_HAVE_BEEN_PREAPPROVED=0
                        endiff

                rem Get original Genius JSON-file download name, which we store as an ADS tag attached the downloaded lyricfile:
                        set   PREVIOUS_GENIUS_FILENAME=%@ExecStr[type <"%@UNQUOTE["%AUDIO_FILE%"]:genius_filename" >&>nul]`` 

                rem Display the filename again in case the lyrics were so long / text zoomed in so large / columns so wide print_with_columns couldn’t fit it on the screen such that it scrolled off and we lost track of what song we are even looking at, and need to be reminded
                        iff "%PREVIOUS_GENIUS_FILENAME%" !=  "" then
                                rem Massage audiofile / geniusfilename / artistname: Step 1: capture original variables, strip out spaces, hyphens, leading The
                                        *setdos /x-8-5
                                        set  PREV_GENIUS_FNAME_2_USE=%@UNQUOTE[%%@REPLACE[',,%@REPLACE[-,,%@REPLACE[ ,,"%PREVIOUS_GENIUS_FILENAME%"]]]]
                                        set    ARTIST_NAME_SCRUNCHED=%@UNQUOTE[%%@REPLACE[',,%@REPLACE[ ,,%@REPLACE[ ,,"%FILE_ARTIST%"]]]]
                                        set    AUDIO_FILE_TO_DISPLAY=%@UNQUOTE[%%@REPLACE[',,%@REPLACE[-,,%@REPLACE[ ,,"%AUDIO_FILE%"]]]]
                                        if   "%AUDIO_FILE_TO_DISPLAY%" != "" if "1" != "%@Regex[^[Tt][Hh][Ee][Yy],%AUDIO_FILE_TO_DISPLAY%]"   set   AUDIO_FILE_TO_DISPLAY=%@UNQUOTE[%%@ReReplace[^[Tt][Hh][Ee],,"%AUDIO_FILE_TO_DISPLAY%"]]
                                        if "%PREV_GENIUS_FNAME_2_USE%" != "" if "1" != "%@Regex[^[Tt][Hh][Ee][Yy],%PREV_GENIUS_FNAME_2_USE%]" set PREV_GENIUS_FNAME_2_USE=%@UNQUOTE[%%@ReReplace[^[Tt][Hh][Ee],,"%PREV_GENIUS_FNAME_2_USE%"]]

                                        rem Take “The ” of artist name:                                                                                                                                                               
                                                rem echo %ANSI_COLOR_DEBUG%- DEBUG: ARTIST_NAME_SCRUNCHED=“%ARTIST_NAME_SCRUNCHED%”, FILE_ARTIST=“%FILE_ARTIST%” which if it’s empty would explain things
                                                set do_it=0
                                                if "" == "%ARTIST_NAME_SCRUNCHED%" goto /i nevermind_1023
                                                if "1" != "%@Regex[^[Tt][Hh][Ee][Yy],%ARTIST_NAME_SCRUNCHED%]"   set do_it=1
                                                :decision_made_1017
                                                if "0" == "%do_it%" goto /i nevermind_1023
                                                if "1" == "%do_it%" set ARTIST_NAME_SCRUNCHED=%@UNQUOTE[%%@ReReplace[^[Tt][Hh][Ee],,"%ARTIST_NAME_SCRUNCHED%"]]
                                                :nevermind_1023 
                                                setdos /x0                   

                                rem Massage audiofile / geniusfilename / artistname: Step 2: strip the “01_” from filenames like “01_track.mp3”
                                        set AUDIO_FILE_TO_DISPLAY_NAME=%@ReReplace[[0-9]+_,,%@UNQUOTE[%@NAME["%AUDIO_FILE_TO_DISPLAY%"]]]

                                rem Massage audiofile / geniusfilename / artistname: Step 3: get initial lengths:
                                        set      ARTIST_NAME_SCRUNCHED_LENGTH=%@LEN[%ARTIST_NAME_SCRUNCHED%]
                                        set      AUDIO_FILE_TO_DISPLAY_LENGTH=%@LEN[%AUDIO_FILE_TO_DISPLAY%]
                                        set AUDIO_FILE_TO_DISPLAY_NAME_LENGTH=%@LEN[%AUDIO_FILE_TO_DISPLAY_NAME%]
                                        set            FILENAME_GENIUS_LENGTH=%@LEN["%PREV_GENIUS_FNAME_2_USE%"]  %+ rem ...and this instaed

                                rem Massage audiofile / geniusfilename / artistname: Step 4: genereate spacers
                                        set tmpSpacer=%@REPEAT[ ,%@EVAL[%ARTIST_NAME_SCRUNCHED_LENGTH]]``
                                        set TMPSPACER_LENGTH=%@LEN[%tmpspacer%]

                                rem Massage audiofile / geniusfilename / artistname: Step 5: calculate additional lengths
                                        set AUDIO_FILE_DISPLAY_LENGTH_WITH_SPACER=%@EVAL[%ARTIST_NAME_SCRUNCHED_LENGTH% + 0 + %AUDIO_FILE_TO_DISPLAY_NAME_LENGTH%] %+ rem 0 used to be 1 used to be 2 

                                rem Massage audiofile / geniusfilename / artistname: Step 6: kill the spacer if both start with the same 5 letters because spacer is not needed if they already line up:
                                        iff "%@LEFT[5,"%AUDIO_FILE_TO_DISPLAY_NAME%"]" == "%@LEFT[5,"%PREVIOUS_GENIUS_FILENAME%"]" then
                                                set tmpSpacer=``
                                                set tmpSpacer_length=0
                                        endiff

                                rem Massage audiofile / geniusfilename / artistname: Step 7: kill the spacer if the ARTIST_NAME_SCRUNCHED isn’t even in the PREVIOUS_GENIUS_FILENAME because what are we even alingning at that point?
                                        if "" != "%ARTIST_NAME_SCRUNCHED%" set LAST_ALIGNMENT_TEMP_INDEX=%@INDEX[%PREVIOUS_GENIUS_FILENAME%,%ARTIST_NAME_SCRUNCHED%]
                                        iff "%LAST_ALIGNMENT_TEMP_INDEX%" == "-1" then
                                                set tmpSpacer=``
                                                set tmpSpacer_length=0
                                        endiff

                                rem Massage audiofile / geniusfilename / artistname: Step 8: Determine which line is longest:
                                        set LENGTHIEST=%@MAX[%FILENAME_GENIUS_LENGTH%,%@EVAL[%AUDIO_FILE_TO_DISPLAY_NAME_LENGTH%+%tmpSpacer_length%]]

                                rem Massage audiofile / geniusfilename / artistname: Step 9: Calculate the column where our message will be displayed:
                                        set MAGIC_COLUMN=%@EVAL[%LENGTHIEST% + 23] 

                                rem Massage audiofile / geniusfilename / artistname: DEBUG INFO
                                        echo  LENGTHIEST=“%lengthiest%” // FILENAME_GENIUS_LENGTH=“%FILENAME_GENIUS_LENGTH%”(%PREVIOUS_GENIUS_FILENAME%) // AUDIO_FILE_DISPLAY_LENGTH_WITH_SPACER=“%AUDIO_FILE_DISPLAY_LENGTH_WITH_SPACER%”(%%) ///// AUDIO_FILE_TO_DISPLAY_NAME_LENGTH=“%AUDIO_FILE_TO_DISPLAY_NAME_LENGTH%”(%AUDIO_FILE_TO_DISPLAY_NAME%) and @LEN[tmpspacer]=“%@LEN[%tmpspacer]” ... so MAGIC_COLUMN=“%MAGIC_COLUMN%” // 😎 ARTIST_NAME_SCRUNCHED_LENGTH=“%ARTIST_NAME_SCRUNCHED_LENGTH%”(%ARTIST_NAME_SCRUNCHED%)

                                rem Massage audiofile / geniusfilename / artistname: Step 10: Set variable to ANSi code to move us to the proper column and set our message color:
                                        set MOVEITMOVEIT=%@ANSI_MOVE_TO_COL[%MAGIC_COLUMN%]%ansi_color_bright_yellow%
                        else
                                unset /q MOVEITMOVEIT
                                set AUDIO_FILE_TO_DISPLAY=%AUDIO_FILE%
                                set AUDIO_FILE_TO_DISPLAY_NAME=%@NAME["%AUDIO_FILE_TO_DISPLAY%"]
                        endiff


                rem Display line #1: the directory:
                        gosub DisplayAudioDirectory "%@UNQUOTE[%AUDIO_FILE%]"

                rem Display line #1.5: the audio filename without processing
                         IF "%PREVIOUS_GENIUS_FILENAME%" !=  "" echo %ansi_color_prompt%%star% %ansi_color_bright_yellow%Syst%@IF["%PREVIOUS_GENIUS_FILENAME%" !=  "",e,]m filename%ansi_color_yellow%: %ansi_color_pink%%@IF["%PREVIOUS_GENIUS_FILENAME%" !=  "",%tmpSpacer%,]%blink_off%“%blink_off%%ansi_color_green%%ansi_color_pink%%italics_on%%AUDIO_FILE%%blink_off%%italics_off%%ansi_color_prompt%”


                rem TODO?: is it always the top one that’s shorter? 
                           rem because the bottom one has the band name, yes.  
                           rem so we could use %@INDEX to find the index of the 1ˢᵗ 5 chars of the audio fileename within the genius filename
                           rem and then make the spacer that way


                rem Display line #2: the audiofile filename
                        rem   %ansi_color_prompt%%star% %ansi_color_bright_yellow%Audio %@IF["%PREVIOUS_GENIUS_FILENAME%" !=  "", ,]filename%ansi_color_yellow%:%ansi_color_prompt% %@IF["%PREVIOUS_GENIUS_FILENAME%" !=  "",%tmpSpacer%,]“%italics_on%%blink_off%%ansi_color_green%%AUDIO_FILE_TO_DISPLAY_NAME%%blink_off%%italics_off%%ansi_color_prompt%”  [old legacy line] with one less space after the colon
                        echos %ansi_color_prompt%%star% %ansi_color_bright_yellow%Audio %@IF["%PREVIOUS_GENIUS_FILENAME%" !=  "", ,]filename%ansi_color_yellow%: %ansi_color_prompt%%@IF["%PREVIOUS_GENIUS_FILENAME%" !=  "",%tmpSpacer%,]%blink_off%“%blink_off%%ansi_color_BRIGHT_green%%italics_on%%AUDIO_FILE_TO_DISPLAY_NAME%%blink_off%%italics_off%%ansi_color_prompt%”


                rem Display line #3: the Genius JSON-file download name, if one was previously fetched:
                        iff "%PREVIOUS_GENIUS_FILENAME%" !=  "" .and. "%PREV_GENIUS_FNAME_2_USE%" != "ECHOisOFF" then
                                echos %MOVEITMOVEIT%%@CHAR[10229]   %blink_on%Are these more%blink_off%
                                echo.
                                echos %ansi_color_prompt%%star% %ansi_color_bright_yellow%%ansi_color_orange%Genius %ansi_color_bright_yellow%filename%ansi_color_yellow%:%ansi_color_prompt% “%italics_on%%blink_off%%ansi_color_BRIGHT_green%%PREV_GENIUS_FNAME_2_USE%%ansi_color_prompt%%blink_off%%italics_off%”
                                echos %MOVEITMOVEIT%%@CHAR[10229]  %blink_on%or less the same%blink_off%?
                        endiff
                        echo.

                rem %ansi_color_prompt%%star% %ansi_color_bright_yellow%Audio %@IF["%PREVIOUS_GENIUS_FILENAME%" !=  "", ,]filename%ansi_color_yellow%:%ansi_color_prompt% %@IF["%PREVIOUS_GENIUS_FILENAME%" !=  "",%tmpSpacer%,]“%italics_on%%blink_off%%ansi_color_green%%AUDIO_FILE_TO_DISPLAY_NAME%%blink_off%%italics_off%%ansi_color_prompt%”  [old legacy line] with 1 less spc after :


        :ask_if_the_lyrics_are_good

                rem Ask if the lyrics are good:
                        rem Default answer is different depending on the situation:
                                iff "1" == "%s%" .or. "1" == "%FORCE_REGEN_LYRICS%" then
                                        set LYRIC_ACCEPTANCE_PROMPT_TO_USE=yes
                                        set LYRIC_ACCEPTABILITY_REVIEW_WAIT_TIME_TO_USE=%LYRIC_ACCEPTABILITY_REVIEW_WAIT_TIME_FOR_FORCE_REGEN%
                                        unset /q LYRICS_SHOULD_BE_CONSIDERED_ACCEPTIBLE
                                else
                                        set LYRIC_ACCEPTANCE_PROMPT_TO_USE=no
                                endiff
                        rem Ask the actual question:
                                :Ask_Again_p_972
                                if "1" == "%JUST_GENERATED_LYRICS%" (call bigecho "%ansi_color_bright_yellow%%star2% Fresh TXT file converted from SRT/LRC%ansi_color_normal%" %+ set LYRIC_ACCEPTANCE_PROMPT_TO_USE=no)  %+ rem was Yes but incorrect LRC downloads would then create incorrectly-accepted lyrics so this did not play out as the right decision 
                                echo %emoji_red_question_mark%%ANSI_COLOR_PROMPT%%EMOJI_QUESTION_MARK% We %italics_on%already have%italics_off% these. Are they acceptable?
                                unset /q ANSWER HOLD_ANSWER
                                call AskYn "Acceptable?%conceal_on%1%conceal_off%[%ANSI_COLOR_bright_green%H%ANSI_COLOR_PROMPT%%connecting_equals%Yes+%ansi_color_bright_green%h%ansi_color_prompt%and-edit,%ANSI_COLOR_bright_green%P%ansi_color_prompt%lay,%ANSI_COLOR_bright_green%G%ANSI_COLOR_PROMPT%oogle,%ansi_color_bright_green%L%ansi_color_prompt%yricless(%ansi_color_green%Z%ansi_color_prompt%%connecting_equals%All),e%ansi_color_bright_green%D%ansi_color_prompt%it band/tit,d%ansi_color_bright_green%O%ansi_color_prompt%wnload,%ansi_color_bright_green%I%ansi_color_prompt%=inst(%ansi_color_bright_green%X%ansi_color_prompt%=All),rena%ansi_color_bright_green%M%ansi_color_prompt%e,s%ansi_color_bright_green%K%ansi_color_prompt%ip file]" %LYRIC_ACCEPTANCE_PROMPT_TO_USE%  %LYRIC_ACCEPTABILITY_REVIEW_WAIT_TIME_TO_USE% DGHILMOPQSKFXZ H:Yes_but_hand-edit_them_first,L:Mark_as_lyricless!!,Z:Mark_everything_here_as_lyricless,Q:enQueue_in_winamp,P:Play_file_it_and_see,G:Google_for_better,D:eDit_the_artist/song_instead,O:dOwnload_new_lyrics_nOw,I:mark_instrumental,X:mark_all_as_insturmentals,M:rename,K:skip_this_folder,F:fail_this_file
                                set HOLD_ANSWER=%ANSWER%

                        rem Deal with our answer:
                                gosub check_for_answer_of_M "%@UNQUOTE[%AUDIO_FILE%]"
                                set ANSWER=%HOLD_ANSWER%

                                gosub check_for_answer_of_P "%@UNQUOTE[%AUDIO_FILE%]"
                                set ANSWER=%HOLD_ANSWER%

                                gosub check_for_answer_of_Q "%@UNQUOTE[%AUDIO_FILE%]"
                                set ANSWER=%HOLD_ANSWER%

                                gosub check_for_answer_of_H
                                set ANSWER=%HOLD_ANSWER%

                                rem rem gosub check_for_answer_of_F
                                set ANSWER=%HOLD_ANSWER%

                                if "F" == "%HOLD_ANSWER%" goto /i end_quick_lrc_mode_fail
                                if "P" == "%HOLD_ANSWER%" goto /i Ask_Again_p_972
                                if "Q" == "%HOLD_ANSWER%" goto /i Ask_Again_p_972
                                if "M" == "%HOLD_ANSWER%" goto /i Ask_Again_p_972
                                if "S" == "%HOLD_ANSWER%" (call important_less "Skipping" %+ goto /i END_OF_GET_LYRICS)
                                
                                if "%HOLD_ANSWER%" == "O" .or. "1" == "%goto_download_with_lyric_downloader_1%" goto /i download_with_lyric_downloader_init

                                gosub check_for_answer_of_D_to_eset_artist_and_song
                                if "D" == "%HOLD_ANSWER%" goto /i download_with_lyric_downloader_init
                                gosub check_for_answer_of_G 
                                if  "1" == "%GOOGLE_NOW%" goto /i Google_Now
                                iff "Y" == "%HOLD_ANSWER%" then
                                        set LYRICS_APPROVED=1
                                else
                                        set ANSWER=%HOLD_ANSWER%
                                        gosub check_for_answer_of_I "%@UNQUOTE[%AUDIO_FILE%]"
                                        gosub check_for_answer_of_L
                                        if "1" == "%GOTO_END%" (goto /i END_OF_GET_LYRICS)
                                        goto /i have_acceptable_lyrics_now_or_at_the_very_least_are_done
                                endiff
                                if "P" == "%HOLD_ANSWER%" (goto /i Ask_Again_p_927)
                                if "I" == "%HOLD_ANSWER%" (goto /i END_OF_GET_LYRICS)
                                if "X" == "%HOLD_ANSWER%" (goto /i END_OF_GET_LYRICS)
                                if "1" == "%GOTO_END%"    (goto /i END_OF_GET_LYRICS)
                                
                rem Since the question we just asked included option to hand-edit, let’s suppress asking that question later:
                        set  DO_NOT_ASK_TO_HAND_EDIT=1
                        echo FORCE_HAND_EDIT=%FORCE_HAND_EDIT% trace 2 >nul 
                        set  FORCE_HAND_EDIT=0
                        
                rem If the lyrics are good, set them as so. if they are not, warn:                        
                        set ANSWER=%HOLD_ANSWER%
                        iff "%ANSWER%" == "Y" .or. "%ANSWER%" == "H" then                        
                                rem if "%LYRIC_STATUS%" == "" call get-lyric-status "%LYRIC_FILE%" silent
                                if "%LYRIC_STATUS%" == "" gosub refresh_lyric_status
                                echo %check% %ansi_color_success%₁Approving lyrics...%ansi_color_normal% %conceal_on%DEF%conceal_off%
                                iff "%LYRIC_STATUS%" != "APPROVED" then
                                        set JUST_APPROVED_LYRICS=1
                                        call  approve-lyrics "%LYRIC_FILE%" >nul
                                        gosub approve_lyrics_done
                                endiff                                        
                                set JUST_APPROVED_LYRICS=1
                                set LYRICS_ACCEPTABLE=1
                                set ANSWER=%HOLD_ANSWER%
                                iff "%ANSWER%" != "H" then
                                        set  DO_NOT_ASK_TO_HAND_EDIT=1
                                        echo FORCE_HAND_EDIT=%FORCE_HAND_EDIT% trace 3 >nul 
                                        set  FORCE_HAND_EDIT=0
                                endiff
                                iff "%ANSWER%" == "H" then
                                        set DO_NOT_ASK_TO_HAND_EDIT=0
                                        rem gosub debug "Setting FORCE_HAND_EDIT=1 .... instance #2 ... answer=“%ANSWER%”"
                                        set  FORCE_HAND_EDIT=1
                                        echo FORCE_HAND_EDIT=%FORCE_HAND_EDIT% trace 4 >nul 
                                else
                                        goto /i have_acceptable_lyrics_now_or_at_the_very_least_are_done
                                endiff                                        
                        else
                                set LYRICS_ACCEPTABLE=0
                                echo %ansi_color_warning_soft%%star% Not using them...%ansi_color_normal%
                                iff exist "%LYRIC_FILE%" then
                                        unset /q ANSWER hold_answer
                                        call AskYN "Remove lyric file" yes 0 A A:approve_it
                                        
                                        iff "Y" == "%ANSWER%" then
                                                set rejected_original_lyrics=%LYRIC_FILE%.%_DATETIME.rejected.bak 
                                                *ren /Ns /q  "%LYRIC_FILE%" "%REJECTED_ORIGINAL_LYRICS%"
                                        else
                                                if "N" == "%ANSWER%" goto /i check_lyric_file_begin
                                        endiff
                                endiff
                                if  exist "%SRT_SIDECAR_FILENAME%" (unset /q answer %+ call AskYN "Remove SRT file" yes 0 %+ if "Y" == "%ANSWER%" *ren  /Ns /q "%SRT_SIDECAR_FILENAME%" "%SRT_SIDECAR_FILENAME%.%_DATETIME.rejected.bak")
                                if  exist "%LRC_SIDECAR_FILENAME%" (unset /q answer %+ call AskYN "Remove LRC file" yes 0 %+ if "Y" == "%ANSWER%" *ren  /Ns /q "%LRC_SIDECAR_FILENAME%" "%LRC_SIDECAR_FILENAME%.%_DATETIME.rejected.bak")

                                rem gosub divider
                                goto /i End_Of_Check_To_See_If_We_Already_Had_Them
                        endiff                     
                        rem DEBUG:
                        echo 🍕🍕  problematic answer is “%[answer]” achieved force_hand_edit value of “%force_hand_edit%” GOAT
                        if "%ANSWER%" == "H" gosub edit_lyrics_now_if_we_answered_H H

        endiff
        :End_Of_Check_To_See_If_We_Already_Had_Them
        if %vebose gt 0 call unimportant ":End_Of_Check_To_See_If_We_Already_Had_Them" 
        if "1" == "%GOTO_END%" (goto /i END_OF_GET_LYRICS)
rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━




rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
rem ━━━━━━━━━━━━━━━━━━━━━━━ CHECKING IN OLD MINILYRICS/EVILLYRICS REPOSITORY STUFF BEGINS HERE ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
:actual_alignment_begins
:repo_stuffs_begin
rem echo - DEBUG:  wondering if things went south yet [32]




rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
rem Check if we have one in our lyric repository already, via 2 different filenames, and then manual selection:
        :check_local_lyric_repository
        unset /q already_tried_potential_lyrics_* 
        unset /q last_maybe_lyrics* %+ rem added 20260421

        call subtle "Checking local lyric repository"
        if "%MAYBE_LYRICS_1%" == "%LAST_MAYBE_LYRICS_1%" goto /i MaybeLyrics1_END
        set LAST_MAYBE_LYRICS_1=%MAYBE_LYRICS_1%
        iff "1" != "%LYRICS_ACCEPTABLE%" .and. exist "%MAYBE_LYRICS_1%" .and. %@FILESIZE["%MAYBE_LYRICS_1%"] gt 0 .and. "1" != %GENIUS_ONLY% then
                set PROCESS_MAYBE_1=1
        else
                set PROCESS_MAYBE_1=0
        endiff

        rem iff "1" == "%LYRICS_ACCEPTABLE%" .and. exist "%MAYBE_LYRICS_1%" .and. %@FILESIZE["%MAYBE_LYRICS_1%"] gt 0 .and. "1" != %GENIUS_ONLY% then
        if "1" != "%PROCESS_MAYBE_1%" goto /i endiff_991
                @gosub divider
                rem “Found possible lyrics”
                @call less_important "Found %italics_on%possible%italics_off% lyrics (type 1) at %emphasis%%maybe_lyrics_1%%deemphasis%!%conceal_on%3838%conceal_off%"
                @call less_important "Let’s review them..."
                rem @gosub divider
                rem @call bigecho %ANSI_COLOR_IMPORTANT_LESS%%star% %underscore_on%Let’s review:%underscore_off%%ANSI_RESET%
                rem (type "%MAYBE_LYRICS_1%" |:u8 unique-lines -A -L) |:u8 print-with-columns
                call review-file -wh "%MAYBE_LYRICS_1%" 
                echos %@ANSI_CURSOR_CHANGE_COLOR_WORD[bright cyan]%ANSI_CURSOR_CHANGE_TO_BLOCK_BLINKING%   
                gosub divider
                rem echo displayaudiofilename 02
                gosub DisplayAudioFileName %AUDIO_FILE%
                :Ask_Again_p_12
                unset /q ANSWER hold_answer
                call AskYn "These good? (e%ansi_color_bright_green%D%ansi_color_prompt%it band/song,%ansi_color_bright_green%P%ansi_color_prompt%lay,%ansi_color_bright_green%H%ansi_color_prompt%and-edit,%ansi_color_bright_green%L%ansi_color_prompt%yric give-up(%ansi_color_bright_green%Z%ansi_color_prompt%=all),I=%ansi_color_bright_green%I%ansi_color_prompt%nstr(%ansi_color_bright_green%X%ansi_color_prompt%=All),delet%ansi_color_bright_green%T%ansi_color_prompt%e)" %DEFAULT_LYRIC_ACCEPTANCE_PROMPT_1%  %LYRIC_ACCEPTABILITY_REVIEW_WAIT_TIME% DHILOPQXZT H:Yes_but_hand_edit_first,L:No!_Marking_as_lyricless,I:Mark_the_track_as_an_instrumental_track,Q:enQueue_in_winamp,P:Play_theeee_file,Z:mark_all_songs_in_folder_as_lyricless,D:edit_artist/song_name,O:dOwnload_lyrics_nOw,X:mark_all_as_instrumental,T:deleTe_them!
                        set SAVED_ANSWER=%ANSWER%
                        set SAVED_ANSWER_THESE_GOOD=%ANSWER%
                        iff "N" == "%SAVED_ANSWER_THESE_GOOD%" then
                                call AskYN "Delete from lyric repo so we don’t run into this again" yes 30
                                        iff "Y" == "%ANSWER%" then
                                                echos %Ansi_color_removal%%emoji_axe% Deleting: ``
                                                gosub delete_file "%MAYBE_LYRICS_1"
                                                goto /i check_local_lyric_repository
                                                goto /i MaybeLyrics2
                                        endiff
                        endiff
                        iff "T" == "%SAVED_ANSWER_THESE_GOOD%" then
                                echos %Ansi_color_removal%%emoji_axe% Deleting: ``
                                *del /q /Ns "%MAYBE_LYRICS_1"
                                goto /i check_local_lyric_repository
                                goto /i MaybeLyrics2
                        endiff
                        rem NO! We’re not using our subroutine here, for reasons: gosub check_for_answer_of_H
                        iff "Y" == "%SAVED_ANSWER_THESE_GOOD%" .or. "H" == "%SAVED_ANSWER_THESE_GOOD%" then
                                echos %ansi_color_success% %check% ``
                                echo yr | *copy /Ns "%MAYBE_LYRICS_1%" "%LYRIC_FILE%
                                echos %ansi_color_normal%
                                set COPIED_REPO_LYRIC=%MAYBE_LYRICS_1%
                                set LYRICS_SHOULD_BE_CONSIDERED_ACCEPTIBLE=1

                                iff "H" == "%SAVED_ANSWER_THESE_GOOD%" then
                                        rem gosub check_for_answer_of_E "%@UNQUOTE["%LYRIC_FILE%"]"
                                        %EDITOR% %LYRIC_FILE%
                                        pause "Hit any key when done editing lyric file"
                                endiff

                                goto /i :have_acceptable_lyrics_now_or_at_the_very_least_are_done
                        endiff
                        if "O" == "%SAVED_ANSWER_THESE_GOOD%" .or. "1" == "%goto_download_with_lyric_downloader_1%" goto download_with_lyric_downloader_init

                        gosub check_for_answer_of_D_to_eset_artist_and_song

                        gosub check_for_answer_of_P "%@UNQUOTE[%AUDIO_FILE%]"
                        if  "P" == "%SAVED_ANSWER_THESE_GOOD%"   goto /i Ask_Again_p_12

                        gosub check_for_answer_of_Q "%@UNQUOTE[%AUDIO_FILE%]"
                        if  "Q" == "%SAVED_ANSWER_THESE_GOOD%"   goto /i Ask_Again_p_12


                        gosub check_for_answer_of_L
                        if  "L" == "%SAVED_ANSWER_THESE_GOOD%"   goto /i END_OF_GET_LYRICS

                        gosub check_for_answer_of_I "%@UNQUOTE[%AUDIO_FILE%]"
                        if "1" == "%GOTO_END%" goto /i END_OF_GET_LYRICS
        :endiff_991

        if  "1" == "%goto_END%"          goto /i END_OF_GET_LYRICS
        if  "1" == "%ABANDONED_SEARCH%"  goto /i END_OF_GET_LYRICS
        if  "L" == "%ANSWER%"            goto /i END_OF_GET_LYRICS
        if  "P" == "%ANSWER%"            goto /i Ask_Again_p_12
        if  "1" == "%goto_download_with_lyric_downloader_1%" goto download_with_lyric_downloader_init


        iff "1" == "%PROCESS_MAYBE_1%" .and. exist "%LYRIC_FILE%" then
                unset /q ANSWER hold_answer
                if "%SAVED_ANSWER_THESE_GOOD%" != "Y" call AskYn "%conceal_on%2%conceal_off%Do %italics_on%these%italics_off% look acceptable (%ansi_color_bright_green%H%ansi_color_prompt%=Yes+%ansi_color_bright_green%H%ansi_color_prompt%and-edit,%ansi_color_bright_green%L%ansi_color_prompt%=No! Give up/%ansi_color_bright_green%L%ansi_color_prompt%yriclessness)" %DEFAULT_LYRIC_ACCEPTANCE_PROMPT_1%  %LYRIC_ACCEPTABILITY_REVIEW_WAIT_TIME% HL H:Yes_but_hand_edit_it_first,L:No!_Marking_as_lyricless
                iff "%ANSWER%" == "Y" .or. "%ANSWER%" == "H" then
                        *copy /Ns "%MAYBE_LYRICS_1%" "%LYRIC_FILE%" 
                        set COPIED_REPO_LYRIC=%MAYBE_LYRICS_1%

                        iff not exist "%LYRIC_FILE%" then
                                call error "Well. This shouldn%apostrophe%t happen. #9334033440" 
                                beep 
                                pause 
                                call exit-maybe
                        endiff

                        iff exist "%LYRIC_FILE%" then
                                rem echo [1☁] about to call edit_lyrics_now_if_we_answered_H 🐐
                                if "%SAVED_ANSWER%" == "H" gosub edit_lyrics_now_if_we_answered_H H

                                set DO_NOT_ASK_TO_HAND_EDIT=1
                                set    JUST_APPROVED_LYRICS=1
                                set       LYRICS_ACCEPTABLE=1

                                call approve-lyrics "%LYRIC_FILE%"
                                set LYRICS_ACCEPTABLE=1
                                set LYRIC_STATUS=APPROVED
                                set LYRIC_STATUS=APPROVED
                        endiff

                        goto /i have_acceptable_lyrics_now_or_at_the_very_least_are_done
                else
                        set LYRICS_ACCEPTABLE=0
                        call warning_soft "Not using potential lyric file #1, then..."
                        goto /i MaybeLyrics2
                endiff
        endiff
        :MaybeLyrics1_END

        :MaybeLyrics2
        iff exist "%MAYBE_LYRICS_2%" .and. %@FILESIZE["%MAYBE_LYRICS_2%"] gt 0  .and. "1" != "%GENIUS_ONLY%" then
                set PROCESS_MAYBE_2=1
        else
                set PROCESS_MAYBE_2=0
        endiff
        iff "1" == "%PROCESS_MAYBE_2%" then
                rem “Found possible lyrics”
                call less_important "Found %italics_on%possible%italics_off% lyrics (type 2) at %emphasis%%maybe_lyrics_2%%emphasis%!%conceal_on%7272%conceal_off%"
                call less_important "Let’s review them:"
                rem gosub divider
                rem @call bigecho %ANSI_COLOR_IMPORTANT_LESS%Let’s review!%ANSI_RESET%
                rem (type "%MAYBE_LYRICS_2%" |:u8 unique-lines -A -L) |:u8 print-with-columns
                call review-file -wh "%MAYBE_LYRICS_2%" "%ANSI_COLOR_IMPORTANT_LESS%Let’s review!%ANSI_RESET%"
                echos %@ANSI_CURSOR_CHANGE_COLOR_WORD[bright cyan]%ANSI_CURSOR_CHANGE_TO_BLOCK_BLINKING%   
                gosub divider
                rem echo displayaudiofilename 03
                gosub DisplayAudioFileName %AUDIO_FILE%
                :ask_again_1297
                unset /q ANSWER hold_answer
                call AskYn "%conceal_on%3%conceal_off%Do these look acceptable [%ansi_color_bright_green%P%ansi_color_prompt%lay,%ansi_color_bright_green%H%ansi_color_prompt%and-edit,dele%ansi_color_bright_green%T%ansi_color_prompt%e these repo lyrics]" %DEFAULT_LYRIC_ACCEPTANCE_PROMPT_1%  %LYRIC_ACCEPTABILITY_REVIEW_WAIT_TIME% HPQT H:Yes_but_hand-edit_first,Q:enQueue_in_winamp,P:play,T:delete_crappy_repo_lyrics                                
                if  "%ANSWER%" == "T" gosub delete_file "%MAYBE_LYRICS_2%"
                iff "%ANSWER%" == "N" then
                        call AskYN "Delete from lyric repo so we don’t run into this again" yes 30
                                iff "Y" == "%ANSWER%" then
                                        rem echos %Ansi_color_removal%%emoji_axe% Deleting: ``
                                        if exist "%TMPREVIEWFILE%"     gosub delete_file "%TMPREVIEWFILE"  %+ rem Won’t exist here unless we’re in successive runs that rudely left their trash
                                        if exist "%MAYBE_LYRICS_1%"    gosub delete_file "%MAYBE_LYRICS_2"
                                        if exist "%COPIED_REPO_LYRIC%" gosub delete_file "%COPIED_REPO_LYRIC%"
                                        goto /i MaybeLyrics2
                                endiff
                endiff
                iff "%ANSWER%" == "Y" .or. "%ANSWER%" == "H" .or. "%ANSWER%" == "P" then
                        *copy /Ns "%MAYBE_LYRICS_2%" "%LYRIC_FILE%"
                        set COPIED_REPO_LYRIC=%MAYBE_LYRICS_2%
                        unset /q LYRIC_STATUS
                        gosub check_for_answer_of_P "%@UNQUOTE[%AUDIO_FILE%]"
                        gosub check_for_answer_of_Q "%@UNQUOTE[%AUDIO_FILE%]"
                        if "%ANSWER%" == "P" goto /i ask_again_1297
                        if "%ANSWER%" == "Q" goto /i ask_again_1297
                        iff "%ANSWER%" == "Y" then
                                set LYRICS_ACCEPTABLE=1
                                set DO_NOT_ASK_TO_HAND_EDIT=1
                        endiff
                        gosub edit_lyrics_now_if_we_answered_H H
                        if "%ANSWER%" == "H" (echo %BLINK_ON%should we ask if post-hand-edited  are good here?? 🚄🚄🚄🚄🚄%BLINK_OFF% 🐐 %+ pause)
                        goto /i have_acceptable_lyrics_now_or_at_the_very_least_are_done
                else
                        set LYRICS_ACCEPTABLE=0
                        call warning_soft "Not using potential lyric file #2, then..."
                endiff
        endiff
        if "1" != "%FORCE_REDOWNLOAD%" .and. ("%LYRICLESSNESS_STATUS%" == "APPROVED" .or. "%GOTO_END%" == "1") goto /i END_OF_GET_LYRICS

rem If we still didn’t find anything acceptable, but have potentially matching files in our lyric repository, let us select one manually:
        :TrySelectingSomethingFromOurLyricsArchive
        :select_from_repo_again
        set TRY_SELECTION_AGAIN=0
        set do_block_1008=0
        if exist "%MAYBE_LYRICS_1_BROAD_SEARCH%" .and. "%SKIP_MANUAL_SELECTION%" != "1" .and. "1" != "%GENIUS_ONLY%" (set do_block_1008=1)

        if "1" != "%do_block_1008%" goto /i do_not_do_block_1008
                set  file_count=%@files["%MAYBE_LYRICS_1_BROAD_SEARCH%"]
                if "%file_count%" == "1" .and. "1" != "%found_broad_lyrics_branch_1%" goto /i true_1010 %+ rem else:
                                                                                      goto /i false_1010
                        :true_1010
                        if "%ONLY_ONE_FILE_AND_IT_WAS_TRIED%" == "1" goto /i End_Of_Local_Lyric_Archive_Selection
                        gosub divider
                        set expanded=%@unquote[%@expand["%MAYBE_LYRICS_1_BROAD_SEARCH%"]]
                        if "%expanded%" == "%maybe_lyrics_1%" (
                                echo %ansi_color_warning_soft%%star2% Skipping %italics_on%MAYBE_LYRICS_1_BROAD_SEARCH%italics_off% because when expanded it is the same as %italics_on%MAYBE_LYRICS_1%italics_off% which is %lq%%expanded%%rq%%ansi_color_normal%
                                goto /i Nevermind_about_this_1 
                        )
                        if %@CKSUM["%expanded%"] == %@CKSUM["%maybe_lyrics_1%"] (
                                echo Skipping checking maybe_lyrics_1_broad_search because expanded has same checksome as maybe_lyrics_1 which is %@CKSUM["%expanded%"] for %lq%%expanded%%rq% and %@CKSUM["%maybe_lyrics_1%"] for %lq%%maybe_lyrics_1%%rq%
                                goto /i Nevermind_about_this_1
                        )
                        if "%[already_tried_potential_lyrics_%expanded%]" == "1" echo %star% We already decided these lyrics weren’t good: %italics_on%%faint_on%%expanded%%faint_off%%italics_off%
                        if "%[already_tried_potential_lyrics_%expanded%]" == "1" goto /i Nevermind_about_this_1
                        rem “Found possible lyrics”
                        call less_important "Found %italics_on%possible%italics_off% lyrics (type 3) at: %emphasis%%expanded%%deemphasis%!"
                                call less_important "Let’s review them..."
                                set  found_broad_lyrics_branch_1=1
                                *copy /Ns "%expanded%" "%TMPREVIEWFILE%" 
                                set COPIED_REPO_LYRIC=%expanded%
