                                on break goto /i :next_one_1
                                if "A" == "%SYNCEDLYRICS_MODE%" .or. "B" == "%SYNCEDLYRICS_MODE%" .or. "T" == "%SYNCEDLYRICS_MODE%" (echo %@ansi_move_to_col[1]%ansi_erase_to_eol%%ansi_color_less_important%%star2% Attempting to fetch %ansi_color_important%%italics_on%plain %[italics_off]text lyrics %ansi_color_important_less%with %italics_on%SyncedLyrics%[italics_off]...%ansi_color_normal% `` %+ echos %ANSI_SAVE_POSITION%  %ANSI_COLOR_NORMAL%%ARROW%  %LYRIC_RETRIEVAL_COMMAND%%ZZZANSI_RESTORE_POSITION%%ZZZANSI_MOVE_UP_1ZZZ% %+ (%LYRIC_RETRIEVAL_COMMAND% >&nul) |:u8 copy-move-post) ) %+ SET TEMPCHAR=%@IF[exist  "%TXT_SIDECAR_FILENAME_TEMP%",%CHECK%,%RED_X%] %+ echo  %TEMPCHAR%%@ansi_move_to_col[3]%TEMPCHAR% %+ rem call errorlevel "%CURRENT_LYRIC_PROVIDER% Problem retrieving plain text lyrics  in %0")
                                :next_one_1
                                on break goto /i :next_one_2
                                if "A" == "%SYNCEDLYRICS_MODE%" .or. "B" == "%SYNCEDLYRICS_MODE%" .or. "L" == "%SYNCEDLYRICS_MODE%" (echo %@ansi_move_to_col[1]%ansi_erase_to_eol%%ansi_color_less_important%%star2% Attempting to fetch %ansi_color_important%%italics_on%standard%italics_off% subtitles %ansi_color_important_less%with %[italics_on]SyncedLyrics%italics_off%...%ansi_color_normal% `` %+ echos %ANSI_SAVE_POSITION%  %ANSI_COLOR_NORMAL%%ARROW%  %SUBTI_RETRIEVAL_COMMAND%%ZZZANSI_RESTORE_POSITION%%ZZZANSI_MOVE_UP_1ZZZ% %+ (%SUBTI_RETRIEVAL_COMMAND% >&nul) |:u8 copy-move-post) ) %+ SET TEMPCHAR=%@IF[exist  "%LRC_SIDECAR_FILENAME_TEMP%",%CHECK%,%RED_X%] %+ echo  %TEMPCHAR%%@ansi_move_to_col[3]%TEMPCHAR% %+ rem call errorlevel "%CURRENT_LYRIC_PROVIDER% Problem retrieving standard subtitles in %0")
                                :next_one_2
                                on break goto /i :next_one_3
                                if "A" == "%SYNCEDLYRICS_MODE%"                                                                     (echo %@ansi_move_to_col[1]%ansi_erase_to_eol%%ansi_color_less_important%%star2% Attempting to fetch %ansi_color_important%%italics_on%extended%italics_off% subtitles %ansi_color_important_less%with %[italics_on]SyncedLyrics%italics_off%...%ansi_color_normal% `` %+ echos %ANSI_SAVE_POSITION%  %ANSI_COLOR_NORMAL%%ARROW%  %EXSUB_RETRIEVAL_COMMAND%%ZZZANSI_RESTORE_POSITION%%ZZZANSI_MOVE_UP_1ZZZ% %+ (%EXSUB_RETRIEVAL_COMMAND% >&nul) |:u8 copy-move-post) ) %+ SET TEMPCHAR=%@IF[exist "%ELRC_SIDECAR_FILENAME_TEMP%",%CHECK%,%RED_X%] %+ echo  %TEMPCHAR%%@ansi_move_to_col[3]%TEMPCHAR% %+ rem call errorlevel "%CURRENT_LYRIC_PROVIDER% Problem retrieving extended subtitles in %0")
                                :next_one_3
                                on break echo %EMOJI_BANG%%EMOJI_BANG%%EMOJI_BANG%%EMOJI_BANG%%EMOJI_BANG%%EMOJI_BANG%%EMOJI_BANG%%EMOJI_BANG%%EMOJI_BANG%%EMOJI_BANG%%EMOJI_BANG%%EMOJI_BANG%%EMOJI_BANG%%EMOJI_BANG%%EMOJI_BANG%
                                echos %@ansi_move_to_col[1]%ansi_erase_to_eol%


                       :skip_only_this_search_2413                                                                                                                                    



                        rem Postprocess those that we can postprocess inline: (TODO: postprocess lyrics maybe? but that requires tmp file stuffs)
                                if exist "%ELRC_SIDECAR_FILENAME_TEMP%" (echo %ansi_color_run%%emoji_gear% Postprocessing potential %italics_on%ELRC%italics_off% file... %ELRC_SIDECAR_FILENAME_TEMP% %ansi_color_normal% %+       lrc-postprocessor.pl   "%ELRC_SIDECAR_FILENAME_TEMP%" )
                                if exist  "%LRC_SIDECAR_FILENAME_TEMP%" (echo %ansi_color_run%%emoji_gear% Postprocessing potential %italics_on%LRC%[italics_off] file... %[LRC_SIDECAR_FILENAME_TEMP] %ansi_color_normal% %+       lrc-postprocessor.pl    "%LRC_SIDECAR_FILENAME_TEMP%" )
                                if exist  "%SRT_SIDECAR_FILENAME_TEMP%" (echo %ansi_color_run%%emoji_gear% Postprocessing potential %italics_on%SRT%[italics_off] file... %[SRT_SIDECAR_FILENAME_TEMP] %ansi_color_normal% %+  subtitle-postprocessor.pl    "%SRT_SIDECAR_FILENAME_TEMP%" )
                                if exist  "%TXT_SIDECAR_FILENAME_TEMP%" (echo %ansi_color_run%%emoji_gear% Postprocessing potential %italics_on%TXT%[italics_off] file... %[TXT_SIDECAR_FILENAME_TEMP] %ansi_color_normal% %+     lyric-postprocessor.pl    "%TXT_SIDECAR_FILENAME_TEMP%" )





                        rem Make sure LRC is actually an LRC:
                                if not exist "%LRC_SIDECAR_FILENAME_TEMP%" goto :end_of_ensure_LRC_compliance
                                        rem Determine if it’s an LRC or not:
                                                unset /q COMP3 COMP4
                                                set COMP3=%@execstr[grep "\[[0-9][0-9]:[0-9][0-9]\.[0-9][0-9][0-9]*\]" "%LRC_SIDECAR_FILENAME_TEMP%"]
                                                set COMP4=%@execstr[grep "\[[0-9][0-9]:[0-9][0-9]\]"                   "%LRC_SIDECAR_FILENAME_TEMP%"]
                                                iff "" == "%COMP3%" .and. "" == "%COMP4%" then
                                                        set LRC_IS_LRC=0
                                                else
                                                        set LRC_IS_LRC=1
                                                endiff

                                        rem Warn+Preview+Delete if it is not an LRC:
                                                rem DEBUG: type "%LRC_SIDECAR_FILENAME_TEMP%" %+ call important "this is/isn’t an lrc: %lrc_is_lrc" %+ call pause-for-x-seconds 2
                                                if  "1" == "%LRC_IS_LRC%" .or.  not exist "%LRC_SIDECAR_FILENAME_TEMP%" goto :endiff_2598
                                                        set    KEEP_LRC=0
