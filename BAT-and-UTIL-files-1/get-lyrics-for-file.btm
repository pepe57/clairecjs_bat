rem ——————————————————————————————————————————————————————————————————————————————————————————

rem USAGE:
        rem rem echo y α linish 87
        iff "%1" == "" then
                echo.
                gosub divider
                rem set goto_end=1
                goto sayusage
                gosub divider
                goto /i END_OF_GET_LYRICS
        endiff

rem For testing the “divider” subroutine:      
        iff "%1" == "divider" then
                gosub divider
                goto /i END_OF_GET_LYRICS
        endiff

rem If the FIRST arg is SetVarsOnly, we are just setting variables without having an associated audio file. So no probing. So this is it.
        rem "%1" == "SetVarsOnly" goto /i END_OF_GET_LYRICS
        if  "%1" == "SetVarsOnly" goto /i final_ending



rem SETUP: GRAB CALLING BAT FILE NAME, IF ANY:
        set PARENT_BAT=%@NAME[%_PBATCHNAME] %+ rem the calling BAT filename without path or extension i.e. “whatever” as opposed to “c:\bat\whatever.bat”
        set currently_getting_lyrics=1

rem DEBUG: 
        rem call bigecho CONSIDER_ALL_LYRICS_APPROVED is %CONSIDER_ALL_LYRICS_APPROVED% 
        rem set SKIP_MANUAL_SELECTION=1 to skip the manual select part

rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

rem Remove any trash environment variables left over from a previously-aborted run which might interfere with the current run:
        rem rem echo y α linish 151
        rem unset /q LYRIC_RETRIEVAL_1_FAILED
        unset /q LD1_MASSAGED_ATTEMPT_1 WE_GOOGLED TRY_SELECTION_AGAIN ONLY_ONE_FILE_AND_IT_WAS_TRIED cover_original_attempt DO_NOT_ASK_TO_HAND_EDIT ALREADY_HAND_EDITED already_searched_for* GOOGLE_NOW ANSWER HOLD_ANSWER goto_download_with_lyric_downloader_1 goto_download_with_lyric DO_NOT_ASK_TO_HAND_EDIT PREV_GENIUS_FNAME_2_USE postprocessed_lyrics FORCE_REGEN_LYRICS logged_lyricapproval_* quick_lrc_mode REFUSED_LOCAL_REPO LAST_FILE_LENGTH
        unset /q CURRENT_LYRIC_PROVIDER CURRENT_LYRIC_PROVIDER_DISPLAY OTHER_LYRIC_PROVIDER OTHER_LYRIC_PROVIDER_DISPLAY PRIMARY_LYRIC_PROVIDER PROVIDER_ONLY PROVIDER_PASS_DONE_GENIUS PROVIDER_PASS_DONE_SYNCEDLYRICS RESTARTED_WITH_OTHER_LYRIC_PROVIDER PREVIOUS_LYRIC_PROVIDER_DISPLAY SYNCEDLYRICS_ONLY current_provider_key DO_NOT_ASK_TO_SET_LYRICLESS_AGAIN COPIED_REPO_LYRIC LRC_STRETCH_ARGUMENT
        set goto_END=0
        set debanded=0
        set FORCE_HAND_EDIT=0
        set LYRICS_ACCEPTABLE=0
        set FORCE_REGEN_LYRICS=0                                               
        set JUST_APPROVED_LYRICS=0
        set JUST_GENERATED_LYRICS=0
        set LYRICS_JUST_DISAPPROVED=0
        set JUST_CONVERTED_LRC_TO_TEXT=0
        set JUST_CONVERTED_SRT_TO_TEXT=0
        set FOUND_BROAD_LYRICS_BRANCH_1=0
        set JUST_APPROVED_LYRICLESSNESS=0
        set JUST_RENAMED_TO_INSTRUMENTAL=0      %+ set JUST_RENAMED=0
        set FORCE_AI_ENCODE_FROM_LYRIC_GET=0
        set DO_NOT_FETCH_LRC_IF_SRT_EXISTS=1
        set ASKED_ABOUT_INSTRUMENTAL_ALREADY=0
        set GOTO_END_AFTER_GET_LYRICS_CALLED=0
        set FORCE_ASK_TO_APPROVE_LYRICLESSNESS=0
        rem set LYRIC_SUCCESS_CELEBRATION_DISPLAYED=0 %+ rem we changed this from a 0/1 flag to a “1_%audio_file%” flag
        set TMPREVIEWFILE=%temp%\lyric-review-file.%_datetime.%@RANDOM[1,99999].%_PID.txt               %+ rem Temp file we sometimes use to hold files-to-review to be reviewed in
        rem Leave this one for when we are calling get-lyrics from create-karaoke: unset /q LYRIC_STATUS
        rem Leave this one for when we are calling get-lyrics from create-karaoke: unset /q LYRICLESSNESS_STATUS
        unset /q LYRIC_SEARCH_FAILED GENIUS_ONLY ABANDONED_SEARCH LYRICS_SHOULD_BE_CONSIDERED_ACCEPTIBLE GOTO_END did_not_go_to_end_169 lyric_downloader_initialized player_command_to_use LAST_ALIGNMENT_TEMP_INDEX rejected_original_lyrics JUST_CONVERTED_FROM
        echo FORCE_HAND_EDIT=%FORCE_HAND_EDIT% trace 1 >nul 


rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

rem Process parameters / Force mode?
        :initialize_parameters
                rem rem echo y α linish 172
                set FORCE_REDOWNLOAD=0
                set QUICK_LRC_MODE=0

        :process_more
                set PROCESS_MORE=0

        :process_force_mode
                if "%1" == "force" (
                        set FORCE_REDOWNLOAD=1 
                        shift
                        set PROCESS_MORE=1
                ) else (
                        if "%2" == "force" .or.  "%3" == "force" .or.  "%4" == "force" .or.  "%5" == "force" (
                                set FORCE_REDOWNLOAD=1 
                        )
                )

        :process_quick_lrc_mode
                if "%1" == "quick_LRC" .or. "%1" == "quick-LRC" .or. "%1" == "quickLRC" (
                        set QUICK_LRC_MODE=1 
                        shift
                        iff "%1" == "upgrade" then
                                set DO_NOT_FETCH_LRC_IF_SRT_EXISTS=0
                                shift
                        endiff
                        set PROCESS_MORE=1
                ) else (
                        if "%2" == "quick_LRC" .or.  "%3" == "quick_LRC" .or.  "%4" == "quick_LRC" .or.  "%5" == "quick_LRC" ( set QUICK_LRC_MODE=1 )
                        if "%2" == "quick-LRC" .or.  "%3" == "quick-LRC" .or.  "%4" == "quick-LRC" .or.  "%5" == "quick-LRC" ( set QUICK_LRC_MODE=1 )
                        if "%2" == "quickLRC"  .or.  "%3" == "quickLRC"  .or.  "%4" == "quickLRC" . or.  "%5" == "quickLRC"  ( set QUICK_LRC_MODE=1 )
                )

        :process_other_parameters
                if "1" == "%PROCESS_MORE%" goto :process_more

        :respond_to_force_parameter
                if "1" == "%FORCE_REDOWNLOAD%" (
                        unset /q last*
                        unset /q already*
                )       

        :debug_stuffs_330
                rem echo FORCE_REDOWNLOAD is “%FORCE_REDOWNLOAD%”       %+ pause
                rem echo QUICK_LRC_MODE   is “%QUICK_LRC_MODE%”         %+ pause

     
rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━


rem VALIDATE ENVIRONMENT [once per session]:
        rem rem echo y α linish 189
        iff "2" != "%VALIDATED_GLVMS_ENV%" then
                rem pause "validating create-lyr env"
                rem Default values to help portability:
                        if not defined ESCAPE                                        set                                            ESCAPE=%@CHAR[27]
                        if not defined ANSI_ESCAPE                                   set                                       ANSI_ESCAPE=%ESCAPE%[
                        if not defined ANSI_CURSOR_CHANGE_TO_DEFAULT                 set        ANSI_CURSOR_CHANGE_TO_DEFAULT=%ANSI_ESCAPE%0 q
                        if not defined ANSI_CURSOR_CHANGE_TO_BLOCK_BLINKING          set ANSI_CURSOR_CHANGE_TO_BLOCK_BLINKING=%ANSI_ESCAPE%1 q
                        if not defined ANSI_CURSOR_CHANGE_TO_BLOCK_STEADY            set ANSI_CURSOR_CHANGE_TO_BLOCK_STEADY=%ANSI_ESCAPE%2 q
                        if not defined ANSI_CURSOR_CHANGE_TO_UNDERLINE_BLINKING      set ANSI_CURSOR_CHANGE_TO_UNDERLINE_BLINKING=%ansi_escape%3 q
                        if not defined ANSI_CURSOR_CHANGE_TO_UNDERLINE_STEADY        set ANSI_CURSOR_CHANGE_TO_UNDERLINE_STEADY=%ansi_escape%4 q
                        if not defined ANSI_CURSOR_CHANGE_TO_VERTICAL_BAR_BLINKING   set ANSI_CURSOR_CHANGE_TO_VERTICAL_BAR_BLINKING=%ansi_escape%5 q
                        if not defined ANSI_CURSOR_CHANGE_TO_VERTICAL_BAR_STEADY     set ANSI_CURSOR_CHANGE_TO_VERTICAL_BAR_STEADY=%ansi_escape%6 q
                        rem TODO: ansi_color_yellow, bold on, bold off
                        if "%@ANSI_CURSOR_CHANGE_COLOR_WORD[]" == ""            function ANSI_CURSOR_CHANGE_COLOR_WORD=`%@char[27][ q%@char[27]]12;%1%@char[7]`                                
                        if not defined FILEMASK_AUDIO                                set FILEMASK_AUDIO=*.mp3;*.wav;*.rm;*.voc;*.au;*.mid;*.stm;*.mod;*.vqf;*.ogg;*.mpc;*.wma;*.mp4;*.flac;*.snd;*.aac;*.opus;*.ac3;*.dtshd
                rem Now Validate:
                        call validate-in-path               %LYRIC_DOWNLOADER_1% %LYRIC_DOWNLOADER_2% %PROBER% %PLAYER_COMMAND% delete-zero-byte-files get-lyrics-with-lyricsgenius-json-processor.pl tail echos  divider unimportant success alarm unimportant debug warning error fatal_error advice  important important_less celebrate eset eset.bat eset-alias.bat insert-before-each-line.pl insert-before-each-line.py pause-alias google.bat google.py google.pl newspaper.bat print_with_columns.py print-with-columns.bat newspaper.bat srt2lrc.py stretch_lrc.py change-single-quotes-to-double-apostrophes.py add-ADS-tag-to-file.bat remove-ADS-tag-from-file.bat display-ADS-tag-from-file.bat display-ADS-tag-from-file.bat approve-lyrics.bat disapprove-lyrics.bat display-lyric-status-for-file.bat review-lyrics.bat review-files.bat approve-lyric-file.bat disapprove-lyric-file.bat approve-subtitle-file.bat disapprove-subtitle-file.bat get-lyric-status.bat approve-LYRICLESSNESS-for-file.bat disapprove-lyriclessness-for-file.bat unapprove-lyriclessness-for-file.bat cut.exe srt2txt.py lrc2txt.bat lrc2txt.py rn.bat clean-up-AI-transcription-trash-files-here.bat check-for-future-dated-files.bat display-mp3-length
 lyric-postprocessor.pl subtitle-postprocessor.pl lrc-postprocessor.pl                       rem  call unimportant               "Validated: lyric downloader, audio file prober" 
                        call validate-environment-variables ANSI_COLORS_HAVE_BEEN_SET EMOJIS_HAVE_BEEN_SET BAT TEMP LYRIC_ACCEPTABILITY_REVIEW_WAIT_TIME LYRIC_SELECT_FROM_FILELIST_WAIT_TIME cool_question_mark star check LONGEST_POSSIBLE_HAND_EDIT_TIME_IN_SECONDS LYRIC_ACCEPTABILITY_REVIEW_WAIT_TIME_AUTO 
                        if not defined filemask_audio       call validate-environment-variable filemask_audio skip_validation_existence
                        call validate-functions             cool_text rainbow_string ansi_rgb
                        call validate-plugin                StRiPaNsI
                        call checkeditor
                        if "1" == "%WINAMP_INTEGRATION_GETLYRICS%" call validate-in-path enqueue.bat winamp-next.bat enqueueee.exe
                        set  VALIDATED_GLVMS_ENV=2
        endiff

        if not defined TRANSCRIBER_VALID_EXTENSIONS gosub "%BAT%\create-srt-from-file.bat" set_TRANSCRIBER_VALID_EXTENSIONS_AND_LOCK_FILE_NAME

rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

rem SET FILENAMES:
        rem rem echo y α linish 216
        *setdos /x-4
        set  AUDIO_FILE=%@UNQUOTE["%1"]
        set ELRC_SIDECAR_FILENAME=%@NAME[%AUDIO_FILE].elrc
        set  LRC_SIDECAR_FILENAME=%@NAME[%AUDIO_FILE].lrc
        set  SRT_SIDECAR_FILENAME=%@NAME[%AUDIO_FILE].srt
        set  TXT_SIDECAR_FILENAME=%@NAME[%AUDIO_FILE].txt
        set            LYRIC_FILE=%TXT_SIDECAR_FILENAME%
        set ELRC_SIDECAR_FILENAME_TEMP=%@NAME[%AUDIO_FILE].elrc.maybe
        set  LRC_SIDECAR_FILENAME_TEMP=%@NAME[%AUDIO_FILE].lrc.maybe
        set  SRT_SIDECAR_FILENAME_TEMP=%@NAME[%AUDIO_FILE].srt.maybe
        set  TXT_SIDECAR_FILENAME_TEMP=%@NAME[%AUDIO_FILE].txt.maybe
        set            LYRIC_FILE_TEMP=%TXT_SIDECAR_FILENAME_TEMP%
        setdos /x0

        :process_audiofile_parameter_again
        rem rem echo y α linish 226
        *setdos /x-4
        set  AUDIO_FILE_FULL=%@UNQUOTE[%@FULL["%AUDIO_FILE%"]]
        set  AUDIO_FILE_BASE=%@UNQUOTE[%@NAME["%AUDIO_FILE%"]]
        set  AUDIO_FILE_NAME=%@UNQUOTE[%@NAME["%AUDIO_FILE%"]]
        set  AUDIO_FILE_EXT=%@UNQUOTE[%@EXT["%AUDIO_FILE%"]]
        setdos /x0



rem VALIDATE PARAMETERS [every time]:
        rem Make sure it’s a transcribeable filename:
                gosub "%BAT%\create-srt-from-file.bat" validate_transcribeable_filename "%AUDIO_FILE%" "getting lyrics"
                set retval=%_?
                iff "%_?" == "666" .or. "%retval%" == "666" .or. "1" == "%goto_end%" then
                        echo %EMOJI_STOP_SIGN% %ansi_color_warning_soft%Aborting because this file is not transcribeable...%ansi_color_normal%
                        gosub divider
                        if "1" == "%QUICK_LRC_MODE%" goto /i :end_quick_lrc_mode_skip
                        quit 123
                        goto /i final_ending
                endiff



        rem Audio file extension correction for invocation mistakes (i.e. calling this on the JSON instead of the MP3/FLAC):
                iff     "%AUDIO_FILE_EXT%" == "json" then                                                                  %+ rem If we invoked a JSON accidentally:
                        set audio_file=%audio_file_base%.flac                                                              %+ rem   Try it with FLAC instead
                        set oops_was_json=1                                                                                %+ rem   And remember we tried...
                        goto /i :process_audiofile_parameter_again                                                         %+ rem   And go try again
                elseiff "%AUDIO_FILE_EXT%" == "flac" .and. not exist "%AUDIO_FILE%" .and. "1" == "%oops_was_json%" then    %+ rem If it was a JSON and the FLAC we tried failed:
                        set audio_file=%audio_file_base%.mp3                                                               %+ rem   Try it with mp3 instead
                        set oops_was_json=0                                                                                %+ rem   but don’t try it ever again
                        goto /i :process_audiofile_parameter_again                                                         %+ rem   ...Now Go try again!
                endiff


        rem Now see if it exists....
                if not exist "%AUDIO_FILE%"  call validate-environment-variable AUDIO_FILE "1ˢᵗ parameter to get-lyrics-for-file must be an audio file that exists! [PBATCHNAME=%@UNQUOTE["%_PBATCHNAME"]] [full command line=“%@UNQUOTE["%0"] %@UNQUOTE["%*"]”]"

        rem Get the folder that the song is in:
                *setdos /x-4
                rem SONG_DIR=%@UNQUOTE[%@PATH["%AUDIO_FILE%"]]
                set SONG_DIR=%@UNQUOTE["%@PATH["%@UNQUOTE["%@FULL["%AUDIO_FILE%"]"]"]"]
                setdos /x0

        rem Validate the extension of the audio file :
                rem pause "call validate-file-extension “%AUDIO_FILE%” %FILEMASK_AUDIO%"
                call validate-file-extension "%AUDIO_FILE%" %FILEMASK_AUDIO%

rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

rem Check for “force” option which may only have been provided this BAT when directly called (it’s often set in get-karaoke.bat)
        if "%1" == "force" .or. "%2" == "force" .or. "%3" == "force" .or. "%4" == "force" .or. "%5" == "force" .or. "%6" == "force" (set force_regen_LYRICS=1 %+ goto /i done_skip_if_already_approved_lyriclessness)

rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

        rem Debug info:
                iff "False" == "True" then
                        echo        CWD                   is %_CWD
                        echo        AUDIO_FILE            is %AUDIO_FILE%
                        echo        AUDIO_FILE_FULL       is %AUDIO_FILE_FULL%
                        echo        @PATH["%AUDIO_FILE%"] is %@PATH["%AUDIO_FILE%"]
                        echo        if "%_CWD\" != "%SONG_DIR%"   pushd "%SONG_DIR%"
                        pause
                endiff

rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

        if "%_CWD\" != "%SONG_DIR%"   pushd "%SONG_DIR%"

                rem Determine lyric-provider mode:
                        set GENIUS_ONLY=0
                        set SYNCEDLYRICS_ONLY=0
                        set PROVIDER_ONLY=
                        set PRIMARY_LYRIC_PROVIDER=%DEFAULT_LYRIC_PROVIDER%
                        if "" != "%STARTING_LYRIC_PROVIDER%" set PRIMARY_LYRIC_PROVIDER=%@UPPER[%STARTING_LYRIC_PROVIDER%]
                        if "%PRIMARY_LYRIC_PROVIDER%" != "GENIUS" .and. "%PRIMARY_LYRIC_PROVIDER%" != "SYNCEDLYRICS" set PRIMARY_LYRIC_PROVIDER=SYNCEDLYRICS

                        iff "%2" == "genius" .or. "%3" == "genius" .or. "%4" == "genius" .or. "%5" == "genius" then
                                set GENIUS_ONLY=1
                                set PROVIDER_ONLY=LyricsGenius
                                set PRIMARY_LYRIC_PROVIDER=LyricsGenius
                                set LYRIC_ACCEPTABILITY_REVIEW_WAIT_TIME=8
                        elseiff "%2" == "syncedlyrics" .or. "%3" == "syncedlyrics" .or. "%4" == "syncedlyrics" .or. "%5" == "syncedlyrics" then
                                set SYNCEDLYRICS_ONLY=1
                                set PROVIDER_ONLY=SyncedLyrics
                                set PRIMARY_LYRIC_PROVIDER=SyncedLyrics
                                set LYRIC_ACCEPTABILITY_REVIEW_WAIT_TIME=8
                        endiff

                        set CURRENT_LYRIC_PROVIDER=%PRIMARY_LYRIC_PROVIDER%
                        set PROVIDER_PASS_DONE_GENIUS=0
                        set PROVIDER_PASS_DONE_SYNCEDLYRICS=0
                        iff "1" != "%QUICK_LRC_MODE%" then
                                gosub refresh_current_lyric_provider_metadatas
                        else

                rem ════════════════════════════════ QUICK LRC REMOVAL MODE ════════════════════════════════
                        if "%PARENT_BAT%" != "create-srt-from-file" .and. "1" != "%RUNNING_QUICKLRC_FROM_CREATESRT%" repeat 6 echo.
                        gosub divider
                        call important "Quick LRC retrieval" big
                        gosub divider
                        echo %ansi_color_warning_soft%%star2% Current folder:  %ZZZZZZZZZZZZZZZZZZZZZZZ%%ansi_color_bright_green%“%ansi_color_warning_soft%%faint_on%%[_CWP]%faint_off%%ansi_color_bright_green%”
                        set thisemphasis=%emphasis%
                        echo %BIG_TOP%%ansi_color_warning_soft%%star2% Audio file: %ZZZZZZZZZZZZZZZZZZZZZZZ%%ansi_color_bright_green%“%ansi_color_warning_soft%%thisemphasis%%AUDIO_FILE%%deemphasis%%ansi_color_bright_green%”
                        echo %BIG_BOT%%ansi_color_warning_soft%%star2% Audio file: %ZZZZZZZZZZZZZZZZZZZZZZZ%%ansi_color_bright_green%“%ansi_color_warning_soft%%thisemphasis%%AUDIO_FILE%%deemphasis%%ansi_color_bright_green%”
                        echos %BIG_OFF%
                        rem gosub say_if_exists AUDIO_FILE        0
                        gosub divider                        

                        iff "1" == "%SKIPPING_GET_LRCS_FOR_REST_OF_FOLDER%" then
                                call less_important "We’ve decided to skip getting LRCs for the rest of this folder..."
                                goto /i :end_quick_lrc_mode_skip
                        endiff

                        rem Visually say which files we have:
                                gosub say_if_exists TXT_SIDECAR_FILENAME  1
                                gosub say_if_exists SRT_SIDECAR_FILENAME  1
                                gosub say_if_exists LRC_SIDECAR_FILENAME  1

                        rem Abort if we already have the file we seek to create:
                                iff exist "%LRC_SIDECAR_FILENAME%" .and. "%QUICK_LRC_MODE%"                 == "1" .and. "1" != "%FORCE_REDOWNLOAD%" then
                                        gosub divider %+ call warning_soft "Skipping LRC retrieval because we already have an LRC" silent %+ goto /i :end_quick_lrc_mode_skip
                                endiff
                        rem Abort if we already have a SRT file -- TODO we will want to turn this off eventually so that we can do upgrades?
                                rem DEBUG: echo FORCE_REDOWNLOAD is %FORCE_REDOWNLOAD%
                                iff exist "%SRT_SIDECAR_FILENAME%" .and. "%DO_NOT_FETCH_LRC_IF_SRT_EXISTS%" == "1" .and. "1" != "%FORCE_REDOWNLOAD%" then
                                        gosub divider %+ call warning_soft "Skipping LRC retrieval because we already have a SRT"  silent %+ goto /i :end_quick_lrc_mode_skip
                                endiff

                endiff

             
rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

:begin_checking_if_this_is_one_we_should_process_or_not

rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━




rem HALT if Quick_LRC mode and we already have an LRC file:
        unset /q TOO
        iff "1" == "%QUICK_LRC_MODE%" .and. exist "%LRC_SIDECAR_FILENAME%" then
                set MESSAGE_SILENCE=1
                gosub divider
                call warning "LRC already exists!" big 
                gosub divider
                call warning "LRC already exists for:%ansi_background_black% %italics_on%%AUDIO_FILE%%italics_off%! ``"                
                gosub divider
                repeat 8 echo.
                unset /q MESSAGE_SILENCE
                exit /b
        endiff
        iff exist "%SRT_SIDECAR_FILENAME%" then
                if "1" == "%QUICK_LRC_MODE%" gosub divider
                call warning "SRT already exists!"
                rem removed for doubles: if "1" == "%QUICK_LRC_MODE%" gosub divider
        endiff



rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━


rem Old/redundant way that should no longer apply at this point:
        rem echo [AA-D] get-lyrics: INITIAL lyric status ===== “%LYRIC_STATUS%”, INITIAL lyriclessness status ===== “%LYRICLESSNESS_STATUS%”
        rem rem echo y α linish 281
        set CHIPTUNE_ENCOUNTERED=0
        iff 1 eq %@RegEx[\\CHIPTUNES\\,"%@UPPER[%@FULL["%AUDIO_FILE%"]]"] .or. 1 eq %@RegEx[[\[\(]CHIPTUNES?[\]\)],"%@UPPER[%@FULL["%AUDIO_FILE%"]]"] then
                gosub divider
                rem echo.
                call bigecho "%ansi_color_warning_soft%%emoji_warning% Chiptune encountered!%ansi_color_normal% %emoji_warning%"
                echo %ANSI_COLOR_WARNING%%emoji_warning% This is a chiptunes track! %emoji_warning%%ansi_color_normal% %ansi_color_bright_yellow%%connecting_minus%%connecting_minus% %ansi_color_yellow%%audio_file%%ansi_color_normal%
                set FORCE_ASK_TO_APPROVE_LYRICLESSNESS=1
                set LYRICLESSNESS_APPROVAL_CURRENT_DEFAULT_ANSWER=yes
                set CHIPTUNE_ENCOUNTERED=1
                rem controversial: just skip over chiptunes:
                rem goto /i END_OF_GET_LYRICS
                rem echo * Automatically approving lyriclessness...                                
                call approve-lyriclessness "%AUDIO_FILE%"
                echo %ansi_color_bright_red%%NO% Aborting because chiptune...
                goto /i END_OF_GET_LYRICS
        endiff
        set INSTRUMENTAL_ENCOUNTERED=0
        iff 1 eq %@RegEx[INSTRUMENTAL,"%@UPPER["%AUDIO_FILE%"]"] then
                gosub "%BAT%\create-srt-from-file.bat" refresh_lyriclessness_status
                rem DEBUG: echo %ansi_color_debug%-DEBUG: lyriclessness_status=“%lyriclessness_status%” %ansi_color_normal%
                set INSTRUMENTAL_ENCOUNTERED=0
                gosub divider
                rem echo.
                call bigecho "%ansi_color_warning_soft%%emoji_warning% Instrumental encountered!%ansi_color_normal% %emoji_warning%"
                echo %ANSI_COLOR_WARNING%%emoji_warning% This is an instrumental track! %emoji_warning%%ansi_color_normal% %ansi_color_bright_yellow%%connecting_minus%%connecting_minus% %ansi_color_yellow%%audio_file%%ansi_color_normal%
                iff "%lyriclessness_status%" != "APPROVED" then
                        set FORCE_ASK_TO_APPROVE_LYRICLESSNESS=1
                        set LYRICLESSNESS_APPROVAL_CURRENT_DEFAULT_ANSWER=yes
                        goto /i ask_to_approve_lyriclessness
                endiff
                echo %ansi_color_bright_red%%NO% Aborting because instrumental...
                goto /i END_OF_GET_LYRICS
        endiff

        set NO_LYRICS_ENCOUNTERED=0
        iff 1 eq %@RegEx["\[NO LYRICS\]]","%@UPPER["%AUDIO_FILE%"]"] .or. 1 eq %@RegEx["\(NO LYRICS\)","%@UPPER["%AUDIO_FILE%"]"] then
                gosub "%BAT%\create-srt-from-file.bat" refresh_lyriclessness_status
                rem DEBUG: rem OLD:           echo %ansi_color_debug%-DEBUG: lyriclessness_status[2]=“%lyriclessness_status%” %ansi_color_normal%
                set NO_LYRICS_ENCOUNTERED=0
                gosub divider
                rem echo.
                call bigecho "%ansi_color_warning_soft%%emoji_warning% Vocal track with no lyrics encountered!%ansi_color_normal% %emoji_warning%"
                echo %ANSI_COLOR_WARNING%%emoji_warning% This is a vocal track with no lyrics! %emoji_warning%%ansi_color_normal% %ansi_color_bright_yellow%%connecting_minus%%connecting_minus% %ansi_color_yellow%%audio_file%%ansi_color_normal%
                iff "%lyriclessness_status%" != "APPROVED" then
                        set FORCE_ASK_TO_APPROVE_LYRICLESSNESS=1
                        set LYRICLESSNESS_APPROVAL_CURRENT_DEFAULT_ANSWER=yes
                        goto /i ask_to_approve_lyriclessness
                endiff
                echo %ansi_color_bright_red%%NO% Aborting because instrumental...
                goto /i END_OF_GET_LYRICS
        endiff


rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━


rem Let user know what we’re about to do! moved from below to here
iff "%2" != "SetVarsOnly" .and. "1" != "%QUICK_LRC_MODE%" then

                                          rem 2024/12/24: not sure that i want this now? it may depend on pbatchname tbh: call  divider
        echos %ANSI_RESET%
        iff "%@UNQUOTE[%PARENT_BAT%]" != "" then
                rem echo PBATCHNAME=“%_PBATCHNAME”
                gosub divider
        endiff
        *setdos /x-4
        rem  bigecho "%STAR% Getting lyrics for “%@ansi_rgb[170,170,244]%italics_on%%audio_file%%italics_off%%ansi_color_normal%”"
        rem  ^^^^^^^^ decided to expand this into 2 lines to reduce line-wrap errors
        set quote_color=%ansi_color_bright_green%


        iff "now" == "goatgoat before 20260428" then
                iff "%LYRICLESSNESS_STATUS%" == "APPROVED" .and. "1" != "%force_regen_LYRICS%" then
                        call warning "is this the infinite loop?!?!?!"
                        call AskYN   "Sorry. Not gonna do it. Unless you really want me to" no 30
                        if   "Y" == "%ANSWER%" goto /i i_really_want_you_to
                        goto /i END_OF_GET_LYRICS
                endiff
                :i_really_want_you_to
        endiff


        rem “✨ Getting lyrics for: “whatever.mp3””
        rem “✨ in:                 “\mp3\misc\1920\””:
                set                           VERB=Getting                                               
                if   exist "%LYRIC_FILE%" set VERB=Aligning existing
                call bigecho "%STAR% %ansi_color_magenta%%VERB% lyrics for: %quote_color%“%@ansi_rgb[170,170,244]%italics_on%%ansi_color_yellow%%@NAME[%audio_file%]%italics_off%%quote_color%”%ansi_color_normal%"
                set  folder_value=%@PATH[%audio_file%]
                if "%folder_value%" == "" set  folder_value=%_CWP
                if "%folder_value%" != "" call bigecho "%STAR% %ansi_color_magenta%in: %quote_color%“%@ansi_rgb[170,170,244]%italics_on%%ansi_color_yellow%%folder_value%%italics_off%%quote_color%”%ansi_color_normal%"
                if "1" == "%LYRIC_KARAOKE_ALIGNMENT_THOROUGH_MODE%" echo %ansi_color_important%%blink_on%%STAR2% Thorough mode is set%blink_off%%ansi_color_normal%


        rem Status bar update + cursor color fix:
                if "1" != "%DONT_MESS_WITH_MY_STATUS_BAR%" call status-bar "%VERB% lyrics for: %@NAME[%audio_file%]"
                setdos /x0
                echos %@ANSI_CURSOR_CHANGE_COLOR_WORD[bright cyan]%ANSI_CURSOR_CHANGE_TO_BLOCK_BLINKING%

endiff
        

rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━


rem Skip if already an approved-for-lyricLESSness song....
        rem set LYRICLESSNESS=%@ExecStr[TYPE "%@UNQUOTE["%AUDIO_FILE%"]:lyriclessness" >&>nul]   %+ rem Read lyriclessness status        
        rem ^^^^^ moved to beginning of file: call get-lyriclessness-status "%AUDIO_FILE%"
        rem  call get-lyriclessness-status "%AUDIO_FILE%" 🐐1 status=%RECEIVED_VALUE / %LYRICLESSNESS_STATUS
        rem echo %ansi_color_subtle%* LYRICLESSNESS_STATUS=“%LYRICLESSNESS_STATUS%”, FORCE_REGEN_LYRICS=“%FORCE_REGEN_LYRICS%” , audio_file=“%audio_file%” %ansi_color_normal% %conceal_on%%conseal_off%
        rem echo  [EL-A] get-lyrics: INITIAL lyric status ===== “%LYRIC_STATUS%” .... LYRICLESSNESS_STATUS ==== “%LYRICLESSNESS_STATUS%” ............... FORCE_REDOWNLOAD=“%FORCE_REDOWNLOAD%”  ............. %%1=“%1” %%2=“%2”

        rem rem echo y α linish 300
        if "%QUICK_LRC_MODE%"        ==   "1"      goto done_skip_if_already_approved_lyriclessness
        if "%LYRICLESSNESS_STATUS%"  == "APPROVED" goto done_skip_if_already_approved_lyriclessness                                                                                                                                                               
        if "%FORCE_REDOWNLOAD%"      ==   "1"      goto done_skip_if_already_approved_lyriclessness
        if "%1" == "force" .or. "%2" == "force"    goto done_skip_if_already_approved_lyriclessness
        if "%3" == "force" .or. "%4" == "force"    goto done_skip_if_already_approved_lyriclessness
        if "%5" == "force" .or. "%6" == "force"    goto done_skip_if_already_approved_lyriclessness
                                                   goto done_skip_if_already_approved_lyriclessness

                        rem if "" == "%LYRICLESSNESS_STATUS%" set LYRICLESSNESS_STATUS=APPROVED
                        :do_it_9024398042890234
                        rem not sure about this blank: echo.
                        gosub divider
                        echo %ansi_color_bright_yellow%%star% File already marked as lyric%underline_on%less%underline_off%. %italics_on%Not%italics_off% fetching lyrics.
                        echo %ansi_color_bright_white%%star% %faint_on%Filename: %italics_on%%AUDIO_FILE%%italics_off% %faint_off%
                        echo %ansi_color_advice%%@CHAR[55357]%@CHAR[56393] Add the “%bold_on%force%bold_off%” parameter to skip this check %@CHAR[55357]%@CHAR[56392]
                        gosub divider
                        iff "1" == "%FORCE_REDOWNLOAD%" then
                                echo %ansi_color_bright_yellow%%star% Forcing because you said so!%ansi_color_normal%
                                goto /i :done_skip_if_already_approved_lyriclessness
                        endiff
                        goto /i END_OF_GET_LYRICS                                                    %+ pause "this shouldn’t happen!"

        :done_skip_if_already_approved_lyriclessness

rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━     WRONG EXTENSION?

rem Skip if extension that can’t have lyrics:
        rem echo  [FL-A] get-lyrics: INITIAL lyric status ===== “%LYRIC_STATUS%” .... LYRICLESSNESS_STATUS ==== “%LYRICLESSNESS_STATUS%” ............... FORCE_REDOWNLOAD=“%FORCE_REDOWNLOAD%”  ............. %%1=“%1” %%2=“%2”
        iff "%AUDIO_FILE_EXT%" == "cmf" .or. "%AUDIO_FILE_EXT%" == "stm" .or. "%AUDIO_FILE_EXT%" == "s3m" .or. "%AUDIO_FILE_EXT%" == "mid" .or. "%AUDIO_FILE_EXT%" == "midi" then
                gosub divider
                echo %ANSI_COLOR_LESS_IMPORTANT%%EMOJI_WARNING% Files of extension “%italics_on%%AUDIO_FILE_EXT%%italics_off%” cannot have vocals (and thus cannot have lyrics)!%ANSI_COLOR_NORMAL%
                if "%LYRICLESSNESS_STATUS%" != "APPROVED" call approve-lyriclessness "%AUDIO_FILE%"
                set  JUST_APPROVED_LYRICLESSNESS=1
                set  LYRICLESSNESS_STATUS=APPROVED        
                gosub divider
                exit /b  %+ rem replaces: goto /i END_OF_GET_LYRICS
        endiff




rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━     MOVED FROM AFTER PROBE TO BEFORE  ON 2025/12/20:

rem Check if the lyrics are already approved...
        if "1" == "%QUICK_LRC_MODE%" goto end_of_Lyrics_Not_Approved_754 %+ rem Skip this section if we are in quick_lrc mode
        if "%LYRIC_STATUS%" == "" gosub refresh_lyric_status
        if not exist "%LYRIC_FILE%" set LYRIC_STATUS=NOT_SET
        if "%LYRIC_STATUS%" != "APPROVED" goto :end_of_Lyrics_Not_Approved_754
                iff "1" == "%FORCE_REGEN_LYRICS%" then
                        *ren /Ns /q "%LYRIC_FILE%" "%LYRIC_FILE%.removed_via_force_parameter.%[_datetime].bak"
                        set LYRIC_STATUS=NOT_SET
                        set LYRICLESSNESS_STATUS=NOT_SET
                        rem call sleep 1
                        goto /i :this_is_line_825
                else
                        iff "1" != "%FORCE_REGEN_LYRICS%" then
                                gosub divider
                                call celebrate "%blink_off%Lyrics already approved!"
                                unset /q SOLELY_BY_AI
                                goto /i END_OF_GET_LYRICS
                        endiff
                endiff
        :end_of_Lyrics_Not_Approved_754










rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━        PROBE FILE: original location

rem Get artist and song so we can use them to download lyrics:
        :start_probing
        if %DEBUG_VALUE_TRANSFER% gt 0 call unimportant "Probing file..."
        
        if "1" != "%QUICK_LRC_MODE%" .and. "%LYRICLESSNESS_STATUS%" == "" .and. exist "%@UNQUOTE[%AUDIO_FILE%]" set LYRICLESSNESS_STATUS=%@EXECSTR[type <"%@unquote["%AUDIO_FILE%"]:lyriclessness" >&>nul]``
        goto /i probe_faster
        
        
                                                                :probe_slower
                                                                        timer /5 on >nul
                                                                        set       FILE_ALBUM=%@EXECSTR[%PROBER% -v quiet -show_entries format_tags=album  -of default=noprint_wrappers=1:nokey=1 "%AUDIO_FILE%" |:u8 change-single-quotes-to-double-apostrophes.py]
                                                                        set      FILE_ARTIST=%@EXECSTR[%PROBER% -v quiet -show_entries format_tags=artist -of default=noprint_wrappers=1:nokey=1 "%AUDIO_FILE%" |:u8 change-single-quotes-to-double-apostrophes.py]
                                                                        set        FILE_SONG=%@EXECSTR[%PROBER% -v quiet -show_entries format_tags=title  -of default=noprint_wrappers=1:nokey=1 "%AUDIO_FILE%" |:u8 change-single-quotes-to-double-apostrophes.py]
                                                                        set FILE_ORIG_ARTIST=%@EXECSTR[%PROBER% -v quiet -show_entries format_tags=TOPE   -of default=noprint_wrappers=1:nokey=1 "%AUDIO_FILE%" |:u8 change-single-quotes-to-double-apostrophes.py]
                                                                        set PROBED_FILE_ALBUM=%PROBED_FILE_ALBUM%
                                                                        set PROBED_FILE_ARTIST=%FILE_ARTIST%
                                                                        set PROBED_FILE_SONG=%FILE_SONG%
                                                                        set PROBED_FILE_ORIG_ARTIST=%FILE_ORIG_ARTIST%
                                                                        echos %ansi_color_yellow%
                                                                        timer  /5  off %+ rem 0.946-.948
                                                                :probe_slower_end


        :probe_faster
                rem timer /5 on >nul
                if "1" != "%QUICK_LRC_MODE%" .and. exist "%LYRIC_FILE%" .and. %@FILESIZE["%LYRIC_FILE%"] gt 0  goto :nevermind_on_probe_due_to_having_lyrics
                
                rem Handle undefined variables
                        set "probe_tit="
                        set "probe_art="
                        set "probe_alb="
                        set "probe_tpe="
                        set "probe_hmm="
                                                
                rem Skip if we already probed the file (for instance, in the outer-layer/LRC-creator):
                        if "%PROBED_OR_REFUSED_ALREADY_709%" == "1" (echo %ansi_color_subtle%* already probed%ansi_color_normal% %+ goto /i :already_probed)
                        set already_probed=0
                        if "1" == "%QUICK_LRC_MODE%" goto :continue_the_probe
                        iff "%last_file_probed%" == "%AUDIO_FILE%" .and. defined probe_output .and. "" != "%PROBE_OUTPUT%" then
                                rem Say stuff:
                                        call warning_soft "We’ve already probed: %faint_on%“%italics_on%%audio_file%%italics_off%”%faint_off%"
                                        call debug "GOATEE PROBED_OR_REFUSED_ALREADY_709=“%PROBED_OR_REFUSED_ALREADY_709%”" silent

                                rem Configure the question we’re about to ask:
                                        unset /q answer hold_answer                                 
                                        iff "1" == "%QUICK_LRC_MODE%" then
                                                set REPROBE_QUESTION_WAIT_TIME=3
                                                set REPROBE_DEFAULT_ANSWER=no
                                        else
                                                set REPROBE_QUESTION_WAIT_TIME=10
                                                set REPROBE_DEFAULT_ANSWER=no
                                                if "Y" != "%PROBED_OR_REFUSED_ALREADY_709%" set REPROBE_DEFAULT_ANSWER=yes
                                        endiff

                                rem Ask the question:
                                        call AskYN "₆Re-get lyrics / Re-Probe again [%ansi_color_bright_green%G%ansi_color_prompt%/%ansi_color_bright_green%S%ansi_color_prompt%=use Genius/SyncedLyrics,%ansi_color_bright_green%F%ansi_color_prompt%ail]" %REPROBE_DEFAULT_ANSWER% %REPROBE_QUESTION_WAIT_TIME% GSF G:do_a_Genius_search,S:do_a_SyncedLyrics_search,F:Failll
                                        rem Save answer:
                                                set REGET_ANSWER=%ANSWER%
                                        rem “Y”/“N”:
                                                if   "Y" == "%REGET_ANSWER%" .or. "N" == "%REGET_ANSWER%" set PROBED_OR_REFUSED_ALREADY_709=1
                                                iff  "N" == "%REGET_ANSWER%" then
                                                        set PROBED_OR_REFUSED_ALREADY_709=1
                                                        call subtle "Probe refused [GOAT]
                                                        goto /i :END_OF_GET_LYRICS
                                                endiff
                                        rem “G”/“S” to toggle between 2 lyric providers:
                                                iff "G" == "%REGET_ANSWER%" then 
                                                        set CURRENT_LYRIC_PROVIDER=LyricsGenius 
                                                endiff
                                                iff "S" == "%REGET_ANSWER%" then 
                                                        set CURRENT_LYRIC_PROVIDER=SyncedLyrics
                                                endiff
                                                iff "G" == "%REGET_ANSWER%" .or. "S" == "%REGET_ANSWER%" then 
                                                        call subtle "Switched search to use %italics_on%%CURRENT_LYRIC_PROVIDER%%italics_off% provider..."
                                                        goto /i download_with_current_provider_init
                                                endiff
                                        rem “Y”:
                                                iff "Y" == "%REGET_ANSWER%" then
                                                        set PROBED_OR_REFUSED_ALREADY_709=1
                                                        goto /i :continue_the_probe
                                                endiff
                                        rem “F”:
                                                iff "F" == "%REGET_ANSWER%" then
                                                        if "1" == "%QUICK_LRC_MODE%" goto /i end_quick_lrc_mode_fail
                                                        if "1" != "%QUICK_LRC_MODE%" goto /i end_of_get_lyrics
                                                endiff
                                goto /i :already_probed
                        endiff
                        :continue_the_probe
                        
                rem Clear any previous leftover probe values:
                        set       FILE_ALBUM=
                        set      FILE_ARTIST=
                        set        FILE_SONG=
                        set FILE_ORIG_ARTIST=
                        
                rem Probe the file:                        
                        set delimeter_ascii=14

                        set PROBE_COMMAND=%PROBER% -v quiet -show_entries format_tags=title,artist,album,TOPE,composer -of compact=p=0:nk=0:s="%@CHAR[%delimeter_ascii%]"  "%AUDIO_FILE%"
                        if %DEBUG_VALUE_TRANSFER% gt 0 (echo %ansi_color_debug%%star9% argh: PROBE_COMMAND=“%PROBE_COMMAND%”)
                        unset /q probe_output        

                        call set-tmp-file "probed_results"
                        set tmpfile=%tmpfile%.txt

                        (%PROBE_COMMAND% |:u8 change-single-quotes-to-double-apostrophes.py) >:u8 %tmpfile%

                        *setdos /x-5 %+ rem otherwise if the probe data has “&&” in it, the part after “&&” gets sent to the command line! bug report filed at https://jpsoft.com/forums/threads/is-this-by-design-execstr-type-filename-and-line-send-parts-of-the-text-file-after-directly-to-the-command-line.12502/
                        set probe_output=%@EXECSTR[type "%@UNQUOTE["%tmpfile%"]"]
                        setdos /x0

                        if %DEBUG_VALUE_TRANSFER% gt 0 (echo %star9% sooo: PROBE_OUTPUT=“%PROBE_OUTPUT%”)

                        set last_file_probed=%AUDIO_FILE%


                rem Split the string into tokens:
                        for /f "tokens=1-5 delims=%@CHAR[%delimeter_ascii%]" %%a in ("%probe_output%") do (
                                rem if %DEBUG_VALUE_TRANSFER gt 0 .or. %DEBUG_TOKEN_PROCESSING gt 0 (echo       %faint_on%%wrench% processing tokens (tit=%[faint_off]%%a %@ansi_move_left[1]%[faint_on]) (art=%[faint_off]%%b %@ansi_move_left[1]%[faint_on]) (alb=%[faint_off]%%c %@ansi_move_left[1]%[faint_on]) (tope=%[faint_off]%%d %@ansi_move_left[1]%[faint_on]) (hmm=%[faint_off]%e %@ansi_move_left[1]%[faint_on])%[faint_off])
                                rem this ruins things *setdos /x-5
                                set "probe_tit=%%a"
                                set "probe_art=%%b"
                                set "probe_alb=%%c"
                                set "probe_tpe=%%d"
                                set "probe_hmm=%%e"
                                setdos /x0
                        )

                rem It doesn’t count if it matches the a/b/c/d/e var we already had outside of the split ... those are urnelated single-letter environment variables
                        *setdos /x-5
                        if "%probe_tit" == "%a" set probe_tit=
                        if "%probe_art" == "%b" set probe_art=
                        if "%probe_alb" == "%c" set probe_alb=
                        if "%probe_tpe" == "%d" set probe_tpe=
                        if "%probe_hmm" == "%e" set probe_hmm=
                        setdos /x0

                rem Save post-probed values for auditing
                        unset /q PROBED*
                        *setdos /x-5
                        set PROBED_FILE_SONG=%probe_tit%
                        set PROBED_FILE_ARTIST=%probe_art%
                        set PROBED_FILE_ALBUM=%probe_alb%
                        set PROBED_FILE_ORIG_ARTIST_TOPE=%probe_tpe%
                        set PROBED_FILE_ORIG_ARTIST_HMMM=%probe_hmm%
                        setdos /x0

                rem Untested attempt to copmensate for original artist/composer difference in mp3/flac tags:
                        if "" == "%probe_tpe" .and. "" != "%probe_hmm%" (set probe_tpe=%probe_hmm%)
                        
                rem Transfer values over to our variables:         
                        for %%tmpVarName in (probe_tit, probe_art, probe_alb, probe_tpe, probe_hmm) do gosub sub_for_724  "%@UNQUOTE["%tmpVarName%"]"
                                        goto /i for_724_end                                        
                                                :sub_for_724 [opt1]
                                                        set tmpVarName=%@UNQUOTE["%tmpVarName%"]
                                                        rem bad idea ... really need to set the separator to somehting else *setdos /x-5
                                                        set value=%[%tmpvarname]                                

                                                        set LEFT_NIN=%@left[ 9,%value%]
                                                        set LEFT_TEN=%@left[10,%value%]
                                                        set LEFT_ELV=%@left[11,%value%]
                                                        set LEFT_THI=%@left[13,%value%]

                                                        if %DEBUG_VALUE_TRANSFER gt 0  (echo %newline%!!   %%tmpVarName  is %lq%%TmpVarName%%rq% is %%value=%lq%%value%%rq% %+ echo    left_nin is %lq%%left_nin%%rq%%+ echo    left_ten is %lq%%left_ten%%rq% %+ echo    left_elv is %lq%%left_elv%%rq% %+ echo    left_thi is %lq%%left_thi%%rq%)
                                                        setdos /x0
                                     
                                                        rem echo %ansi_color_grey%- DEBUG:  wondering if things went south yet [3]%ansi_color_normal%

                                                        iff "%LEFT_TEN%" == "tag:TITLE=" then
                                                                if %DEBUG_VALUE_TRANSFER gt 0 (echo    🐓 setting FILE_SONG=%@right[%@eval[%@len[%value]-10],%value])
                                                                set FILE_SONG=%@right[%@eval[%@len[%value]-10],%value]
                                                        endiff
                                                        iff "%LEFT_ELV%" == "tag:ARTIST=" then
                                                                set FILE_ARTIST=%@right[%@eval[%@len[%value]-11],%value]
                                                                if %DEBUG_VALUE_TRANSFER gt 0 (echo    🐓 setting FILE_ARTIST=%@right[%@eval[%@len[%value]-11],%value])
                                                        endiff 
                                                        iff "%LEFT_TEN%" == "tag:ALBUM=" then
                                                                set tmpvalue=%@right[%@eval[%@len[%value]-10],%value]
                                                                set FILE_ALBUM=%tmpvalue%
                                                                if %DEBUG_VALUE_TRANSFER gt 0 (echo    🐓 setting FILE_ALBUM=%lq%%tmpvalue%%rq%)
                                                        endiff 
                                                        iff "%LEFT_THI%" == "tag:COMPOSER=" then
                                                                set FILE_ORIG_ARTIST=%@right[%@eval[%@len[%value]-13],%value]
                                                                if %DEBUG_VALUE_TRANSFER gt 0 (echo    🐓 setting FILE_ORIG_ARTIST=%@right[%@eval[%@len[%value]-13],%value])
                                                        endiff
                                                        iff "%LEFT_NIN%" == "tag:TOPE=" then
                                                                set FILE_ORIG_ARTIST=%@right[%@eval[%@len[%value]-9],%value]
                                                                if %DEBUG_VALUE_TRANSFER gt 0 (echo    🐓 setting FILE_ORIG_ARTIST=%@right[%@eval[%@len[%value]-9],%value])
                                                        endiff
                                                return
                                        :for_724_end
                        rem echo - DEBUG:  wondering if things went south yet [4]
                        iff "1" == "%DEBUG_DISPLAY_PROBE_RESULTS%" then
                                %color_debug%
                                echos %ansi_color_debug%
                                setdos /x-5
                                echo    🔬 probed song: “%probe_tit%” but file_song  =“%file_song%”
                                echo    🔬 probed band: “%probe_art%” but file_artist=“%file_artist%”
                                echo    🔬 probed albm: “%probe_alb%” but file_album =“%file_album%”
                                echo    🔬 probed tope: “%probe_tpe%” \__ orig_artist=“%file_orig_artist%”
                                echo    🔬 probed hmmm: “%probe_hmm%” /
                                setdos /x0
                                %color_normal%
                        endiff                                

        rem If we didn’t get a title, use the filename after the number, i.e. “01_Time.flac" ——> “Time"
                if "" == "%FILE_SONG%" (set FILE_SONG=%@rereplace[[\d]+_,,%@name["%AUDIO_FILE%"]])

        rem If we didnt’ get an artist, but the filename is a " - " type name, then get the aprt before the " - "                
                set audio_file_has_spacedashspace=%@RegEx[ \- ,"%AUDIO_FILE%"]
                iff "" == "%FILE_ARTIST%" .and. "1" == "%audio_file_has_spacedashspace%" then
                        set FILE_ARTIST=%@UNQUOTE[%@ReReplace[[0-9]+_,,%@ReReplace[ \- .*$,,"%AUDIO_FILE%"]]]
                        echo %star3%%emoji_warning% Attempting to create file_artist from audio filename.... got “%FILE_ARTIST%” %emoji_warning% %star3% %conceal_on%🦕🦕🦕🦕🦕🦕🦕🦕🦕🦕🦕🦕🦕🦕🦕🦕%conceal_off%
                endiff

        rem If we didn’t get an original artist, also check fo the Composer tag which is the only place it would likely be in a FLAC file...
                rem echo - DEBUG:  wondering if things went south yet [5]
                rem NO! ffprobe does some voodoo behind the scenes making this unnecessary: if "" == "%FILE_ORIG_ARTIST%" (set FILE_ORIG_ARTIST=%@EXECSTR[%PROBER% -v quiet -show_entries format_tags=Composer -of default=noprint_wrappers=1:nokey=1 "%AUDIO_FILE%" |:u8 change-single-quotes-to-double-apostrophes.py])

        rem “Title” is better than “Song”, but we are doing both for ease-of-remembrance
                set FILE_TITLE=%FILE_SONG%

        rem Done probing!                
                if %DEBUG gt 0 call unimportant "Probing done"         
                :already_probed


rem Update window title:
        if %DEBUG gt 0 call unimportant "setting window title to “%FILE_ARTIST% – %FILE_SONG%”"
        set title=%FILE_ARTIST% – %FILE_SONG%
        title %title%
        if %vebose gt 0 call unimportant "Title set" 

rem Back up original values of these variables because we change them as we try various different ways of searching:
        set      FILE_ARTIST_INITIAL=%FILE_ARTIST%
        set FILE_ORIG_ARTIST_INITIAL=%FILE_ORIG_ARTIST%
        set       FILE_ALBUM_INITIAL=%FILE_ALBUM%
        set        FILE_SONG_INITIAL=%FILE_SONG%
        set       FILE_TITLE_INITIAL=%FILE_SONG%
        if %vebose gt 0 call unimportant "Original values saved" 
        rem echo - DEBUG:  wondering if things went south yet [6]

:old_probe_end_846
rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━


rem Check if the lyrics are already approved was here until 20251220



rem Check if lyriclessness is already approved
        :check_if_lyriclessness_is_approved
        if "1" == "%QUICK_LRC_MODE%" goto :end_of_refresh_lyriclessness %+ rem Skip this section if we are in quick-lrc_mode
        gosub "%BAT%\create-srt-from-file.bat" refresh_lyriclessness_status
        rem echo [GM]   INITIAL lyriclessness status ===== “%LYRICLESSNESS_STATUS%”
        if "%LYRICLESSNESS_STATUS%" != "APPROVED" goto /i not_lyricless
                rem OLD: echo %ANSI_COLOR_WARNING_SOFT%%blink_on%%STAR2%%blink_off% Already marked %italics_on%lyric%underscore_on%less%underscore_off%%italics_off%!%ansi_color_normal% %faint_on%[force_regen_LYRICS=%force_regen_LYRICS%]%faint_off%
                rem NEW:
                rem no longer need this debug output: %faint_on%[force_regen_LYRICS=%force_regen_LYRICS%]%faint_off%
                call warning_soft "%ansi_color_orange%Already marked %italics_on%lyric%underscore_on%less%underscore_off%%italics_off%!" big
                call warning_soft "%ansi_color_orange%(which causes automatic transcription without having to fetch lyrics first)" 
                call warning_soft "%ansi_color_orange%%faint_on%(use the “force” parameter to do it anyway)%faint_off%" 


                rem But if we somehow have lyrics despite lyricLESSness status——perhaps due to LRCget or other utility
                rem downloading them——then we need to deal with that situation and decide whether the lyrics are canon:
                        iff exist "%LYRIC_FILE%" then
                                call warning "But wait! A TXT lyric file exists, despite lyric%italics_on%less%italics_off%ness status"
                                call review-file -wh "%LYRIC_FILE%"
                                set USE_WAIT_TIME=%WAIT_TO_DELETE_LYRICS%
                                if "1" == "%LYRIC_KARAOKE_ALIGNMENT_THOROUGH_MODE%" set USE_WAIT_TIME=0
                                call AskYN "Delete these lyrics %faint_on%[a backup %italics_on%will%italics_off% be kept]%faint_off%" no %USE_WAIT_TIME%
                                        iff "Y" == "%ANSWER%" then
                                                echos %ansi_color_removal%%EMOJI_AXE% Removing lyrics: ``
                                                *ren /Ns "%LYRIC_FILE%" "%LYRIC_FILE%.found-after-lyriclessness-established.%_DATETIME.bak"  
                                                echos %ansi_color_normal%
                                        endiff
                                        iff "N" == "%ANSWER%" then
                                                echo %ansi_color_important_less%%star2% Since you are now keeping lyrics, we will unapprove lyriclessness status%ansi_color_normal%
                                                call unapprove-lyriclessness "%AUDIO_FILE%"
                                                set LYRICLESSNESS_STATUS=NOT_APPROVED
                                                set  JUST_APPROVED_LYRICLESSNESS=0                        
                                                goto /i begin_checking_if_this_is_one_we_should_process_or_not
                                        endiff
                        endiff

                if "1" != "%FORCE_REGEN_LYRICS%" .and. "%1" !=  "force" .and. "%2" != "force" .and. "%3" !=  "force" .and. "1" != "%did_not_go_to_end_169%" goto /i END_OF_GET_LYRICS
                        rem so at this point it wwas marked lyricless, but we’re also forcing. So we should potentially check the lyrics first, and not force a download over it.
                        set did_not_go_to_end_169=1
                        unset /q ANSWER hold_answer
                        rem TODO maybe should not be 0 unless thorough mode
                        call AskYN "Unmark them as lyric%underline_on%%italics_on%less%italics_off%%underline_off% %faint_on%(so that we can download lyrics afterall)%faint_off%" yes 10
                                iff "Y" == "%ANSWER%" then
                                        call unapprove-lyriclessness "%AUDIO_FILE%"
                                        set LYRICLESSNESS_STATUS=NOT_APPROVED
                                        set  JUST_APPROVED_LYRICLESSNESS=0
                                        set DO_NOT_ASK_TO_SET_LYRICLESS_AGAIN=1
                                        rem At this point we need to kind of start over?
                                        goto /i begin_checking_if_this_is_one_we_should_process_or_not
                                endiff
        :end_of_refresh_lyriclessness
        :not_lyricless

rem Delete lyrics if they are zero bytes...
        iff 0 eq %@FILESIZE["%LYRIC_FILE%"] then
                call warning "Deleting 0-byte lyric file: %faint_on%%LYRIC_FILE%%faint_off%" silent
                gosub delete_file /q "%LYRIC_FILE%"
                goto /i top
        endiff

rem Catch our breath
        if "1" == "%goto_end%"      goto /i END_OF_GET_LYRICS
        if not exist "%LYRIC_FILE%" goto /i start_lyric_download_process
        rem call get-lyric-status "%LYRIC_FILE%" silent
        if "%LYRIC_STATUS%" == "" gosub refresh_lyric_status

rem Skip if the lyrics are already approved:
        iff "%LYRIC_STATUS%" == "APPROVED" .and. "%2" != "SetVarsOnly" .and. "1" != "%FORCE_REGEN_LYRICS%" then
                rem if "1" == "%QUICK_LRC_MODE%" gosub divider
                    if "1" == "%QUICK_LRC_MODE%" gosub divider
                call success "Lyrics already approved for “%italics_on%%@name[%audio_file%]%italics_off%”!"
                if not defined LONGEST_POSSIBLE_HAND_EDIT_TIME_IN_SECONDS set LONGEST_POSSIBLE_HAND_EDIT_TIME_IN_SECONDS=800
                if not defined EDIT_KARAOKE_AFTER_CREATION_WAIT_TIME      set EDIT_KARAOKE_AFTER_CREATION_WAIT_TIME=%LONGEST_POSSIBLE_HAND_EDIT_TIME_IN_SECONDS% 
                if "1" != "%QUICK_LRC_MODE%" goto /i END_OF_GET_LYRICS
        endiff
        if "1" == "%goto_end%" goto /i END_OF_GET_LYRICS
        :this_is_line_825          

rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━     GENIUS-ONLY 

rem If we are in Genius-download-only mode, skip if we’ve already tried it for this song:
        iff "1" == "%GENIUS_ONLY%" then
                set GENIUS_SEARCHED_ALREADY=%@ExecStr[type <"%@UNQUOTE["%AUDIO_FILE%"]:genius_searched_already" >&>nul]`` 
                rem Setting genius_searched_already to 0 here forces a redo of all old searches. This could later be expanded into a ’re-search’/’delete search history’ type parameter
                rem set genius_search_status=%@EXECSTR[type <"%@UNQUOTE["%AUDIO_FILE%"]:genius_searched_already" >&>nul]
                set     genius_search_status=%GENIUS_SEARCHED_ALREADY%
                echo.

                rem DEBUG: pause "GENIUS_SEARCHED_ALREADY is “%GENIUS_SEARCHED_ALREADY%” for “%audio_file%”  🐻"
                iff "%genius_search_status%" == "True" then
                        gosub divider
                        rem echo displayaudiofilename 01
                        gosub DisplayAudioFileName %AUDIO_FILE%
                        echo %star% %conceal_off%%ansi_color_bright_yellow%Already searched this file in genius-only mode. Skipping.%ansi_color_reset%
                        goto /i END_OF_GET_LYRICS
                endiff
        endiff


rem ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━     WARN TXT FILE EXISTS

rem Check if we already have a TXT file in the same folder and shouldn’t even be running this:
        :nevermind_on_probe_due_to_having_lyrics
        iff exist "%LYRIC_FILE%" .and. %@FILESIZE["%LYRIC_FILE%"] gt 0 then

                rem Warn that lyrics :
                        rem echos  ``
                        iff "1" != "%JUST_GENERATED_LYRICS" then
                                gosub divider
                                if "%LYRICLESSNESS_STATUS%" == "" call get-lyriclessness-status "%AUDIO_FILE%"
                                if "%LYRIC_STATUS%"         == "" call get-lyric-status         "%LYRIC_FILE%"

                                set NOT_APPROVED_STR=%ansi_color_red%NOT_APPROVED
                                echo %ansi_color_warning_soft%%star2% Current folder:            %ZZZZZZZZZZZZZZZZZZZZZZZ%%ansi_color_bright_green%“%ansi_color_warning_soft%%faint_on%%[_CWP]%faint_off%%ansi_color_bright_green%”
                                echo %ansi_color_warning_soft%%star2% Audio file:                %ZZZZZZZZZZZZZZZZZZZZZZZ%%ansi_color_bright_green%“%ansi_color_warning_soft%%emphasis%%AUDIO_FILE%%deemphasis%%ansi_color_bright_green%”
                                echo %ansi_color_warning_soft%%star2% Lyrics already exist       %ZZZZZZZZZZZZZZZZZZZZZZZ%%ansi_color_bright_green%“%ansi_color_warning_soft%%emphasis%%LYRIC_FILE%%deemphasis%%ansi_color_bright_green%”
                                echo %ansi_color_warning_soft%%star2% Lyrics approval status:    %ZZZZZZZZZZZZZZZZZZZZZZZ%%ansi_color_bright_green%“%ansi_color_warning_soft%%emphasis%%@IF["" !=         "%LYRIC_STATUS%",%LYRIC_STATUS%,%NOT_APPROVED_STR%]%deemphasis%%ansi_color_bright_green%”
                                echo %ansi_color_warning_soft%%star2% Lyric%italics_on%less%italics_off% approval status: %ansi_color_bright_green%“%ansi_color_warning_soft%%emphasis%%@IF["" != "%LYRICLESSNESS_STATUS%",%LYRICLESSNESS_STATUS%,%NOT_APPROVED_STR%]%deemphasis%%ansi_color_bright_green%”%ansi_color_normal%
                        endiff

                rem If we’re in “Genius” mode—which is for unattended mass/batch 1ˢᵗ-pass Genius downloads, 
                rem then abort. We don’t want unattended lyric-overwrites. Those are for when we are at the keyboard.
                rem This mode is for when we are asleep/unattended
                        if "1" == "%GENIUS_ONLY%" goto /i END_OF_GET_LYRICS





