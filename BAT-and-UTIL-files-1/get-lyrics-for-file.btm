                set LAST_LYRIC_RETRIEVAL_COMMAND=%LYRIC_RETRIEVAL_COMMAND%
                rem  LYRIC_RETRIEVAL_COMMAND=“%LYRIC_RETRIEVAL_COMMAND%”
                rem ((echo y | %LYRIC_RETRIEVAL_COMMAND%) |:u8 insert-before-each-line.py "            " |:u8 copy-move-post.py whisper)    %+ rem temporarily disabling this until we get that leak fixed ... actually i don’t thik it was related to that leak but making this one moment color cycle really isn’t important
                rem ((echo y | %LYRIC_RETRIEVAL_COMMAND%) |:u8 insert-before-each-line.py "            ")
                rem ((echo y | %LYRIC_RETRIEVAL_COMMAND%) |:u8 insert-before-each-line.py "            " |:u8 strip-ansi |:u8 highlight "Wrote \b.*.json" |:u8 gr -v q.*].*#CF5500)
                rem ((echo y | %LYRIC_RETRIEVAL_COMMAND%) |:u8 insert-before-each-line.py "            " |:u8 strip-ansi |:u8 highlight       "\b.*.json" |:u8 gr -v q.*].*#CF5500) %+ rem CF5500 is just a kludge for something else not working right at the moment and i’m not even sure if it’s still happening or not
                rem ((echo y | %LYRIC_RETRIEVAL_COMMAND%) |:u8 insert-before-each-line.py "          "   |:u8 strip-ansi |:u8 highlight       "\b.*.json" |:u8 gr -v q.*].*#CF5500) %+ rem CF5500 is just a kludge for something else not working right at the moment and i’m not even sure if it’s still happening or not
                rem ((echo y | %LYRIC_RETRIEVAL_COMMAND%) |:u8 insert-before-each-line.py "          "   |:u8 strip-ansi |:u8 highlight       "\b.*.json")                          %+ rem CF5500 is just a kludge for something else not working right at the moment and i’m not even sure if it’s still happening or not
                *setdos /x-89
                    rem *eset LYRIC_RETRIEVAL_COMMAND

                if "%CURRENT_LYRIC_PROVIDER%" == "SyncedLyrics" goto provide_SyncedLyrics
                                                                goto provide_LyricsGenius

                        :provide_SyncedLyrics
                        rem call debug "Initiating search with %italics_on%SyncedLyrics%italics_off%..." silent

                        rem Unset any flags laying about that relate to this section:
                                unset /q REPLACE_ELRC REPLACE_LRC REPLACE_TXT KEEP_ELRC KEEP_LRC KEEP_TXT COMPARE1 COMPARE2 COMPARE3 COMPARE4 COMPARE5 COMPARE6 ANSWER_252825 TEXT_SHOWN SHOW_COMPARISON COMPARISON_FILE LRC_COMPARISON_FILENAME TXT_FILE_REVIEWED LAST_FILE_LENGTH LENGTH_SS_* 

                        rem Fetch mode:
                                rem Define search mode mode variables:
                                        set SYNCEDLYRICS_MODE_A_4PRINT=all%[ansi_color_less_unimportant]... LRC %italics_on%%ZZZZZZZZ%and%ZZZZZZ%%italics_off% TXT %italics_on%and%italics_off% ELRC
                                        set SYNCEDLYRICS_MODE_L_4PRINT=LRC%[ansi_color_less_unimportant] file %italics_on%%ZZZZZZZZZZ%only%ZZZZZ%%italics_off% 
                                        set SYNCEDLYRICS_MODE_T_4PRINT=TXT%[ansi_color_less_unimportant] lyrics %italics_on%%ZZZZZZZZ%only%ZZZZZ%%italics_off% 
                                        set SYNCEDLYRICS_MODE_B_4PRINT=both%ansi_color_less_unimportant% LRC file %italics_on%a%ZZZZZ%nd%ZZZZZZZ%%italics_off% TXT lyrics
                                                                   
                                rem Set default modes only if not already set; otherwise, carryover modes from previous runs:
                                        if not defined SYNCEDLYRICS_MODE       set SYNCEDLYRICS_MODE=A 
                                        if not defined SYNCEDLYRICS_MODE4PRINT set SYNCEDLYRICS_MODE4PRINT=%SYNCEDLYRICS_MODE_A_4PRINT%

                                rem Ask which mode to use, unless it’s quick-LRC-mode then we jump right into mode “L”:
                                :ask_about_mode
                                        iff "1" != "%QUICK_LRC_MODE%" then
                                                call less_important " %faint_on%Current file fetching mode is:%faint_off% %italics_on%%SYNCEDLYRICS_MODE4PRINT%%italics_off%"
                                                call advice          "Key to change fetch modes: %ansi_color_bright_green%K%ansi_color_prompt%=LRC only, %ansi_color_bright_green%T%ansi_color_prompt%=TXT only, %ansi_color_bright_green%B%ansi_color_prompt%=both LRC+TXT, %ansi_color_bright_green%A%ansi_color_prompt%ll (LRC+TXT+ELRC)"
                                                set PROCEED_WAIT_TIME=60
                                                if "1" == "%QUICK_LRC_MODE%" set PROCEED_WAIT_TIME=20
                                                call AskYn "Proceed? [Y/N/%ansi_color_bright_green%G%ansi_color_prompt%enius search/%ansi_color_bright_green%U%ansi_color_prompt%nset search history/%ansi_color_bright_green%I%ansi_color_prompt%nstrum/%ansi_color_bright_green%S%ansi_color_prompt%nd clip,%ansi_color_bright_green%F%ansi_color_prompt%ail]"  yes %PROCEED_WAIT_TIME% YNKTBAGUISLF  Y:Yes_proceed_to_fetching,N:No,B:fetch_TXT_lyrics_and_LRC_file,A:fetch_TXT_and_LRC_and_ELRC,K:fetch_LRC_only,T:fetch_TXT_lyrics_only,G:switch_to_LyricsGenius_search,U:unset_search_history,I:mark_it_as_instrumental,S:mark_it_as_sound_clip,L:mark_as_lyricless!!!!!,F:fail_out_of_this_one
                                        else
                                                set SYNCEDLYRICS_MODE=L 
                                                set SYNCEDLYRICS_MODE4PRINT=%SYNCEDLYRICS_MODE_L_4PRINT%
                                                goto /i :ask_about_mode_end
                                        endiff
                                        gosub check_for_answer_of_L "%@UNQUOTE[%AUDIO_FILE%]"
                                        gosub check_for_answer_of_I "%@UNQUOTE[%AUDIO_FILE%]"
                                        gosub check_for_answer_of_S "%@UNQUOTE[%AUDIO_FILE%]"
                                        rem gosub check_for_answer_of_F "%@UNQUOTE[%AUDIO_FILE%]"
                                        if "F" == "%ANSWER%"  goto /i end_quick_lrc_mode_fail
                                        if "I" == "%ANSWER%"  goto /i end_quick_lrc_mode_skip
                                        if "S" == "%ANSWER%"  gosub ask_about_mode
                                        rem N" == "%ANSWER%" (call important_less "Skipping this lyric search"                                    %+ goto :skip_only_this_search2413)
                                        if "N" == "%ANSWER%" (call important_less "Skipping this lyric search"                                    %+ goto :skip_only_this_search)
